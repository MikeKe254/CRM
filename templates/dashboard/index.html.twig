                    <span class="text-xs font-bold text-white">{{ c.name|first }}</span>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold text-gray-800 truncate">{{ c.name }}</p>
                    <p class="text-xs text-gray-400">{{ c.visits }} visits</p>
                </div>
                <div class="text-right flex-shrink-0">
                    <p class="text-xs font-bold text-gray-800">{{ c.spend }}</p>
                    <span class="text-xs font-semibold px-1.5 py-0.5 rounded {{ c.bc }}">{{ c.badge }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {# Loyalty snapshot #}
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden" style="box-shadow:0 1px 4px rgba(0,0,0,.05);">
        <div class="px-5 py-4 border-b border-gray-100">
            <p class="text-sm font-semibold text-gray-900">Loyalty Snapshot</p>
            <p class="text-xs text-gray-400 mt-0.5">Points economy this month</p>
        </div>
        <div class="px-5 py-4 space-y-4">
            <div class="grid grid-cols-2 gap-3">
                <div class="bg-indigo-50 rounded-lg p-3 text-center">
                    <p class="text-xl font-bold text-indigo-700">847</p>
                    <p class="text-xs text-indigo-500 mt-0.5">Enrolled</p>
                </div>
                <div class="bg-emerald-50 rounded-lg p-3 text-center">
                    <p class="text-xl font-bold text-emerald-700">312</p>
                    <p class="text-xs text-emerald-500 mt-0.5">Redeemed</p>
                </div>
            </div>
            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <span class="text-xs text-gray-500">Points awarded this month</span>
                    <span class="text-xs font-bold text-gray-800">124,350 pts</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full bg-indigo-500" style="width:73%;"></div>
                </div>
            </div>
            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <span class="text-xs text-gray-500">Points redeemed</span>
                    <span class="text-xs font-bold text-gray-800">42,100 pts</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full bg-emerald-500" style="width:34%;"></div>
                </div>
            </div>
            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <span class="text-xs text-gray-500">Loyalty capture rate</span>
                    <span class="text-xs font-bold text-gray-800">66%</span>
                </div>
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full bg-amber-400" style="width:66%;"></div>
                </div>
            </div>
        </div>
    </div>

    {# What's coming — platform roadmap teaser #}
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden" style="box-shadow:0 1px 4px rgba(0,0,0,.05);">
        <div class="px-5 py-4 border-b border-gray-100">
            <p class="text-sm font-semibold text-gray-900">What's Coming</p>
            <p class="text-xs text-gray-400 mt-0.5">Patronr is actively expanding</p>
        </div>
        <div class="px-5 py-4 space-y-3">
            {% set roadmap = [
                {label: 'Customer Segments',    desc: 'Auto-groups by behaviour',           done: true,  color: 'bg-emerald-500'},
                {label: 'SMS Campaigns',         desc: 'Targeted win-back & rewards',        done: false, color: 'bg-gray-300'},
                {label: 'WhatsApp Messaging',    desc: 'Two-way customer comms',             done: false, color: 'bg-gray-300'},
                {label: 'Campaign Outcomes',     desc: 'Did the action work?',               done: false, color: 'bg-gray-300'},
                {label: 'Revenue Reports',       desc: 'Deep analytics across all pillars',  done: false, color: 'bg-gray-300'},
                {label: 'Event ROI',             desc: 'Which events drive repeat visits?',  done: false, color: 'bg-gray-300'},
            ] %}
            {% for item in roadmap %}
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full flex-shrink-0 {{ item.color }}"></div>
                <div class="flex-1 min-w-0">
                    <p class="text-xs font-semibold text-gray-800">{{ item.label }}</p>
                    <p class="text-xs text-gray-400">{{ item.desc }}</p>
                </div>
                {% if item.done %}
                <svg width="13" height="13" fill="none" stroke="#10b981" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                {% else %}
                <span class="text-xs text-gray-300 font-semibold">Soon</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>

</div>

{# ── Patronr tagline footer ─────────────────────────────────────────────────── #}
<div class="rounded-xl border border-indigo-100 bg-gradient-to-r from-indigo-50 to-purple-50 px-8 py-6 flex flex-wrap items-center justify-between gap-4">
    <div>
        <p class="text-sm font-bold text-indigo-900">Patronr — CRM &amp; Revenue Operating System</p>
        <p class="text-xs text-indigo-600 mt-0.5 max-w-xl leading-relaxed">
            Every transaction is an opportunity to know your customer, classify your revenue, and act on what the data reveals.
            Capture at payment → Understand through data → Act on intelligence → Measure what changed.
        </p>
    </div>
    <div class="flex items-center gap-2 text-xs text-indigo-400 font-semibold">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse inline-block"></span>
        EAT {{ 'now'|date('H:i') }}
    </div>
</div>

{% endblock %}
