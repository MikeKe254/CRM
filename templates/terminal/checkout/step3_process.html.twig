{% extends 'layouts/terminal_app.html.twig' %}
{% set _p = {subdomain: app.request.attributes.get('subdomain'), domain: app.request.attributes.get('domain'), branch: app.request.attributes.get('branch')} %}

{% block title %}Checkout — Process Payment{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;height:100%;overflow:hidden;">

    {# ── Top bar ─────────────────────────────────────────────────────────── #}
    <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid #1f2937;flex-shrink:0;">
        <a href="{{ path('terminal_checkout_step2', _p) }}" class="action-btn"
           style="width:38px;height:38px;background:#1f2937;border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;flex-shrink:0;">
            <svg width="18" height="18" fill="none" stroke="#9ca3af" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
            </svg>
        </a>
        <div style="flex:1;">
            <div style="color:#fff;font-weight:700;font-size:15px;">Process Payment</div>
            <div style="color:#6b7280;font-size:11px;">Step 3 of 5 — {{ payment ? payment.label : 'Payment' }}</div>
        </div>
        <div style="display:flex;gap:5px;align-items:center;">
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#10b981;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
        </div>
    </div>

    {# ── Split progress (only shown when multiple splits) ───────────────── #}
    {% if total_splits is defined and total_splits > 1 %}
    <div style="padding:6px 16px 0;flex-shrink:0;">
        <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:8px 12px;display:flex;align-items:center;justify-content:space-between;">
            <div style="color:#9ca3af;font-size:11px;">Split {{ (split_index ?? 0) + 1 }} of {{ total_splits }}</div>
            <div style="display:flex;gap:4px;">
                {% for i in 0..(total_splits - 1) %}
                <div style="width:{{ i == (split_index ?? 0) ? 20 : 8 }}px;height:6px;border-radius:3px;background:{{ i < (split_index ?? 0) ? '#10b981' : (i == (split_index ?? 0) ? '#3b82f6' : '#374151') }};transition:all .3s;"></div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# ── Amount ──────────────────────────────────────────────────────────── #}
    <div style="padding:8px 16px 6px;text-align:center;flex-shrink:0;">
        {% if total_splits is defined and total_splits > 1 %}
        <div style="color:#9ca3af;font-size:11px;">This split</div>
        <div style="color:#fff;font-size:40px;font-weight:800;font-variant-numeric:tabular-nums;line-height:1.1;">
            KES {{ split_amount is defined ? split_amount|number_format(0, '.', ',') : draft.get('amount', 0)|number_format(0, '.', ',') }}
        </div>
        <div style="color:#6b7280;font-size:12px;margin-top:1px;">
            Total: KES {{ draft.get('amount', 0)|number_format(0, '.', ',') }}
        </div>
        {% else %}
        <div style="color:#9ca3af;font-size:11px;">Amount to collect</div>
        <div style="color:#fff;font-size:40px;font-weight:800;font-variant-numeric:tabular-nums;line-height:1.1;">
            KES {{ draft.get('amount', 0)|number_format(0, '.', ',') }}
        </div>
        {% if draft.get('description') %}
        <div style="color:#6b7280;font-size:12px;margin-top:1px;">{{ draft.get('description') }}</div>
        {% endif %}
        {% endif %}
    </div>

    {# =================== MPESA — all 3 modes =================== #}
    {% if payment and payment.methodKey == 'mpesa' %}

    {# Mode tab selector #}
    <div style="flex-shrink:0;padding:0 16px 0;margin-top:2px;">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;background:#111827;border:1px solid #1f2937;border-radius:14px;padding:4px;">
            <button type="button" id="tab-stk" onclick="switchMode('stk')"
                    class="mode-tab"
                    style="padding:8px 4px;border:none;border-radius:10px;font-size:12px;font-weight:600;cursor:pointer;background:#1f2937;color:#fff;">
                📱 STK Push
            </button>
            <button type="button" id="tab-cb" onclick="switchMode('cb')"
                    class="mode-tab"
                    style="padding:8px 4px;border:none;border-radius:10px;font-size:12px;font-weight:600;cursor:pointer;background:transparent;color:#6b7280;">
                ⏳ Wait
            </button>
            <button type="button" id="tab-manual" onclick="switchMode('manual')"
                    class="mode-tab"
                    style="padding:8px 4px;border:none;border-radius:10px;font-size:12px;font-weight:600;cursor:pointer;background:transparent;color:#6b7280;">
                ✓ Manual
            </button>
        </div>
    </div>

    {# ────────── STK PUSH PANEL ────────── #}
    <div id="panel-stk" style="display:flex;flex-direction:column;flex:1;padding:6px 16px 14px;overflow:hidden;min-height:0;">

        <div id="stk-form-panel" style="display:flex;flex-direction:column;flex:1;min-height:0;">
            <div style="color:#9ca3af;font-size:11px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;flex-shrink:0;">Customer Phone (M-Pesa)</div>
            <div style="background:#111827;border:1px solid #1f2937;border-radius:14px;padding:10px;text-align:center;margin-bottom:6px;flex-shrink:0;">
                <div id="stk-phone-display"
                     style="color:#fff;font-size:26px;font-family:ui-monospace,monospace;letter-spacing:.12em;font-weight:600;">0___ ___ ___</div>
                <input type="hidden" id="stk-phone-input" value="{{ draft.get('stk_phone', '') }}">
            </div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;flex:1;min-height:0;">
                {% for n in [1,2,3,4,5,6,7,8,9] %}
                <button type="button" class="keypad-btn" onclick="stkKey('{{ n }}')"
                        style="background:#1f2937;border:none;border-radius:12px;color:#fff;font-size:20px;font-weight:600;">{{ n }}</button>
                {% endfor %}
                <button type="button" class="keypad-btn" onclick="stkClear()"
                        style="background:#1f2937;border:none;border-radius:12px;color:#9ca3af;font-size:12px;font-weight:600;">CLR</button>
                <button type="button" class="keypad-btn" onclick="stkKey('0')"
                        style="background:#1f2937;border:none;border-radius:12px;color:#fff;font-size:20px;font-weight:600;">0</button>
                <button type="button" class="keypad-btn" onclick="stkBack()"
                        style="background:#1f2937;border:none;border-radius:12px;color:#9ca3af;font-size:20px;">⌫</button>
            </div>
            <button id="stk-send-btn" onclick="stkSend()"
                    style="width:100%;height:50px;background:#16a34a;border:none;border-radius:12px;color:#fff;font-size:16px;font-weight:700;margin-top:6px;flex-shrink:0;opacity:0.35;cursor:not-allowed;">
                Send STK Push
            </button>
        </div>

        <div id="stk-waiting-panel" style="display:none;flex:1;flex-direction:column;align-items:center;justify-content:center;gap:16px;text-align:center;">
            <div style="position:relative;width:72px;height:72px;">
                <div style="width:72px;height:72px;background:rgba(22,163,74,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <svg width="36" height="36" fill="none" stroke="#4ade80" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3m-3 3.75h.008v.008H10.5v-.008zm0 3.75h.008v.008H10.5v-.008zm3-3.75h.008v.008H13.5v-.008zm0 3.75h.008v.008H13.5v-.008z"/>
                    </svg>
                </div>
                <div class="pulse-ring" style="position:absolute;inset:0;border-radius:50%;border:2px solid rgba(74,222,128,0.3);"></div>
            </div>
            <div>
                <div style="color:#fff;font-size:18px;font-weight:700;">Waiting for payment…</div>
                <div id="stk-status-text" style="color:#9ca3af;font-size:13px;margin-top:4px;">Check phone for the M-Pesa prompt</div>
            </div>
            <div id="stk-countdown" style="color:#4b5563;font-size:12px;font-variant-numeric:tabular-nums;"></div>
            <button onclick="stkRetry()" style="background:transparent;border:none;color:#6b7280;font-size:13px;text-decoration:underline;cursor:pointer;">
                Try again with a different number
            </button>
        </div>

        <div id="stk-failed-panel" style="display:none;flex:1;flex-direction:column;align-items:center;justify-content:center;gap:16px;text-align:center;">
            <div style="width:60px;height:60px;background:rgba(239,68,68,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <svg width="28" height="28" fill="none" stroke="#f87171" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
            <div>
                <div style="color:#fff;font-size:18px;font-weight:700;">Payment Failed</div>
                <div id="stk-error-text" style="color:#9ca3af;font-size:13px;margin-top:4px;">The payment was not completed.</div>
            </div>
            <button onclick="stkRetry()"
                    style="width:100%;height:50px;background:#1f2937;border:none;border-radius:12px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;">
                Try Again
            </button>
        </div>

    </div>

    {# ────────── CALLBACK (Wait) PANEL ────────── #}
    <div id="panel-cb" style="display:none;flex-direction:column;flex:1;padding:6px 16px 14px;min-height:0;">

        <div style="background:rgba(22,163,74,0.08);border:1px solid rgba(22,163,74,0.25);border-radius:14px;padding:14px;flex-shrink:0;">
            {% if payment.mpesaType == 'till' %}
            <div style="color:#9ca3af;font-size:11px;margin-bottom:2px;">Buy Goods / Till Number</div>
            <div style="color:#fff;font-size:30px;font-weight:800;font-family:ui-monospace,monospace;">
                {{ payment.cfg('till_number') ?: payment.cfg('shortcode') }}
            </div>
            {% else %}
            <div style="color:#9ca3af;font-size:11px;margin-bottom:2px;">Paybill Number</div>
            <div style="color:#fff;font-size:30px;font-weight:800;font-family:ui-monospace,monospace;">{{ payment.cfg('shortcode') }}</div>
            {% if payment.cfg('account_reference') %}
            <div style="color:#9ca3af;font-size:12px;margin-top:4px;">
                Account: <span style="color:#d1d5db;font-weight:600;">{{ payment.cfg('account_reference') }}</span>
            </div>
            {% endif %}
            {% endif %}
            <div style="color:#6b7280;font-size:11px;margin-top:6px;">
                Customer pays KES {{ (split_amount is defined and total_splits > 1) ? split_amount|number_format(0, '.', ',') : draft.get('amount', 0)|number_format(0,'.', ',') }}
            </div>
        </div>

        {# ── Waiting state ─────────────────────────────────── #}
        <div id="cb-wait-area" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;text-align:center;">
            <div style="position:relative;width:56px;height:56px;">
                <div style="width:56px;height:56px;background:rgba(22,163,74,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <svg width="26" height="26" fill="none" stroke="#4ade80" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="pulse-ring" style="position:absolute;inset:0;border-radius:50%;border:2px solid rgba(74,222,128,0.3);"></div>
            </div>
            <div style="color:#9ca3af;font-size:13px;">Waiting for M-Pesa payment…</div>
        </div>

        {# ── Matches state — cashier picks which payment ───── #}
        <div id="cb-matches-area" style="display:none;flex:1;flex-direction:column;min-height:0;">
            <div style="color:#9ca3af;font-size:11px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;flex-shrink:0;">
                Select the correct payment
            </div>
            <div id="cb-matches-list" style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:8px;">
                {# JS fills this #}
            </div>
        </div>

        {# ── Done state ────────────────────────────────────── #}
        <div id="cb-done-area" style="display:none;flex:1;flex-direction:column;align-items:center;justify-content:center;gap:12px;text-align:center;">
            <div style="width:60px;height:60px;background:rgba(22,163,74,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <svg width="30" height="30" fill="none" stroke="#4ade80" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
            </div>
            <div style="color:#4ade80;font-size:16px;font-weight:700;">Payment claimed!</div>
            <div id="cb-receipt" style="color:#6b7280;font-size:12px;font-family:ui-monospace,monospace;"></div>
        </div>

        <div style="flex-shrink:0;display:flex;flex-direction:column;gap:6px;">
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}" id="cb-confirm-form">
                <button type="submit" id="cb-continue-btn"
                        style="display:none;width:100%;height:50px;background:#059669;border:none;border-radius:12px;color:#fff;font-size:16px;font-weight:700;cursor:pointer;">
                    Continue →
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:8px;background:transparent;border:none;color:#4b5563;font-size:12px;cursor:pointer;">
                    Cancel
                </button>
            </form>
        </div>

    </div>

    {# ────────── MANUAL PANEL ────────── #}
    <div id="panel-manual" style="display:none;flex-direction:column;flex:1;padding:16px 16px 14px;justify-content:space-between;">
        <div style="background:rgba(5,150,105,0.08);border:1px solid rgba(5,150,105,0.3);border-radius:18px;padding:24px;text-align:center;">
            <div style="color:#4ade80;font-size:13px;font-weight:600;margin-bottom:4px;">M-Pesa Payment</div>
            {% if payment.mpesaType == 'till' %}
            <div style="color:#9ca3af;font-size:12px;">
                Till: <span style="color:#d1d5db;font-weight:600;">{{ payment.cfg('till_number') ?: payment.cfg('shortcode') }}</span>
            </div>
            {% else %}
            <div style="color:#9ca3af;font-size:12px;">
                Paybill: <span style="color:#d1d5db;font-weight:600;">{{ payment.cfg('shortcode') }}</span>
            </div>
            {% endif %}
            <div style="color:#fff;font-size:42px;font-weight:800;font-variant-numeric:tabular-nums;margin-top:10px;">
                KES {{ (split_amount is defined and total_splits > 1) ? split_amount|number_format(0, '.', ',') : draft.get('amount', 0)|number_format(0, '.', ',') }}
            </div>
            {% if total_splits is defined and total_splits > 1 %}
            <div style="color:#6b7280;font-size:11px;margin-top:2px;">Total: KES {{ draft.get('amount', 0)|number_format(0, '.', ',') }}</div>
            {% endif %}
            <div style="color:#6b7280;font-size:12px;margin-top:6px;">Confirm once payment is complete on customer's phone.</div>
        </div>
        {% set code_required = payment.cfg('manual_code_required') %}
        <div style="display:flex;flex-direction:column;gap:8px;">
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}" id="manual-confirm-form">
                <div style="margin-bottom:10px;">
                    <div style="color:#6b7280;font-size:11px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">
                        M-Pesa Code{% if code_required %}&nbsp;<span style="color:#ef4444;">required</span>{% else %}&nbsp;<span style="color:#4b5563;">optional</span>{% endif %}
                    </div>
                    <input type="text" name="mpesa_code" id="manual-mpesa-code"
                           placeholder="e.g. QHX4AB1234"
                           maxlength="20"
                           autocomplete="off"
                           autocapitalize="characters"
                           style="width:100%;box-sizing:border-box;background:#111827;border:1px solid #374151;border-radius:12px;color:#fff;font-size:17px;font-family:ui-monospace,monospace;font-weight:600;letter-spacing:.06em;padding:13px 16px;outline:none;-webkit-tap-highlight-color:transparent;"
                           oninput="this.value=this.value.toUpperCase();manualCodeInput()">
                </div>
                <button type="submit" id="manual-confirm-btn"
                        style="width:100%;height:56px;background:#059669;border:none;border-radius:14px;color:#fff;font-size:18px;font-weight:700;cursor:pointer;transition:opacity .15s;{% if code_required %}opacity:.4;{% endif %}"
                        {% if code_required %}disabled{% endif %}>
                    ✓ &nbsp;M-Pesa Received
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:12px;background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;">
                    Cancel
                </button>
            </form>
        </div>
        <script>
        (function() {
            var required = {{ code_required ? 'true' : 'false' }};
            window.manualCodeInput = function() {
                var val = document.getElementById('manual-mpesa-code').value.trim();
                var btn = document.getElementById('manual-confirm-btn');
                var ok  = !required || val.length >= 6;
                btn.disabled     = !ok;
                btn.style.opacity = ok ? '1' : '.4';
            };
        })();
        </script>
    </div>

    {# =================== CASH =================== #}
    {% elseif payment and payment.methodKey == 'cash' %}

    <div style="flex:1;display:flex;flex-direction:column;padding:16px 16px 20px;justify-content:space-between;">
        <div style="background:rgba(5,150,105,0.1);border:1px solid rgba(5,150,105,0.4);border-radius:20px;padding:28px;text-align:center;">
            <div style="color:#34d399;font-size:14px;font-weight:600;margin-bottom:8px;">Collect from customer</div>
            <div style="color:#fff;font-size:44px;font-weight:800;font-variant-numeric:tabular-nums;">
                KES {{ (split_amount is defined and total_splits > 1) ? split_amount|number_format(0, '.', ',') : draft.get('amount', 0)|number_format(0, '.', ',') }}
            </div>
            {% if total_splits is defined and total_splits > 1 %}
            <div style="color:#6b7280;font-size:12px;margin-top:4px;">Total: KES {{ draft.get('amount', 0)|number_format(0, '.', ',') }}</div>
            {% endif %}
            <div style="color:#6b7280;font-size:13px;margin-top:8px;">Confirm once cash has been physically received.</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}">
                <button type="submit"
                        style="width:100%;height:60px;background:#059669;border:none;border-radius:16px;color:#fff;font-size:20px;font-weight:700;cursor:pointer;">
                    ✓ &nbsp;Cash Received
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:12px;background:transparent;border:none;color:#6b7280;font-size:14px;cursor:pointer;">Cancel</button>
            </form>
        </div>
    </div>

    {# =================== BANK =================== #}
    {% elseif payment and payment.methodKey == 'bank' %}

    <div style="flex:1;display:flex;flex-direction:column;padding:16px 16px 20px;justify-content:space-between;">
        <div style="background:rgba(37,99,235,0.1);border:1px solid rgba(37,99,235,0.3);border-radius:20px;padding:20px;">
            <div style="color:#93c5fd;font-size:14px;font-weight:600;margin-bottom:12px;">Bank Transfer Details</div>
            {% if payment.cfg('account_holder_name') %}
            <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(37,99,235,0.2);">
                <span style="color:#9ca3af;">Account Name</span>
                <span style="color:#fff;font-weight:600;">{{ payment.cfg('account_holder_name') }}</span>
            </div>
            {% endif %}
            {% if payment.cfg('account_number') %}
            <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(37,99,235,0.2);">
                <span style="color:#9ca3af;">Account No.</span>
                <span style="color:#fff;font-weight:600;">{{ payment.cfg('account_number') }}</span>
            </div>
            {% endif %}
            {% if payment.cfg('bank_name') %}
            <div style="display:flex;justify-content:space-between;padding:10px 0;">
                <span style="color:#9ca3af;">Bank</span>
                <span style="color:#fff;font-weight:600;">{{ payment.cfg('bank_name') }}</span>
            </div>
            {% endif %}
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}">
                <button type="submit"
                        style="width:100%;height:60px;background:#2563eb;border:none;border-radius:16px;color:#fff;font-size:20px;font-weight:700;cursor:pointer;">
                    ✓ &nbsp;Transfer Confirmed
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:12px;background:transparent;border:none;color:#6b7280;font-size:14px;cursor:pointer;">Cancel</button>
            </form>
        </div>
    </div>

    {# =================== LOYALTY REDEMPTION =================== #}
    {% elseif payment and payment.methodKey == 'loyalty' %}

    <div style="flex:1;display:flex;flex-direction:column;padding:8px 16px 0;overflow:hidden;min-height:0;">

        {# ── Loyalty banner ───────────────────────────────────────────────── #}
        <div style="background:rgba(217,119,6,0.1);border:1px solid rgba(217,119,6,0.3);border-radius:14px;padding:12px 14px;flex-shrink:0;margin-bottom:8px;">
            <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:34px;height:34px;background:rgba(217,119,6,0.2);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="18" height="18" fill="#d97706" viewBox="0 0 24 24">
                        <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                    </svg>
                </div>
                <div>
                    <div style="color:#d97706;font-size:13px;font-weight:700;">{{ payment.label }}</div>
                    <div style="color:#9ca3af;font-size:11px;">
                        {{ payment.cfg('kes_per_point', 1)|number_format(2) }} KES per {{ payment.cfg('points_symbol', 'pt') }}
                        · deducting KES {{ split_amount is defined ? split_amount|number_format(0, '.', ',') : draft.get('amount', 0)|number_format(0, '.', ',') }}
                    </div>
                </div>
            </div>
        </div>

        {# ── Panels — positioned absolute inside a relative container ──────── #}
        <div style="flex:1;min-height:0;position:relative;overflow:hidden;">

            {# Auto-confirm #}
            <div id="loyalty-auto-panel" style="display:none;position:absolute;inset:0;flex-direction:column;gap:10px;overflow-y:auto;">
                <div style="background:#111827;border:1px solid #1f2937;border-radius:14px;padding:16px;">
                    <div style="color:#9ca3af;font-size:11px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">Customer</div>
                    <div id="auto-phone-display" style="color:#fff;font-size:22px;font-family:ui-monospace,monospace;font-weight:700;letter-spacing:.08em;"></div>
                    <div id="auto-pts-display" style="color:#10b981;font-size:13px;margin-top:6px;"></div>
                </div>
                <div style="background:rgba(217,119,6,0.08);border:1px solid rgba(217,119,6,0.25);border-radius:14px;padding:14px;display:flex;align-items:center;justify-content:space-between;">
                    <div style="color:#d97706;font-size:13px;">Points to deduct</div>
                    <div id="auto-deduct-display" style="color:#fff;font-size:18px;font-weight:800;"></div>
                </div>
            </div>

            {# Keypad #}
            <div id="loyalty-phone-panel" style="display:none;position:absolute;inset:0;flex-direction:column;gap:4px;">
                <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:8px;text-align:center;flex-shrink:0;">
                    <div id="loy-phone-display" style="color:#fff;font-size:22px;font-family:ui-monospace,monospace;letter-spacing:.1em;font-weight:600;">0___ ___ ___</div>
                    <div id="loy-status" style="color:#6b7280;font-size:12px;margin-top:2px;min-height:15px;"></div>
                </div>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:4px;flex:1;min-height:0;overflow:hidden;">
                    {% for n in [1,2,3,4,5,6,7,8,9] %}
                    <button type="button" class="keypad-btn" onclick="loyKey('{{ n }}')"
                            style="background:#1f2937;border:none;border-radius:10px;color:#fff;font-size:19px;font-weight:600;min-height:0;">{{ n }}</button>
                    {% endfor %}
                    <button type="button" class="keypad-btn" onclick="loyClear()"
                            style="background:#1f2937;border:none;border-radius:10px;color:#9ca3af;font-size:11px;font-weight:600;min-height:0;">CLR</button>
                    <button type="button" class="keypad-btn" onclick="loyKey('0')"
                            style="background:#1f2937;border:none;border-radius:10px;color:#fff;font-size:19px;font-weight:600;min-height:0;">0</button>
                    <button type="button" class="keypad-btn" onclick="loyBackspace()"
                            style="background:#1f2937;border:none;border-radius:10px;color:#9ca3af;font-size:18px;min-height:0;">⌫</button>
                </div>
            </div>

            {# Done #}
            <div id="loyalty-done-panel" style="display:none;position:absolute;inset:0;flex-direction:column;align-items:center;justify-content:center;gap:14px;text-align:center;">
                <div style="width:60px;height:60px;background:rgba(217,119,6,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <svg width="30" height="30" fill="none" stroke="#d97706" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                    </svg>
                </div>
                <div>
                    <div style="color:#fff;font-size:18px;font-weight:700;">Points Redeemed!</div>
                    <div id="loy-done-text" style="color:#9ca3af;font-size:13px;margin-top:4px;"></div>
                </div>
            </div>

        </div>

        {# ── Pinned bottom buttons ─────────────────────────────────────────── #}
        <div style="flex-shrink:0;padding:8px 0 14px;display:flex;flex-direction:column;gap:6px;">
            <button id="loy-confirm-btn" onclick="loyRedeem()"
                    style="width:100%;height:52px;background:#d97706;border:none;border-radius:13px;color:#fff;font-size:16px;font-weight:700;opacity:0.4;cursor:not-allowed;">
                Confirm Redemption
            </button>
            <button id="loy-diff-btn" onclick="switchLoyPanel('keypad')" style="display:none;width:100%;padding:8px;background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;">
                Different customer?
            </button>
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}" id="loy-continue-form" style="display:none;">
                <button type="submit" style="width:100%;height:52px;background:#059669;border:none;border-radius:13px;color:#fff;font-size:16px;font-weight:700;cursor:pointer;">
                    Continue →
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:8px;background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;">
                    Cancel
                </button>
            </form>
        </div>

    </div>

    {# =================== PESAPAL / OTHER =================== #}
    {% else %}

    <div style="flex:1;display:flex;flex-direction:column;padding:16px 16px 20px;justify-content:space-between;">
        <div style="background:#111827;border:1px solid #1f2937;border-radius:20px;padding:28px;text-align:center;">
            <div style="color:#d1d5db;font-size:14px;margin-bottom:8px;">{{ payment ? payment.label : 'Payment' }}</div>
            <div style="color:#fff;font-size:44px;font-weight:800;font-variant-numeric:tabular-nums;">
                KES {{ draft.get('amount', 0)|number_format(0, '.', ',') }}
            </div>
            <div style="color:#6b7280;font-size:13px;margin-top:8px;">
                Complete payment via {{ payment ? payment.label : 'selected method' }}, then confirm below.
            </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            <form method="post" action="{{ path('terminal_checkout_confirm', _p) }}">
                <button type="submit"
                        style="width:100%;height:60px;background:#7c3aed;border:none;border-radius:16px;color:#fff;font-size:20px;font-weight:700;cursor:pointer;">
                    ✓ &nbsp;Payment Confirmed
                </button>
            </form>
            <form method="post" action="{{ path('terminal_checkout_cancel', _p) }}">
                <button type="submit" style="width:100%;padding:12px;background:transparent;border:none;color:#6b7280;font-size:14px;cursor:pointer;">Cancel</button>
            </form>
        </div>
    </div>

    {% endif %}

</div>

{% if payment and payment.methodKey == 'mpesa' %}
<style>
.claim-card {
    width:100%;background:#111827;border:1px solid #1f2937;border-radius:14px;
    padding:14px 16px;display:flex;align-items:center;justify-content:space-between;
    cursor:pointer;text-align:left;
}
.claim-card-icon {
    width:38px;height:38px;background:rgba(22,163,74,0.15);border-radius:10px;
    display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.claim-card-name  { color:#fff;font-size:15px;font-weight:700; }
.claim-card-phone { color:#6b7280;font-size:12px;font-family:ui-monospace,monospace; }
.claim-card-kes   { color:#4ade80;font-size:15px;font-weight:700; }
.claim-card-ref   { color:#374151;font-size:11px;font-family:ui-monospace,monospace; }

[data-theme="light"] .claim-card        { background:#ffffff !important; border-color:#e2e8f0 !important; }
[data-theme="light"] .claim-card-icon   { background:rgba(22,163,74,0.12) !important; }
[data-theme="light"] .claim-card-name   { color:#0f172a !important; }
[data-theme="light"] .claim-card-phone  { color:#64748b !important; }
[data-theme="light"] .claim-card-kes    { color:#15803d !important; }
[data-theme="light"] .claim-card-ref    { color:#94a3b8 !important; }
</style>
<script>
(function() {
    const stkPushUrl    = '{{ path('terminal_checkout_stk_push', _p) }}';
    const stkStatusUrl  = '{{ path('terminal_checkout_stk_status', _p) }}';
    const cbStatusUrl   = '{{ path('terminal_checkout_callback_status', _p) }}';
    const nextUrl       = '{{ path('terminal_checkout_step3', _p) }}'; // step3 controller forwards to step4 when draft advances
    const defaultMode   = '{{ payment.integrationMode ?? 'stk' }}' === 'callback' ? 'cb'
                        : ('{{ payment.integrationMode ?? 'stk' }}' === 'manual' ? 'manual' : 'stk');

    // ── Mode tabs ──────────────────────────────────────────────────────────
    const panels = { stk: 'panel-stk', cb: 'panel-cb', manual: 'panel-manual' };
    const tabs   = { stk: 'tab-stk',   cb: 'tab-cb',   manual: 'tab-manual'   };
    let cbPollInterval = null;

    window.switchMode = mode => {
        Object.entries(panels).forEach(([k, id]) => {
            const el = document.getElementById(id);
            if (el) el.style.display = k === mode ? 'flex' : 'none';
        });
        Object.entries(tabs).forEach(([k, id]) => {
            const el = document.getElementById(id);
            if (!el) return;
            if (k === mode) {
                el.style.background = '#1f2937';
                el.style.color = '#fff';
            } else {
                el.style.background = 'transparent';
                el.style.color = '#6b7280';
            }
        });

        if (mode === 'cb') startCbPolling();
        else stopCbPolling();
    };

    // ── STK Push ───────────────────────────────────────────────────────────
    const phoneDisplay = document.getElementById('stk-phone-display');
    const phoneInput   = document.getElementById('stk-phone-input');
    const sendBtn      = document.getElementById('stk-send-btn');
    const formPanel    = document.getElementById('stk-form-panel');
    const waitPanel    = document.getElementById('stk-waiting-panel');
    const failPanel    = document.getElementById('stk-failed-panel');

    let raw = (phoneInput?.value || '').replace(/\D/g,'').replace(/^254/,'0');
    let pollInterval = null, pollCount = 0, checkoutId = null;

    function renderPhone() {
        const d = raw.padEnd(10, '_');
        phoneDisplay.textContent = d.slice(0,4)+' '+d.slice(4,7)+' '+d.slice(7,10);
        const ok = raw.length === 10;
        sendBtn.style.opacity = ok ? '1' : '0.35';
        sendBtn.style.cursor  = ok ? 'pointer' : 'not-allowed';
    }

    window.stkKey   = k => { if (raw.length < 10) { raw += k; renderPhone(); } };
    window.stkBack  = () => { raw = raw.slice(0,-1); renderPhone(); };
    window.stkClear = () => { raw = ''; renderPhone(); };

    window.stkSend = async () => {
        if (raw.length !== 10) return;
        formPanel.style.display = 'none';
        waitPanel.style.display = 'flex';
        failPanel.style.display = 'none';
        pollCount = 0;
        try {
            const fd = new FormData(); fd.append('phone', raw);
            const data = await (await fetch(stkPushUrl, { method:'POST', body: fd })).json();
            if (!data.success) {
                document.getElementById('stk-error-text').textContent = data.message || 'Failed to send push.';
                waitPanel.style.display = 'none'; failPanel.style.display = 'flex'; return;
            }
            checkoutId = data.checkout_request_id;
            startStkPolling();
        } catch(e) {
            document.getElementById('stk-error-text').textContent = 'Network error — try again.';
            waitPanel.style.display = 'none'; failPanel.style.display = 'flex';
        }
    };

    function startStkPolling() {
        const maxPolls = 40;
        const cdEl = document.getElementById('stk-countdown');
        let remaining = 120;
        pollInterval = setInterval(async () => {
            pollCount++;
            remaining = Math.max(0, 120 - pollCount * 3);
            cdEl.textContent = `Expires in ${Math.floor(remaining/60)}:${String(remaining%60).padStart(2,'0')}`;
            if (pollCount >= maxPolls) {
                clearInterval(pollInterval);
                document.getElementById('stk-error-text').textContent = 'Payment timed out.';
                waitPanel.style.display = 'none'; failPanel.style.display = 'flex'; return;
            }
            try {
                const data = await (await fetch(stkStatusUrl + '?checkout_id=' + encodeURIComponent(checkoutId))).json();
                if (data.status === 'complete') {
                    clearInterval(pollInterval);
                    if (window.Turbo) window.Turbo.visit(nextUrl); else location.href = nextUrl;
                } else if (data.status === 'failed' || data.status === 'cancelled') {
                    clearInterval(pollInterval);
                    document.getElementById('stk-error-text').textContent = data.message || 'Payment was declined.';
                    waitPanel.style.display = 'none'; failPanel.style.display = 'flex';
                }
            } catch(e) {}
        }, 3000);
    }

    window.stkRetry = () => {
        clearInterval(pollInterval);
        checkoutId = null; pollCount = 0; raw = '';
        renderPhone();
        failPanel.style.display = 'none'; waitPanel.style.display = 'none'; formPanel.style.display = 'flex';
    };

    renderPhone();

    // ── Callback polling ───────────────────────────────────────────────────
    const claimUrl = '{{ path('terminal_checkout_claim_payment', _p) }}';
    let cbDone = false;

    function showCbWait()    {
        document.getElementById('cb-wait-area').style.display    = 'flex';
        document.getElementById('cb-matches-area').style.display = 'none';
        document.getElementById('cb-done-area').style.display    = 'none';
    }
    function showCbMatches(payments) {
        document.getElementById('cb-wait-area').style.display    = 'none';
        document.getElementById('cb-matches-area').style.display = 'flex';
        document.getElementById('cb-done-area').style.display    = 'none';

        const list = document.getElementById('cb-matches-list');
        list.innerHTML = '';
        payments.forEach(p => {
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'claim-card';
            card.innerHTML = `
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="claim-card-icon">
                        <svg width="18" height="18" fill="none" stroke="#4ade80" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="claim-card-name">${p.name}</div>
                        <div class="claim-card-phone">···${p.phone_tail}</div>
                    </div>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                    <div class="claim-card-kes">KES ${Number(p.amount).toLocaleString()}</div>
                    ${p.receipt ? `<div class="claim-card-ref">${p.receipt}</div>` : ''}
                </div>`;
            card.onclick = () => claimPayment(p.id);
            list.appendChild(card);
        });
    }
    function showCbDone(receipt) {
        document.getElementById('cb-wait-area').style.display    = 'none';
        document.getElementById('cb-matches-area').style.display = 'none';
        document.getElementById('cb-done-area').style.display    = 'flex';
        if (receipt) document.getElementById('cb-receipt').textContent = 'Ref: ' + receipt;
        document.getElementById('cb-continue-btn').style.display = 'block';
    }

    async function claimPayment(id) {
        cbDone = true;
        clearInterval(cbPollInterval);
        try {
            const fd = new FormData(); fd.append('mpesa_payment_id', id);
            const data = await (await fetch(claimUrl, { method: 'POST', body: fd })).json();
            if (data.ok) {
                showCbDone(data.receipt);
                setTimeout(() => {
                    if (window.Turbo) window.Turbo.visit(nextUrl); else location.href = nextUrl;
                }, 1200);
            } else {
                // Row may have been claimed by someone else — restart polling
                cbDone = false;
                showCbWait();
                startCbPolling();
            }
        } catch(e) {
            cbDone = false;
            showCbWait();
            startCbPolling();
        }
    }

    function startCbPolling() {
        if (cbDone) return;
        cbPollInterval = setInterval(async () => {
            if (cbDone) { clearInterval(cbPollInterval); return; }
            try {
                const data = await (await fetch(cbStatusUrl)).json();
                if (data.status === 'matches') {
                    // Refresh the list every poll — new payments may arrive while cashier is looking
                    showCbMatches(data.payments);
                }
                // status === 'pending' while matches are showing → do nothing, keep list as-is
            } catch(e) {}
        }, 3000);
    }
    function stopCbPolling() { clearInterval(cbPollInterval); }

    window.cbManualConfirm = () => {
        stopCbPolling(); cbDone = true;
        const f = document.getElementById('cb-confirm-form');
        (f.requestSubmit ? f.requestSubmit() : f.submit());
    };

    // ── Init ───────────────────────────────────────────────────────────────
    switchMode(defaultMode);
})();
</script>
{% endif %}

{% if payment and payment.methodKey == 'loyalty' %}
<script>
(function() {
    const redeemUrl    = '{{ path('terminal_checkout_loyalty_redeem', _p) }}';
    const balanceUrl   = '{{ path('terminal_checkout_redemption_balance', _p) }}';
    const totalBill    = {{ draft.get('amount', 0)|number_format(0, '.', '') }};
    const confirmUrl   = '{{ path('terminal_checkout_confirm', _p) }}';

    {# Pre-fill from loy_phone in the current split (entered at step 2) #}
    {% set _cur_split = splits[split_index] ?? {} %}
    const prefillPhone = '{{ (_cur_split.loy_phone ?? draft.get('stk_phone', ''))|e('js') }}';
    let raw = prefillPhone.replace(/\D/g, '').replace(/^254/, '0');
    let lookupTimer = null;
    let accountData = null;

    // ── Panel switcher ─────────────────────────────────────────────────────
    function switchLoyPanel(which) {
        document.getElementById('loyalty-auto-panel').style.display  = which === 'auto'   ? 'flex' : 'none';
        document.getElementById('loyalty-phone-panel').style.display = which === 'keypad' ? 'flex' : 'none';
        document.getElementById('loyalty-done-panel').style.display  = which === 'done'   ? 'flex' : 'none';
        // Confirm button
        const btn  = document.getElementById('loy-confirm-btn');
        const diff = document.getElementById('loy-diff-btn');
        const cont = document.getElementById('loy-continue-form');
        if (which === 'auto') {
            btn.style.display = ''; btn.style.opacity = '1'; btn.style.cursor = 'pointer';
            btn.textContent = 'Confirm Redemption';
            diff.style.display = ''; cont.style.display = 'none';
        } else if (which === 'keypad') {
            btn.style.display = ''; updateKeypadConfirmBtn();
            diff.style.display = 'none'; cont.style.display = 'none';
        } else { // done
            btn.style.display = 'none';
            diff.style.display = 'none'; cont.style.display = '';
        }
    }
    window.switchLoyPanel = switchLoyPanel;

    function showAutoPanel(data) {
        const fmt = n => n.toString().replace(/\D/g,'').replace(/^254/,'0')
                          .replace(/(\d{4})(\d{3})(\d{3})/,'$1 $2 $3');
        document.getElementById('auto-phone-display').textContent = fmt(raw);
        document.getElementById('auto-pts-display').textContent =
            `${data.balance.toLocaleString()} ${data.points_symbol} available · ${data.points_needed} needed`;
        document.getElementById('auto-deduct-display').textContent =
            `${data.points_needed} ${data.points_symbol} · KES ${data.redeemable_kes ?? data.points_needed}`;
        switchLoyPanel('auto');
    }

    // ── Keypad ─────────────────────────────────────────────────────────────
    function renderPhone() {
        const d = raw.padEnd(10, '_');
        document.getElementById('loy-phone-display').textContent =
            d.slice(0,4)+' '+d.slice(4,7)+' '+d.slice(7,10);
        updateKeypadConfirmBtn();
        if (raw.length === 10) scheduleLookup();
        else {
            clearTimeout(lookupTimer);
            accountData = null;
            document.getElementById('loy-status').textContent = '';
            document.getElementById('loy-status').style.color = '#6b7280';
        }
    }

    window.showLoyKeypad = () => { raw = ''; accountData = null; switchLoyPanel('keypad'); renderPhone(); };
    window.loyKey        = k  => { if (raw.length < 10) { raw += k; renderPhone(); } };
    window.loyBackspace  = () => { raw = raw.slice(0,-1); renderPhone(); };
    window.loyClear      = () => { raw = ''; renderPhone(); };

    async function doLookup() {
        const statusEl = document.getElementById('loy-status');
        if (statusEl) { statusEl.textContent = 'Checking\u2026'; statusEl.style.color = '#6b7280'; }
        try {
            const data = await (await fetch(balanceUrl + '?phone=' + encodeURIComponent(raw) + '&amount=' + totalBill)).json();
            if (data.enrolled && data.can_redeem) {
                accountData = data;
                return data;
            } else if (data.enrolled) {
                accountData = null;
                if (statusEl) {
                    const sym = data.points_symbol;
                    let msg;
                    if (data.deny_reason === 'amount_too_low') {
                        msg = `Bill too small \u2014 ${data.max_pct}% limit gives KES 0`;
                    } else if (data.deny_reason === 'no_points') {
                        msg = `No redeemable points`;
                    } else {
                        msg = `${data.balance.toLocaleString()} ${sym} \u2014 not enough for this bill`;
                    }
                    statusEl.textContent = msg;
                    statusEl.style.color = '#ef4444';
                }
            } else {
                accountData = null;
                if (statusEl) { statusEl.textContent = 'Not enrolled in loyalty'; statusEl.style.color = '#ef4444'; }
            }
        } catch(e) {
            accountData = null;
            if (statusEl) { statusEl.textContent = 'Lookup failed'; statusEl.style.color = '#ef4444'; }
        }
        updateKeypadConfirmBtn();
        return null;
    }

    function scheduleLookup() {
        clearTimeout(lookupTimer);
        lookupTimer = setTimeout(async () => {
            const data = await doLookup();
            if (data) {
                showAutoPanel(data); // switch to clean confirm view on success
            }
            updateKeypadConfirmBtn();
        }, 350);
    }

    function updateKeypadConfirmBtn() {
        const btn = document.getElementById('loy-confirm-btn');
        if (!btn) return;
        const ok = raw.length === 10 && accountData !== null;
        btn.style.opacity = ok ? '1' : '0.4';
        btn.style.cursor  = ok ? 'pointer' : 'not-allowed';
    }

    // ── Redeem ─────────────────────────────────────────────────────────────
    window.loyRedeem = async function() {
        if (!accountData) return;
        const btn = document.getElementById('loy-confirm-btn');
        btn.textContent = 'Processing\u2026'; btn.style.opacity = '0.7'; btn.style.cursor = 'not-allowed';
        try {
            const fd = new FormData(); fd.append('phone', raw);
            const data = await (await fetch(redeemUrl, { method:'POST', body: fd })).json();
            if (data.success) {
                document.getElementById('loy-done-text').textContent =
                    `${data.points_redeemed.toLocaleString()} pts redeemed · ${data.balance_after.toLocaleString()} pts remaining`;
                switchLoyPanel('done');
            } else {
                btn.textContent = 'Confirm Redemption'; btn.style.opacity = '1'; btn.style.cursor = 'pointer';
                const statusEl = document.getElementById('loy-status');
                if (statusEl) { statusEl.textContent = data.message || 'Redemption failed'; statusEl.style.color = '#ef4444'; }
            }
        } catch(e) {
            btn.textContent = 'Confirm Redemption'; btn.style.opacity = '1'; btn.style.cursor = 'pointer';
        }
    };

    // ── Init — auto-confirm if phone pre-filled ────────────────────────────
    (async () => {
        if (raw.length === 10) {
            // Show keypad first with phone already populated, then lookup
            switchLoyPanel('keypad');
            renderPhone();
            const data = await doLookup();
            if (data) {
                showAutoPanel(data); // switch to cleaner auto-panel
            }
            // If lookup fails, keypad stays with error shown in loy-status
        } else {
            switchLoyPanel('keypad');
            renderPhone();
        }
    })();
})();
</script>
{% endif %}

{% endblock %}
