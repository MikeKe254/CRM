{% extends 'layouts/terminal_app.html.twig' %}
{% set _p = {subdomain: app.request.attributes.get('subdomain'), domain: app.request.attributes.get('domain'), branch: app.request.attributes.get('branch')} %}

{% block title %}Checkout — Loyalty{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;height:100%;overflow:hidden;">

    {# ── Top bar ─────────────────────────────────────────────────────────── #}
    <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-bottom:1px solid #1f2937;flex-shrink:0;">
        <div style="width:38px;height:38px;background:rgba(234,179,8,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="20" height="20" fill="#eab308" viewBox="0 0 24 24">
                <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
            </svg>
        </div>
        <div style="flex:1;">
            <div style="color:#fff;font-weight:700;font-size:15px;">Loyalty Points</div>
            <div style="color:#6b7280;font-size:11px;">Step 4 of 5 — Award points</div>
        </div>
        <div style="display:flex;gap:5px;align-items:center;">
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#10b981;"></div>
            <div style="width:8px;height:8px;border-radius:50%;background:#374151;"></div>
        </div>
    </div>

    <form method="post" action="{{ path('terminal_checkout_save4', _p) }}"
          id="loyalty-form"
          style="display:flex;flex-direction:column;flex:1;overflow:hidden;min-height:0;">

        {% if program %}

        {# ── Points preview ───────────────────────────────────────────────── #}
        <div style="padding:8px 16px 4px;flex-shrink:0;">
            <div style="background:linear-gradient(135deg,rgba(161,98,7,0.3),rgba(120,53,15,0.2));border:1px solid rgba(161,98,7,0.4);border-radius:14px;padding:10px 14px;display:flex;align-items:center;gap:12px;">
                <div style="width:34px;height:34px;background:rgba(234,179,8,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="18" height="18" fill="#eab308" viewBox="0 0 24 24">
                        <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                    </svg>
                </div>
                <div style="flex:1;">
                    <div style="color:#fde68a;font-size:10px;font-weight:600;">{{ program.program_name }}</div>
                    <div style="color:#fff;font-size:20px;font-weight:800;line-height:1.1;">
                        +{{ points_preview }} <span style="color:#eab308;font-size:12px;">{{ program.points_symbol ?? program.points_name }}</span>
                    </div>
                </div>
                <div id="enroll-status-pill"
                     style="background:#1f2937;border:1px solid #374151;border-radius:20px;padding:3px 10px;font-size:11px;color:#9ca3af;white-space:nowrap;flex-shrink:0;">
                    —
                </div>
            </div>
        </div>

        {# ── Phone display ────────────────────────────────────────────────── #}
        <div style="padding:4px 16px 4px;flex-shrink:0;">
            <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:8px 12px;text-align:center;">
                <div id="loyalty-phone-display"
                     style="color:#fff;font-size:24px;font-family:ui-monospace,monospace;letter-spacing:.12em;font-weight:600;">
                    {% if stk_phone %}{{ stk_phone|slice(0,4) }} {{ stk_phone|slice(4,3) }} {{ stk_phone|slice(7) }}{% else %}0___ ___ ___{% endif %}
                </div>
                <input type="tel" name="phone" id="loyalty-phone-input" readonly value="{{ stk_phone }}"
                       style="position:absolute;opacity:0;pointer-events:none;">
            </div>
        </div>

        {# ── Keypad panel ─────────────────────────────────────────────────── #}
        <div id="keypad-panel" style="flex:1;display:flex;flex-direction:column;padding:0 16px 0;min-height:0;">
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;flex:1;min-height:0;">
                {% for n in [1,2,3,4,5,6,7,8,9] %}
                <button type="button" class="keypad-btn" onclick="loyaltyKey('{{ n }}')"
                        style="background:#1f2937;border:none;border-radius:12px;color:#fff;font-size:20px;font-weight:600;">{{ n }}</button>
                {% endfor %}
                <button type="button" class="keypad-btn" onclick="loyaltyClear()"
                        style="background:#1f2937;border:none;border-radius:12px;color:#9ca3af;font-size:12px;font-weight:600;">CLR</button>
                <button type="button" class="keypad-btn" onclick="loyaltyKey('0')"
                        style="background:#1f2937;border:none;border-radius:12px;color:#fff;font-size:20px;font-weight:600;">0</button>
                <button type="button" class="keypad-btn" onclick="loyaltyBack()"
                        style="background:#1f2937;border:none;border-radius:12px;color:#9ca3af;font-size:20px;">⌫</button>
            </div>
        </div>

        {# ── Enrollment detail panel (shown for new customers) ─────────────── #}
        <div id="enroll-panel"
             style="display:none;flex:1;flex-direction:column;padding:4px 16px 0;gap:8px;overflow-y:auto;min-height:0;">

            <div style="background:#111827;border:1px solid #374151;border-radius:12px;padding:10px 14px;">
                <div style="color:#9ca3af;font-size:10px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">New Customer Details</div>

                {# First Name #}
                <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid #1f2937;">
                    <svg width="14" height="14" fill="none" stroke="#6b7280" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                    <input type="text" name="first_name" id="enroll-name"
                           placeholder="First name (required)"
                           autocomplete="off" autocorrect="off" autocapitalize="words"
                           style="flex:1;background:transparent;border:none;color:#fff;font-size:14px;outline:none;padding:2px 0;"
                           oninput="updateEnrollBtn()">
                </div>

                {# Gender #}
                <div style="padding:10px 0;border-bottom:1px solid #1f2937;">
                    <div style="color:#9ca3af;font-size:11px;margin-bottom:6px;">Gender <span style="color:#4b5563;">(required)</span></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                        <button type="button" id="gender-male" onclick="setGender('male')"
                                style="padding:10px;border:1px solid #374151;border-radius:10px;background:#1f2937;color:#9ca3af;font-size:14px;font-weight:600;cursor:pointer;">
                            Male
                        </button>
                        <button type="button" id="gender-female" onclick="setGender('female')"
                                style="padding:10px;border:1px solid #374151;border-radius:10px;background:#1f2937;color:#9ca3af;font-size:14px;font-weight:600;cursor:pointer;">
                            Female
                        </button>
                    </div>
                    <input type="hidden" name="gender" id="enroll-gender" value="">
                </div>

                {# Birthday (optional) #}
                <div style="padding:10px 0;">
                    <div style="color:#9ca3af;font-size:11px;margin-bottom:6px;">Birthday <span style="color:#4b5563;">(optional — no year)</span></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                        <select name="birth_month" id="enroll-month"
                                style="background:#1f2937;border:1px solid #374151;border-radius:10px;color:#d1d5db;font-size:14px;padding:10px;outline:none;">
                            <option value="">Month</option>
                            {% for m in [
                                [1,'January'],[2,'February'],[3,'March'],[4,'April'],
                                [5,'May'],[6,'June'],[7,'July'],[8,'August'],
                                [9,'September'],[10,'October'],[11,'November'],[12,'December']
                            ] %}
                            <option value="{{ m[0] }}">{{ m[1] }}</option>
                            {% endfor %}
                        </select>
                        <select name="birth_day" id="enroll-day"
                                style="background:#1f2937;border:1px solid #374151;border-radius:10px;color:#d1d5db;font-size:14px;padding:10px;outline:none;">
                            <option value="">Day</option>
                            {% for d in range(1, 31) %}
                            <option value="{{ d }}">{{ d }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

            </div>

        </div>

        {# ── Action buttons ───────────────────────────────────────────────── #}
        <div style="padding:6px 16px 14px;flex-shrink:0;display:flex;flex-direction:column;gap:6px;">
            <button type="submit" id="loyalty-award-btn"
                    style="width:100%;height:52px;background:#d97706;border:none;border-radius:13px;color:#fff;font-size:16px;font-weight:700;cursor:not-allowed;opacity:0.35;">
                Award {{ points_preview }} {{ program.points_symbol ?? program.points_name }}
            </button>
            <button type="submit" name="skip" value="1"
                    style="width:100%;padding:10px;background:transparent;border:none;color:#6b7280;font-size:13px;cursor:pointer;">
                Skip — no loyalty
            </button>
        </div>

        {% else %}

        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;text-align:center;padding:32px;">
            <div style="color:#6b7280;font-size:14px;">No loyalty program configured.</div>
        </div>
        <div style="padding:12px 16px 20px;flex-shrink:0;">
            <button type="submit" name="skip" value="1"
                    style="width:100%;height:54px;background:#059669;border:none;border-radius:14px;color:#fff;font-size:18px;font-weight:700;cursor:pointer;">
                Continue
            </button>
        </div>

        {% endif %}

    </form>

</div>

<script>
(function() {
    const display     = document.getElementById('loyalty-phone-display');
    const input       = document.getElementById('loyalty-phone-input');
    const awardBtn    = document.getElementById('loyalty-award-btn');
    const statusPill  = document.getElementById('enroll-status-pill');
    const keypadPanel = document.getElementById('keypad-panel');
    const enrollPanel = document.getElementById('enroll-panel');
    if (!display) return;

    const checkUrl    = '{{ path('terminal_checkout_loyalty_check', _p) }}';
    const pointsLabel = '{{ points_preview }} {{ (program.points_symbol ?? program.points_name)|e('js') }}';

    let raw = '{{ stk_phone ? stk_phone|replace({'254': '0'})|slice(0,10)|e('js') : '' }}';
    let isNewCustomer = false;
    let checkTimer = null;
    let selectedGender = '';

    function render() {
        const d = raw.padEnd(10, '_');
        display.textContent = d.slice(0,4)+' '+d.slice(4,7)+' '+d.slice(7,10);
        input.value = raw;
        if (raw.length < 10) {
            setStatus('—', null);
            showKeypad();
            disableBtn();
        }
    }

    function setStatus(text, type) {
        if (!statusPill) return;
        statusPill.textContent = text;
        if (type === 'enrolled') {
            statusPill.style.cssText = 'background:rgba(5,150,105,0.2);border:1px solid #059669;border-radius:20px;padding:3px 10px;font-size:11px;color:#34d399;white-space:nowrap;flex-shrink:0;';
        } else if (type === 'new') {
            statusPill.style.cssText = 'background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.5);border-radius:20px;padding:3px 10px;font-size:11px;color:#fde68a;white-space:nowrap;flex-shrink:0;';
        } else {
            statusPill.style.cssText = 'background:#1f2937;border:1px solid #374151;border-radius:20px;padding:3px 10px;font-size:11px;color:#9ca3af;white-space:nowrap;flex-shrink:0;';
        }
    }

    function showKeypad() {
        keypadPanel.style.display = 'flex';
        enrollPanel.style.display = 'none';
        isNewCustomer = false;
    }

    function showEnrollForm() {
        keypadPanel.style.display = 'none';
        enrollPanel.style.display = 'flex';
        isNewCustomer = true;
        setTimeout(() => document.getElementById('enroll-name')?.focus(), 50);
    }

    function disableBtn() {
        awardBtn.disabled = true;
        awardBtn.style.opacity = '0.35';
        awardBtn.style.cursor = 'not-allowed';
        awardBtn.textContent = 'Award ' + pointsLabel;
    }

    function enableBtn(label) {
        awardBtn.disabled = false;
        awardBtn.style.opacity = '1';
        awardBtn.style.cursor = 'pointer';
        awardBtn.textContent = label;
    }

    window.updateEnrollBtn = () => {
        const name   = (document.getElementById('enroll-name')?.value || '').trim();
        const gender = document.getElementById('enroll-gender')?.value || '';
        if (name && gender) {
            enableBtn('Enroll & Award ' + pointsLabel);
        } else {
            disableBtn();
            awardBtn.textContent = name ? 'Select gender to continue' : 'Enter first name to continue';
            awardBtn.style.opacity = '0.5';
        }
    };

    window.setGender = g => {
        selectedGender = g;
        document.getElementById('enroll-gender').value = g;
        ['male','female'].forEach(k => {
            const btn = document.getElementById('gender-' + k);
            if (!btn) return;
            if (k === g) {
                btn.style.background = g === 'male' ? 'rgba(37,99,235,0.3)' : 'rgba(236,72,153,0.3)';
                btn.style.borderColor = g === 'male' ? '#3b82f6' : '#ec4899';
                btn.style.color = '#fff';
            } else {
                btn.style.background = '#1f2937';
                btn.style.borderColor = '#374151';
                btn.style.color = '#9ca3af';
            }
        });
        updateEnrollBtn();
    };

    async function checkEnrollment() {
        if (raw.length !== 10) return;
        setStatus('Checking…', null);
        try {
            const data = await (await fetch(checkUrl + '?phone=' + encodeURIComponent(raw))).json();
            if (data.enrolled) {
                const bal = data.balance + ' ' + (data.points_symbol || 'pts');
                setStatus('Enrolled · ' + bal, 'enrolled');
                showKeypad();
                enableBtn('Award ' + pointsLabel);
            } else {
                setStatus('New customer', 'new');
                showEnrollForm();
                disableBtn();
                awardBtn.textContent = 'Enter details to enroll';
                awardBtn.style.opacity = '0.5';
            }
        } catch(e) {
            setStatus('Check failed', null);
            showKeypad();
        }
    }

    function scheduleCheck() {
        clearTimeout(checkTimer);
        if (raw.length === 10) checkTimer = setTimeout(checkEnrollment, 300);
    }

    window.loyaltyKey   = k  => { if (raw.length < 10) { raw += k; render(); scheduleCheck(); } };
    window.loyaltyBack  = () => {
        raw = raw.slice(0,-1);
        if (isNewCustomer) showKeypad();
        render();
    };
    window.loyaltyClear = () => { raw = ''; if (isNewCustomer) showKeypad(); render(); };

    render();
    if (raw.length === 10) checkEnrollment();
})();
</script>
{% endblock %}
