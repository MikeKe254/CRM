{% extends 'layouts/terminal_app.html.twig' %}
{% set _p = {subdomain: app.request.attributes.get('subdomain'), domain: app.request.attributes.get('domain'), branch: app.request.attributes.get('branch')} %}

{% set points_awarded  = draft.get('points_awarded', 0) %}
{% set loyalty_phone   = draft.get('loyalty_phone', '') %}
{% set loyalty_balance = draft.get('loyalty_balance') %}
{% set loyalty_tier    = draft.get('loyalty_tier', '') %}
{% set loyalty_name    = draft.get('loyalty_name', program ? program.points_name : 'points') %}
{% set amount          = draft.get('amount', 0) %}
{% set method_key      = draft.get('payment_method_key', '') %}

{% block title %}Checkout — Complete{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;height:100%;">

    {# ── Success content ─────────────────────────────────────────────────── #}
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 28px;text-align:center;gap:24px;">

        {# Animated check circle #}
        <div style="position:relative;" class="slide-up">
            <div style="width:96px;height:96px;background:#059669;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <svg width="48" height="48" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                </svg>
            </div>
            <div class="pulse-ring"
                 style="position:absolute;inset:0;border-radius:50%;border:3px solid rgba(16,185,129,0.3);"></div>
        </div>

        <div class="slide-up" style="animation-delay:.08s;">
            <div style="color:#fff;font-size:30px;font-weight:800;">Payment Complete</div>
            <div style="color:#34d399;font-size:22px;font-weight:700;margin-top:4px;font-variant-numeric:tabular-nums;">
                KES {{ amount|number_format(0, '.', ',') }}
            </div>
            <div style="color:#6b7280;font-size:14px;margin-top:4px;">
                via
                {% if method_key == 'mpesa' %}M-Pesa
                {% elseif method_key == 'cash' %}Cash
                {% elseif method_key == 'bank' %}Bank Transfer
                {% else %}{{ method_key|replace({'_': ' '})|title }}{% endif %}
            </div>
        </div>

        {# Loyalty awarded #}
        {% if points_awarded > 0 %}
        <div class="slide-up"
             style="animation-delay:.16s;width:100%;background:linear-gradient(135deg,rgba(161,98,7,0.3),rgba(120,53,15,0.2));border:1px solid rgba(161,98,7,0.4);border-radius:20px;padding:16px 20px;">
            <div style="display:flex;align-items:center;gap:12px;">
                <div style="width:44px;height:44px;background:rgba(234,179,8,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="24" height="24" fill="#eab308" viewBox="0 0 24 24">
                        <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                    </svg>
                </div>
                <div style="flex:1;text-align:left;">
                    <div style="color:#fde68a;font-size:13px;">Points Awarded</div>
                    <div style="color:#fff;font-size:22px;font-weight:800;">
                        +{{ points_awarded }} <span style="color:#eab308;font-size:15px;font-weight:600;">{{ loyalty_name }}</span>
                    </div>
                    {% if loyalty_balance is not null %}
                    <div style="color:#9ca3af;font-size:12px;margin-top:2px;">
                        Balance: {{ loyalty_balance }} {{ loyalty_name }}{% if loyalty_tier %} · {{ loyalty_tier }}{% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
            {% if loyalty_phone %}
            <div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(161,98,7,0.3);color:#6b7280;font-size:12px;">
                {{ loyalty_phone }}
            </div>
            {% endif %}
        </div>
        {% endif %}

    </div>

    {# ── Bottom actions ──────────────────────────────────────────────────── #}
    <div style="padding:0 20px 32px;flex-shrink:0;display:flex;flex-direction:column;gap:10px;" class="slide-up" style="animation-delay:.24s;">
        <div style="text-align:center;color:#4b5563;font-size:13px;margin-bottom:4px;">
            New checkout in <span id="countdown">5</span>s
        </div>
        <a href="{{ path('terminal_checkout_start', _p) }}" class="action-btn"
           style="display:flex;align-items:center;justify-content:center;height:56px;background:#059669;border-radius:14px;color:#fff;font-size:18px;font-weight:700;text-decoration:none;">
            New Checkout
        </a>
        <a href="{{ path('terminal_dashboard', _p) }}" class="action-btn"
           style="display:flex;align-items:center;justify-content:center;padding:14px;color:#6b7280;font-size:14px;text-decoration:none;">
            Back to Dashboard
        </a>
    </div>

</div>

<script>
(function() {
    let n = 5;
    const el  = document.getElementById('countdown');
    const url = '{{ path('terminal_checkout_start', _p) }}';
    const t   = setInterval(() => {
        n--;
        if (el) el.textContent = n;
        if (n <= 0) {
            clearInterval(t);
            if (window.Turbo) window.Turbo.visit(url);
            else location.href = url;
        }
    }, 1000);
    document.addEventListener('pointerdown', () => clearInterval(t), { once: true });
})();
</script>
{% endblock %}
