{% extends 'layouts/terminal_app.html.twig' %}
{% set _p = {subdomain: app.request.attributes.get('subdomain'), domain: app.request.attributes.get('domain'), branch: app.request.attributes.get('branch')} %}

{% block title %}Terminal{% endblock %}

{% block body %}

{% include 'terminal/lock_screen.html.twig' with {
    is_locked:   is_locked,
    unlock_url:  path('terminal_session_unlock', _p),
    login_url:   path('terminal_login_page', _p),
} %}

<div id="patronr-dashboard"
     style="display:{{ is_locked ? 'none' : 'flex' }};flex-direction:column;height:100%;overflow:hidden;">

    {# ── Top bar ─────────────────────────────────────────────────────────── #}
    {# Uses flex-wrap so that when the screen is too narrow the buttons spill #}
    {# onto their own second row below — clock always stays in the first row. #}
    <div style="display:flex;flex-wrap:wrap;align-items:center;padding:14px 20px 0;border-bottom:1px solid #1f2937;flex-shrink:0;gap:8px;">

        {# Branch / user — grows to fill space, never wraps itself #}
        <div style="flex:1 1 140px;min-width:0;padding-bottom:14px;">
            <div style="color:#fff;font-weight:700;font-size:16px;line-height:1.2;">
                {{ app.request.attributes.get('branch')|replace({'-': ' '})|title }}
            </div>
            <div style="color:#6b7280;font-size:11px;margin-top:1px;">
                POS Terminal{% if user_name is defined and user_name %} &nbsp;·&nbsp; <span style="color:#9ca3af;">{{ user_name }}</span>{% endif %}
            </div>
        </div>

        {# Buttons — flex-shrink:0 keeps them together; when they can't fit   #}
        {# alongside the branch name they wrap as a group onto the next row.  #}
        {% if (quick_stk_enabled is defined and quick_stk_enabled) or (mpesa_feed_enabled is defined and mpesa_feed_enabled) %}
        <div style="display:flex;gap:8px;flex:0 0 auto;padding-bottom:14px;order:3;width:100%;border-top:1px solid #1f2937;padding-top:10px;"
             id="tb-btn-row">
            {% if quick_stk_enabled is defined and quick_stk_enabled %}
            <a href="{{ path('terminal_quick_stk', _p) }}" class="action-btn"
               style="flex:1;height:38px;background:#052e16;border:1px solid rgba(16,185,129,0.35);border-radius:12px;display:flex;align-items:center;justify-content:center;gap:7px;text-decoration:none;">
                <svg width="15" height="15" fill="none" stroke="#34d399" stroke-width="2.2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                </svg>
                <span style="color:#34d399;font-size:12px;font-weight:600;white-space:nowrap;">Quick STK</span>
            </a>
            {% endif %}
            {% if mpesa_feed_enabled is defined and mpesa_feed_enabled %}
            <a href="{{ path('terminal_mpesa_feed', _p) }}" class="action-btn"
               style="flex:1;height:38px;background:#052e16;border:1px solid rgba(16,185,129,0.35);border-radius:12px;display:flex;align-items:center;justify-content:center;gap:7px;text-decoration:none;">
                <svg width="15" height="15" fill="none" stroke="#34d399" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 15.75h3"/>
                </svg>
                <span style="color:#34d399;font-size:12px;font-weight:600;white-space:nowrap;">M-Pesa Feed</span>
            </a>
            {% endif %}
        </div>
        {% endif %}

        {# Clock — always stays right in the first row #}
        <div id="terminal-clock"
             style="flex:0 0 auto;color:#fff;font-family:ui-monospace,monospace;font-size:20px;font-variant-numeric:tabular-nums;font-weight:600;padding-bottom:14px;margin-left:auto;order:2;"></div>
    </div>

    {# ── Action cards — flex:1 each so they fill available space ─────────── #}
    <div style="flex:1;display:flex;flex-direction:column;gap:10px;padding:14px 16px;min-height:0;overflow:hidden;">

        <a href="{{ path('terminal_checkout_start', _p) }}" class="action-btn"
           style="flex:1;display:flex;align-items:center;gap:16px;background:#059669;border-radius:18px;padding:0 20px;text-decoration:none;box-shadow:0 6px 24px rgba(5,150,105,0.25);min-height:0;">
            <div style="width:44px;height:44px;background:rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
                </svg>
            </div>
            <div style="flex:1;">
                <div style="color:#fff;font-size:18px;font-weight:700;">Checkout</div>
                <div style="color:rgba(255,255,255,0.65);font-size:12px;margin-top:1px;">Start a new sale</div>
            </div>
            <svg width="20" height="20" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
        </a>

        <a href="{{ path('terminal_transactions', _p) }}" class="action-btn"
           style="flex:1;display:flex;align-items:center;gap:16px;background:#111827;border:1px solid #1f2937;border-radius:18px;padding:0 20px;text-decoration:none;min-height:0;">
            <div style="width:44px;height:44px;background:#1f2937;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="24" height="24" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/>
                </svg>
            </div>
            <div style="flex:1;">
                <div style="color:#fff;font-size:18px;font-weight:700;">Transactions</div>
                <div style="color:#6b7280;font-size:12px;margin-top:1px;">View recent sales</div>
            </div>
            <svg width="20" height="20" fill="none" stroke="#4b5563" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
        </a>

        {% if loyalty_enabled %}
        <a href="{{ path('terminal_loyalty_enroll', _p) }}" class="action-btn"
           style="flex:1;display:flex;align-items:center;gap:16px;background:#111827;border:1px solid #1f2937;border-radius:18px;padding:0 20px;text-decoration:none;min-height:0;">
            <div style="width:44px;height:44px;background:#1f2937;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="24" height="24" fill="#eab308" viewBox="0 0 24 24">
                    <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
            </div>
            <div style="flex:1;">
                <div style="color:#fff;font-size:18px;font-weight:700;">Loyalty</div>
                <div style="color:#6b7280;font-size:12px;margin-top:1px;">Enroll a customer</div>
            </div>
            <svg width="20" height="20" fill="none" stroke="#4b5563" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
        </a>

        <a href="{{ path('terminal_loyalty_check', _p) }}" class="action-btn"
           style="flex:1;display:flex;align-items:center;gap:16px;background:#111827;border:1px solid #1f2937;border-radius:18px;padding:0 20px;text-decoration:none;min-height:0;">
            <div style="width:44px;height:44px;background:#1f2937;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" fill="none" stroke="#eab308" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z"/>
                </svg>
            </div>
            <div style="flex:1;">
                <div style="color:#fff;font-size:18px;font-weight:700;">Points Checker</div>
                <div style="color:#6b7280;font-size:12px;margin-top:1px;">Look up a customer's balance</div>
            </div>
            <svg width="20" height="20" fill="none" stroke="#4b5563" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
        </a>
        {% endif %}

    </div>

    {# ── Lock button ─────────────────────────────────────────────────────── #}
<style>
@media (max-width: 480px) {
    .tb-btn-label { display: none !important; }
    .tb-btn       { padding: 0 !important; width: 40px !important; }
}
</style>
    <div style="padding:0 16px 24px;flex-shrink:0;">
        <button id="patronr-lock-btn" class="action-btn"
                style="width:100%;height:48px;background:#111827;border:1px solid #1f2937;border-radius:14px;color:#9ca3af;font-size:14px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:8px;cursor:pointer;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
            </svg>
            Lock Terminal
        </button>
    </div>

</div>

<script>
// Reset lock state before Turbo caches this page.
document.addEventListener('turbo:before-cache', function() {
    const lock = document.getElementById('patronr-lock');
    const dash = document.getElementById('patronr-dashboard');
    if (lock) lock.style.display = 'none';
    if (dash) dash.style.display = 'flex';
});

// Live clock
(function() {
    const el = document.getElementById('terminal-clock');
    function tick() {
        el.textContent = new Date().toLocaleTimeString('en-KE', {hour:'2-digit', minute:'2-digit'});
    }
    tick(); setInterval(tick, 10000);
})();

// Lock button
document.getElementById('patronr-lock-btn')?.addEventListener('click', async () => {
    try {
        await fetch('{{ path('terminal_session_lock', _p) }}', { method: 'POST' });
    } catch(e) {}
    document.getElementById('patronr-dashboard').style.display = 'none';
    document.getElementById('patronr-lock').style.display     = 'flex';
});
</script>
{% endblock %}
