{% extends 'layouts/terminal_app.html.twig' %}
{% set _p = {subdomain: app.request.attributes.get('subdomain'), domain: app.request.attributes.get('domain'), branch: app.request.attributes.get('branch')} %}

{% block title %}Loyalty — Enroll{% endblock %}

{% block body %}
<div style="display:flex;flex-direction:column;height:100%;">

    <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid #1f2937;flex-shrink:0;">
        <a href="{{ path('terminal_dashboard', _p) }}" class="action-btn"
           style="width:40px;height:40px;background:#1f2937;border-radius:12px;display:flex;align-items:center;justify-content:center;text-decoration:none;flex-shrink:0;">
            <svg width="20" height="20" fill="none" stroke="#9ca3af" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/>
            </svg>
        </a>
        <div style="flex:1;">
            <div style="color:#fff;font-weight:700;font-size:15px;">Enroll Customer</div>
            <div style="color:#6b7280;font-size:12px;">{% if program %}{{ program.program_name }}{% else %}Loyalty Program{% endif %}</div>
        </div>
        <div style="width:40px;height:40px;background:rgba(234,179,8,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;">
            <svg width="20" height="20" fill="#eab308" viewBox="0 0 24 24">
                <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
            </svg>
        </div>
    </div>

    {% if not program %}

    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;gap:12px;text-align:center;color:#6b7280;">
        <svg width="48" height="48" fill="none" stroke="#374151" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
        </svg>
        <div style="font-size:14px;">No loyalty program configured for this company.</div>
    </div>

    {% elseif enrolled %}

    {# ── Already enrolled / just enrolled ─────────────────────────────────── #}
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px;gap:20px;text-align:center;" class="fade-in">
        <div style="width:80px;height:80px;background:rgba(234,179,8,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;">
            <svg width="40" height="40" fill="#eab308" viewBox="0 0 24 24">
                <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
            </svg>
        </div>
        <div>
            <div style="color:#fff;font-size:26px;font-weight:800;">{{ just_enrolled ? 'Welcome!' : 'Already Enrolled' }}</div>
            {% if enrolled.first_name %}
            <div style="color:#d1d5db;font-size:16px;font-weight:600;margin-top:2px;">{{ enrolled.first_name }}</div>
            {% endif %}
            <div style="color:#9ca3af;font-size:14px;margin-top:2px;">{{ enrolled.msisdn }}</div>
        </div>
        <div style="width:100%;background:#111827;border:1px solid #1f2937;border-radius:18px;padding:16px 20px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <span style="color:#9ca3af;font-size:13px;">{{ program.points_name }} Balance</span>
                <span style="color:#fff;font-size:15px;font-weight:700;">
                    {{ account.pointsBalance ?? 0 }} {{ program.points_symbol ?? program.points_name }}
                </span>
            </div>
            {% if account and account.tierName %}
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="color:#9ca3af;font-size:13px;">Tier</span>
                <span style="font-size:14px;font-weight:600;color:{{ account.tierColor ?? '#fff' }};">{{ account.tierName }}</span>
            </div>
            {% endif %}
            {% if program.enroll_bonus_points and just_enrolled %}
            <div style="margin-top:10px;padding-top:10px;border-top:1px solid #1f2937;color:#eab308;font-size:13px;text-align:center;">
                +{{ program.enroll_bonus_points }} welcome bonus awarded!
            </div>
            {% endif %}
        </div>
    </div>

    <div style="padding:12px 20px 28px;flex-shrink:0;">
        <a href="{{ path('terminal_dashboard', _p) }}" class="action-btn"
           style="display:flex;align-items:center;justify-content:center;height:56px;background:#059669;border-radius:14px;color:#fff;font-size:18px;font-weight:700;text-decoration:none;">
            Done
        </a>
    </div>

    {% else %}

    {# ── Enrollment form ──────────────────────────────────────────────────── #}
    <form method="post" action="{{ path('terminal_loyalty_enroll', _p) }}"
          style="display:flex;flex-direction:column;flex:1;overflow:hidden;min-height:0;padding:0 16px;">

        {# Program banner #}
        <div style="flex-shrink:0;padding:8px 0 6px;">
            <div style="background:rgba(161,98,7,0.15);border:1px solid rgba(161,98,7,0.3);border-radius:12px;padding:8px 14px;text-align:center;">
                <div style="color:#fde68a;font-size:13px;font-weight:600;">{{ program.program_name }}</div>
                <div style="color:#9ca3af;font-size:11px;margin-top:1px;">
                    Earn {{ program.points_per_unit }} {{ program.points_name }} per KES {{ program.unit_amount|number_format(0) }}
                    {% if program.enroll_bonus_points %} · +{{ program.enroll_bonus_points }} welcome bonus{% endif %}
                </div>
            </div>
        </div>

        {# Phone display #}
        <div style="flex-shrink:0;margin-bottom:6px;">
            <div style="color:#9ca3af;font-size:10px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;">Customer Phone</div>
            <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:8px;text-align:center;">
                <div id="enroll-phone-display"
                     style="color:#fff;font-size:24px;font-family:ui-monospace,monospace;letter-spacing:.12em;font-weight:600;">
                    0___ ___ ___
                </div>
                <div id="phone-status-banner" style="font-size:11px;min-height:14px;margin-top:2px;color:#4b5563;"></div>
                <input type="tel" name="phone" id="enroll-phone-input" readonly value=""
                       style="position:absolute;opacity:0;pointer-events:none;">
            </div>
        </div>

        {# Customer details #}
        <div style="flex-shrink:0;margin-bottom:6px;">
            <div style="background:#111827;border:1px solid #1f2937;border-radius:12px;padding:8px 12px;">
                {# First Name #}
                <div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid #1f2937;">
                    <svg width="13" height="13" fill="none" stroke="#6b7280" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                    <input type="text" name="first_name" id="enroll-name"
                           placeholder="First name (required)"
                           autocomplete="off" autocorrect="off" autocapitalize="words"
                           style="flex:1;background:transparent;border:none;color:#fff;font-size:14px;outline:none;padding:2px 0;"
                           oninput="updateEnrollBtn()">
                </div>
                {# Gender #}
                <div style="padding:6px 0;border-bottom:1px solid #1f2937;">
                    <div style="color:#9ca3af;font-size:10px;margin-bottom:5px;">Gender <span style="color:#4b5563;">(required)</span></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
                        <button type="button" id="gender-male" onclick="setGender('male')"
                                style="padding:7px;border:1px solid #374151;border-radius:9px;background:#1f2937;color:#9ca3af;font-size:13px;font-weight:600;cursor:pointer;">
                            Male
                        </button>
                        <button type="button" id="gender-female" onclick="setGender('female')"
                                style="padding:7px;border:1px solid #374151;border-radius:9px;background:#1f2937;color:#9ca3af;font-size:13px;font-weight:600;cursor:pointer;">
                            Female
                        </button>
                    </div>
                    <input type="hidden" name="gender" id="enroll-gender" value="">
                </div>
                {# Birthday #}
                <div style="padding:6px 0 2px;">
                    <div style="color:#9ca3af;font-size:10px;margin-bottom:5px;">Birthday <span style="color:#4b5563;">(optional)</span></div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
                        <select name="birth_month"
                                style="background:#1f2937;border:1px solid #374151;border-radius:9px;color:#d1d5db;font-size:13px;padding:7px;outline:none;">
                            <option value="">Month</option>
                            {% for m in [
                                [1,'January'],[2,'February'],[3,'March'],[4,'April'],
                                [5,'May'],[6,'June'],[7,'July'],[8,'August'],
                                [9,'September'],[10,'October'],[11,'November'],[12,'December']
                            ] %}
                            <option value="{{ m[0] }}">{{ m[1] }}</option>
                            {% endfor %}
                        </select>
                        <select name="birth_day"
                                style="background:#1f2937;border:1px solid #374151;border-radius:9px;color:#d1d5db;font-size:13px;padding:7px;outline:none;">
                            <option value="">Day</option>
                            {% for d in range(1, 31) %}
                            <option value="{{ d }}">{{ d }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>
        </div>

        {# Keypad — takes remaining space #}
        <div style="flex:1;min-height:0;display:flex;flex-direction:column;">
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:4px;flex:1;min-height:0;overflow:hidden;">
                {% for n in [1,2,3,4,5,6,7,8,9] %}
                <button type="button" class="keypad-btn" onclick="enrollKey('{{ n }}')"
                        style="background:#1f2937;border:none;border-radius:10px;color:#fff;font-size:19px;font-weight:600;min-height:0;">{{ n }}</button>
                {% endfor %}
                <button type="button" class="keypad-btn" onclick="enrollClear()"
                        style="background:#1f2937;border:none;border-radius:10px;color:#9ca3af;font-size:11px;font-weight:600;min-height:0;">CLR</button>
                <button type="button" class="keypad-btn" onclick="enrollKey('0')"
                        style="background:#1f2937;border:none;border-radius:10px;color:#fff;font-size:19px;font-weight:600;min-height:0;">0</button>
                <button type="button" class="keypad-btn" onclick="enrollBack()"
                        style="background:#1f2937;border:none;border-radius:10px;color:#9ca3af;font-size:18px;min-height:0;">⌫</button>
            </div>
        </div>

        {# Submit — pinned footer #}
        <div style="flex-shrink:0;padding:6px 0 18px;">
            <button type="submit" id="enroll-btn"
                    style="width:100%;height:50px;background:#d97706;border:none;border-radius:13px;color:#fff;font-size:16px;font-weight:700;cursor:not-allowed;opacity:.35;">
                Enroll Customer
            </button>
        </div>

    </form>

    <script>
    (function() {
        const checkPhoneUrl = '{{ path('terminal_loyalty_check_phone', _p) }}';
        const display = document.getElementById('enroll-phone-display');
        const input   = document.getElementById('enroll-phone-input');
        const btn     = document.getElementById('enroll-btn');
        const banner  = document.getElementById('phone-status-banner');
        let raw = '';
        let alreadyEnrolled = false;
        let checkTimer = null;

        function showBanner(msg, type) {
            const colors = { error: '#f87171', success: '#34d399', info: '#6b7280' };
            banner.style.color = colors[type] || '#6b7280';
            banner.textContent = msg;
        }

        function hideBanner() {
            banner.textContent = '';
            banner.style.color = '#4b5563';
        }

        async function checkPhone() {
            if (raw.length !== 10) {
                alreadyEnrolled = false;
                hideBanner();
                updateEnrollBtn();
                return;
            }
            showBanner('Checking\u2026', 'info');
            try {
                const res  = await fetch(checkPhoneUrl + '?phone=' + encodeURIComponent(raw));
                const data = await res.json();
                if (data.enrolled) {
                    alreadyEnrolled = true;
                    const name = data.first_name ? ` · ${data.first_name}` : '';
                    showBanner(
                        `Already enrolled${name} — ${data.points_balance.toLocaleString()} ${data.points_symbol}`,
                        'error'
                    );
                } else {
                    alreadyEnrolled = false;
                    showBanner('Not yet enrolled — ready to register', 'success');
                }
            } catch(e) {
                alreadyEnrolled = false;
                hideBanner();
            }
            updateEnrollBtn();
        }

        function render() {
            const d = raw.padEnd(10, '_');
            display.textContent = d.slice(0,4)+' '+d.slice(4,7)+' '+d.slice(7,10);
            input.value = raw;
            if (raw.length === 10) {
                clearTimeout(checkTimer);
                checkTimer = setTimeout(checkPhone, 300);
            } else {
                alreadyEnrolled = false;
                hideBanner();
            }
            updateEnrollBtn();
        }

        window.updateEnrollBtn = () => {
            const phone  = raw.length === 10;
            const name   = (document.getElementById('enroll-name')?.value || '').trim();
            const gender = document.getElementById('enroll-gender')?.value || '';
            const ok     = phone && name !== '' && gender !== '' && !alreadyEnrolled;
            btn.disabled = !ok;
            btn.style.opacity = ok ? '1' : '0.35';
            btn.style.cursor  = ok ? 'pointer' : 'not-allowed';
        };

        window.setGender = g => {
            document.getElementById('enroll-gender').value = g;
            ['male','female'].forEach(k => {
                const b = document.getElementById('gender-' + k);
                if (!b) return;
                if (k === g) {
                    b.style.background  = g === 'male' ? 'rgba(37,99,235,0.3)' : 'rgba(236,72,153,0.3)';
                    b.style.borderColor = g === 'male' ? '#3b82f6' : '#ec4899';
                    b.style.color = '#fff';
                } else {
                    b.style.background = '#1f2937'; b.style.borderColor = '#374151'; b.style.color = '#9ca3af';
                }
            });
            updateEnrollBtn();
        };

        window.enrollKey   = k => { if (raw.length < 10) { raw += k; render(); } };
        window.enrollBack  = () => { raw = raw.slice(0,-1); render(); };
        window.enrollClear = () => { raw = ''; render(); };

        render();
    })();
    </script>

    {% endif %}

</div>
{% endblock %}
