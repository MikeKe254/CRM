{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% block admin_title %}Roles{% endblock %}
{% block admin_subtitle %}Manage roles and their permission sets{% endblock %}

{% block admin_actions %}
{% if can.create %}
<button onclick="openCreateRole()"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Role
</button>
{% endif %}
{% endblock %}

{% block admin_content %}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="role-search" type="text" placeholder="Search roles…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
        <span class="ml-auto text-xs text-gray-400">{{ roles|length }} role{{ roles|length != 1 ? 's' : '' }}</span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full" id="roles-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Role</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Description</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Permissions</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Type</th>
                    <th class="px-4 py-3 w-48"></th>
                </tr>
            </thead>
            <tbody>
            {% for role in roles %}
            <tr id="role-row-{{ role.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0">
                            <svg width="14" height="14" fill="none" stroke="#4f46e5" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <a href="{{ path('admin_roles_show', {subdomain: tenant_subdomain, domain: tenant_domain, id: role.id}) }}"
                           class="text-sm font-medium text-gray-900 hover:text-indigo-600 transition-colors">
                            {{ role.name }}
                        </a>
                    </div>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">{{ role.description ?? '—' }}</td>
                <td class="px-4 py-3">
                    <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded font-semibold">
                        {{ role.permission_count }} permission{{ role.permission_count != 1 ? 's' : '' }}
                    </span>
                </td>
                <td class="px-4 py-3">
                    {% if role.is_system_role %}
                        <span class="text-xs bg-purple-50 text-purple-700 px-2 py-0.5 rounded font-semibold">System</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded font-semibold">Custom</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3">
                    <div class="flex items-center gap-1">
                        <a href="{{ path('admin_roles_show', {subdomain: tenant_subdomain, domain: tenant_domain, id: role.id}) }}"
                           class="text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 px-2.5 py-1 rounded transition-colors">
                            Permissions
                        </a>
                        {% if can.edit and not role.is_system_role %}
                        <button onclick="openEditRole({{ role|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        {% endif %}
                        {% if can.delete and not role.is_system_role %}
                        <button onclick="deleteRole({{ role.id }}, '{{ role.name|e('js') }}')"
                                class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">No roles found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block admin_scripts %}
<script>
liveFilter('role-search', 'roles-table');

function roleFormHtml(r = {}) {
    return `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Role Name *</label>
            <input id="f-name" type="text" value="${r.name??''}" placeholder="e.g. Manager"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <input id="f-desc" type="text" value="${r.description??''}" placeholder="What does this role do?"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
        </div>
    `;
}

function drawerFooter(onSave) {
    return `
        <button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        <button data-primary onclick="${onSave}" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save</button>
    `;
}

function openCreateRole() { openDrawer('Add Role', roleFormHtml(), drawerFooter('submitCreateRole()')); }
function openEditRole(r)   { openDrawer('Edit Role', roleFormHtml(r), drawerFooter(`submitEditRole(${r.id})`)); }

function submitCreateRole() {
    adminFetch('{{ path('admin_roles_create', {subdomain: tenant_subdomain, domain: tenant_domain}) }}', {
        name:        document.getElementById('f-name').value,
        description: document.getElementById('f-desc').value,
    }, () => turboReload());
}

function submitEditRole(id) {
    // 2026-03-19: Use the real Symfony route path. The role update endpoint is
    // "/update", not "/edit", and generated URLs keep the tenant host/domain correct.
    adminFetch(`{{ path('admin_roles_update', {subdomain: tenant_subdomain, domain: tenant_domain, id: '__ROLE_ID__'}) }}`.replace('__ROLE_ID__', id), {
        name:        document.getElementById('f-name').value,
        description: document.getElementById('f-desc').value,
    }, () => turboReload());
}

function deleteRole(id, name) {
    // 2026-03-19: Generate the delete URL from Symfony so role actions stay valid
    // across dynamic tenant domains and route naming changes.
    adminDelete(
        `{{ path('admin_roles_delete', {subdomain: tenant_subdomain, domain: tenant_domain, id: '__ROLE_ID__'}) }}`.replace('__ROLE_ID__', id),
        `Delete role "${name}"? All users with this role will lose it.`,
        () => document.getElementById(`role-row-${id}`)?.remove()
    );
}
</script>
{% endblock %}
