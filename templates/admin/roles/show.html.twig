{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}

{% block admin_title %}{{ role.name }}{% endblock %}
{% block admin_subtitle %}Manage permissions and constraints for this role{% endblock %}

{% block admin_actions %}
    <a href="{{ path('admin_roles', {subdomain: tenant_subdomain, domain: tenant_domain}) }}"
       class="inline-flex items-center gap-1.5 h-9 px-4 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Roles
    </a>
{% endblock %}

{% block admin_content %}

{# ── ERROR MODAL ── #}
<div id="error-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeErrorModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
        <div class="h-1 bg-gradient-to-r from-red-400 via-rose-500 to-red-500"></div>
        <div class="p-6">
            <div class="flex items-start gap-4 mb-5">
                <div class="w-10 h-10 rounded-xl bg-red-50 border border-red-100 flex items-center justify-center flex-shrink-0 text-red-500">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                </div>
                <div class="pt-0.5 flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-900 mb-1">Action Failed</p>
                    <p id="error-modal-message" class="text-sm text-gray-500 leading-relaxed"></p>
                </div>
            </div>
            <div class="flex justify-end">
                <button onclick="closeErrorModal()"
                        class="h-9 px-5 bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg transition-colors">
                    Got it
                </button>
            </div>
        </div>
    </div>
</div>

{# ── ROLE SUMMARY ── #}
<div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center flex-shrink-0">
        <svg width="18" height="18" fill="none" stroke="#4f46e5" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
    </div>
    <div>
        <div class="text-base font-semibold text-gray-900">{{ role.name }}</div>
        <div class="text-xs text-gray-400">
            <span id="assigned-count">{{ assignedIds|length }}</span> permission{{ assignedIds|length != 1 ? 's' : '' }} assigned
            · {% if role.is_system_role %}
                <span class="text-purple-600 font-medium">System role</span>
            {% else %}
                <span class="text-gray-400">Custom role</span>
            {% endif %}
        </div>
    </div>
</div>

{# ── SEARCH ── #}
<div class="flex items-center gap-3 mb-4">
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="13" height="13"
             fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input id="perm-search" type="text" placeholder="Search permissions…"
               class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
    </div>
    <span class="text-xs text-gray-400 ml-auto">
        <span id="assigned-count-label">{{ assignedIds|length }}</span> of {{ all|reduce((carry, perms) => carry + perms|length, 0) }} assigned
    </span>
</div>

{# ── PERMISSION SECTIONS ── #}
{#
    Data available:
    - all:               { category: [permission, …] }   — all permissions, grouped
    - assignedIds:       [permId, …]
    - rolePermissionMap: { permId: rolePermissionId }
    - constraintData:    { permId: [constraint_row, …] }
    - can.assign:        bool
#}

<div id="perm-sections" class="space-y-3">
{% for category, perms in all %}
<div class="perm-section bg-white rounded-xl border border-gray-200 overflow-hidden" data-category="{{ category }}">

    {# Category header #}
    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100 bg-gray-50/60">
        <span class="text-xs font-semibold text-gray-600 uppercase tracking-wide">{{ category }}</span>
        <span class="text-xs text-gray-400">{{ perms|length }}</span>
    </div>

    {# Permission rows #}
    <div class="divide-y divide-gray-50">
    {% for p in perms %}
    {% set isAssigned = p.id in assignedIds %}
    {% set permConstraints = constraintData[p.id] ?? [] %}
    {% set rpId = rolePermissionMap[p.id] ?? 0 %}

    <div class="perm-row" id="perm-row-{{ p.id }}">

        {# Main row: name + description + toggle #}
        <div class="flex items-center justify-between px-5 py-3.5 hover:bg-gray-50/50 transition-colors">
            <div class="flex-1 min-w-0 pr-4">
                <div class="text-sm font-medium text-gray-900">{{ p.name }}</div>
                {% if p.description %}
                    <div class="text-xs text-gray-400 mt-0.5">{{ p.description }}</div>
                {% endif %}
            </div>

            {% if can.assign %}
            <label class="toggle-switch flex-shrink-0 cursor-pointer">
                <input type="checkbox"
                       id="toggle-{{ p.id }}"
                       data-perm-id="{{ p.id }}"
                       {{ isAssigned ? 'checked' : '' }}
                       onchange="togglePermission({{ role.id }}, {{ p.id }}, '{{ p.name|e('js') }}', this)">
                <span class="toggle-slider"></span>
            </label>
            {% else %}
                {% if isAssigned %}
                    <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded font-semibold">Assigned</span>
                {% endif %}
            {% endif %}
        </div>

        {# Constraints panel — only shown when permission has constraints defined #}
        {% if permConstraints|length > 0 %}
        <div class="constraints-panel px-5 pb-4 border-t border-gray-50"
             id="constraints-{{ p.id }}"
             style="{{ isAssigned ? '' : 'display:none' }}">

            <div class="mt-3 space-y-3">
            {% for c in permConstraints %}
            <div class="flex items-start gap-4" id="constraint-row-{{ c.constraint_id }}-{{ p.id }}">

                {# Constraint label #}
                <div class="flex-1 min-w-0">
                    <div class="text-xs font-medium text-gray-700">
                        {{ c.constraint_name }}
                        {% if c.is_required %}
                            <span class="ml-1 text-red-400">*</span>
                        {% endif %}
                    </div>
                    {% if c.constraint_description %}
                        <div class="text-xs text-gray-400 mt-0.5">{{ c.constraint_description }}</div>
                    {% endif %}
                </div>

                {# Constraint value input — type-aware #}
                <div class="flex items-center gap-2 flex-shrink-0">
                    {% if can.assign %}

                        {% if c.constraint_type == 'boolean' %}
                        <label class="toggle-switch cursor-pointer"
                               title="{{ c.constraint_value ? 'Enabled' : 'Disabled' }}">
                            <input type="checkbox"
                                   id="cv-{{ c.constraint_id }}-{{ p.id }}"
                                   {{ c.constraint_value == '1' ? 'checked' : '' }}
                                   onchange="saveConstraint({{ rpId }}, {{ c.constraint_id }}, this.checked ? '1' : '0', this)">
                            <span class="toggle-slider toggle-slider--sm"></span>
                        </label>
                        <span class="text-xs text-gray-400 w-12" id="cv-label-{{ c.constraint_id }}-{{ p.id }}">
                            {{ c.constraint_value == '1' ? 'Enabled' : 'Disabled' }}
                        </span>

                        {% elseif c.constraint_type == 'list' %}
                        {% if c.constraint_key == 'allowed_shortcodes' %}
                            {# Multi-checkbox from the company's live MPesa configs #}
                            {% set selectedCodes = c.constraint_value ? c.constraint_value|split(',') : [] %}
                            {% set selectedCodes = selectedCodes|map(v => v|trim) %}
                            <div class="flex flex-col gap-1.5" id="cv-{{ c.constraint_id }}-{{ p.id }}-wrap">
                                {% if mpesaShortcodes|length == 0 %}
                                    <span class="text-xs text-gray-400 italic">No MPesa configs found for this company.</span>
                                {% else %}
                                    {% for sc in mpesaShortcodes %}
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox"
                                               class="shortcode-cb-{{ c.constraint_id }}-{{ p.id }} rounded border-gray-300 text-indigo-600 focus:ring-indigo-300"
                                               value="{{ sc.shortcode }}"
                                               {{ sc.shortcode in selectedCodes ? 'checked' : '' }}
                                               onchange="saveShortcodes({{ rpId }}, {{ c.constraint_id }}, {{ p.id }}, this)">
                                        <span class="text-sm text-gray-800">{{ sc.account_name }}</span>
                                        <span class="text-xs text-gray-400 font-mono">{{ sc.shortcode }}</span>
                                        <span class="text-xs px-1.5 py-0.5 rounded
                                            {% if sc.type == 'paybill' %}bg-blue-50 text-blue-600
                                            {% elseif sc.type in ['till', 'buygoods'] %}bg-green-50 text-green-600
                                            {% else %}bg-gray-100 text-gray-500{% endif %}">
                                            {{ sc.type }}
                                        </span>
                                    </label>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        {% else %}
                            {# Generic list — options come from constraint's allowed_values field #}
                            <select id="cv-{{ c.constraint_id }}-{{ p.id }}"
                                    class="h-8 px-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-40"
                                    onchange="saveConstraint({{ rpId }}, {{ c.constraint_id }}, this.value, this)">
                                <option value="">— default —</option>
                                {% for opt in (c.allowed_values ?? '')|split(',') %}
                                    {% set opt = opt|trim %}
                                    {% if opt %}
                                    <option value="{{ opt }}" {{ c.constraint_value == opt ? 'selected' : '' }}>{{ opt }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        {% endif %}

                        {% elseif c.constraint_type == 'time' %}
                        {# DB stores seconds; user types hours #}
                        {% set rawSeconds = c.constraint_value ?? c.default_value ?? '' %}
                        {% set displayHours = rawSeconds != '' ? (rawSeconds / 3600)|round(2) : '' %}
                        <div class="flex items-center gap-1.5">
                            <input type="number"
                                   id="cv-{{ c.constraint_id }}-{{ p.id }}"
                                   value="{{ displayHours }}"
                                   placeholder="{{ c.default_value != '' ? (c.default_value / 3600)|round(2) : '' }}"
                                   min="0"
                                   step="0.5"
                                   class="w-24 h-8 px-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 text-right"
                                   onchange="saveConstraint({{ rpId }}, {{ c.constraint_id }}, Math.round(parseFloat(this.value || 0) * 3600).toString(), this)">
                            <span class="text-xs text-gray-400">hrs</span>
                        </div>

                        {% elseif c.constraint_type in ['number', 'currency', 'percentage'] %}
                        <input type="number"
                               id="cv-{{ c.constraint_id }}-{{ p.id }}"
                               value="{{ c.constraint_value ?? c.default_value ?? '' }}"
                               placeholder="{{ c.default_value ?? '' }}"
                               class="w-28 h-8 px-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 text-right"
                               onchange="saveConstraint({{ rpId }}, {{ c.constraint_id }}, this.value, this)">

                        {% else %}
                        <input type="text"
                               id="cv-{{ c.constraint_id }}-{{ p.id }}"
                               value="{{ c.constraint_value ?? c.default_value ?? '' }}"
                               placeholder="{{ c.default_value ?? '' }}"
                               class="w-44 h-8 px-2 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               onchange="saveConstraint({{ rpId }}, {{ c.constraint_id }}, this.value, this)">
                        {% endif %}

                    {% else %}
                        {# Read-only view #}
                        {% if c.constraint_type == 'time' %}
                            {% set rawSeconds = c.constraint_value ?? c.default_value ?? '' %}
                            <span class="text-sm text-gray-700">
                                {{ rawSeconds != '' ? (rawSeconds / 3600)|round(2) ~ ' hrs' : '—' }}
                            </span>
                        {% elseif c.constraint_type == 'list' and c.constraint_key == 'allowed_shortcodes' %}
                            {% set selectedCodes = c.constraint_value ? c.constraint_value|split(',') : [] %}
                            {% set selectedCodes = selectedCodes|map(v => v|trim) %}
                            {% if selectedCodes|length == 0 %}
                                <span class="text-sm text-gray-400">—</span>
                            {% else %}
                                <div class="flex flex-col gap-1">
                                {% for sc in mpesaShortcodes %}
                                    {% if sc.shortcode in selectedCodes %}
                                        <span class="text-sm text-gray-700">{{ sc.account_name }} <span class="text-xs text-gray-400 font-mono">{{ sc.shortcode }}</span></span>
                                    {% endif %}
                                {% endfor %}
                                </div>
                            {% endif %}
                        {% else %}
                            <span class="text-sm text-gray-700 font-mono">
                                {{ c.constraint_value ?? c.default_value ?? '—' }}
                            </span>
                        {% endif %}
                    {% endif %}

                    {# Save indicator #}
                    <span class="save-indicator text-xs text-gray-300 w-5 flex-shrink-0"
                          id="save-{{ c.constraint_id }}-{{ p.id }}">
                        {% if c.constraint_value is not null %}
                            <svg width="14" height="14" fill="none" stroke="#10b981" stroke-width="2" viewBox="0 0 24 24">
                                <polyline points="20 6 9 13 4 10"/>
                            </svg>
                        {% endif %}
                    </span>
                </div>

            </div>
            {% endfor %}
            </div>

        </div>
        {% endif %}
        {# /constraints panel #}

    </div>
    {# /perm-row #}

    {% endfor %}
    </div>

</div>
{% endfor %}
</div>
{# /perm-sections #}

{% endblock %}

{% block admin_scripts %}
<script>
const roleId = {{ role.id }};
let assignedCount = {{ assignedIds|length }};

// ── ERROR MODAL ───────────────────────────────────────────────────────────────
function showError(message) {
    document.getElementById('error-modal-message').textContent = message;
    document.getElementById('error-modal').classList.remove('hidden');
}

function closeErrorModal() {
    document.getElementById('error-modal').classList.add('hidden');
    document.getElementById('error-modal-message').textContent = '';
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeErrorModal();
});

// ── SEARCH ────────────────────────────────────────────────────────────────────
document.getElementById('perm-search').oninput = function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.perm-row').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
    document.querySelectorAll('.perm-section').forEach(section => {
        const visible = [...section.querySelectorAll('.perm-row')].some(r => r.style.display !== 'none');
        section.style.display = visible ? '' : 'none';
    });
};

// ── TOGGLE PERMISSION ─────────────────────────────────────────────────────────
async function togglePermission(roleId, permId, permName, checkbox) {
    const isChecked = checkbox.checked;
    checkbox.disabled = true;

    // 2026-03-19: Use generated role action URLs so permission toggles follow
    // the current Symfony routes and dynamic tenant domain handling.
    const url = isChecked
        ? `{{ path('admin_roles_assign_permission', {subdomain: tenant_subdomain, domain: tenant_domain, id: '__ROLE_ID__'}) }}`.replace('__ROLE_ID__', roleId)
        : `{{ path('admin_roles_revoke_permission', {subdomain: tenant_subdomain, domain: tenant_domain, id: '__ROLE_ID__'}) }}`.replace('__ROLE_ID__', roleId);

    try {
        const res  = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ permission_id: permId }).toString(),
        });
        const data = await res.json();

        if (data.success) {
            assignedCount += isChecked ? 1 : -1;
            window.updatePermissionAssignedCount?.(assignedCount);
            window.updateCategoryCount?.(permId);

            const panel = document.getElementById(`constraints-${permId}`);
            if (panel) {
                if (isChecked) {
                    panel.style.display = '';
                    panel.querySelectorAll('input, select').forEach(el => el.disabled = false);
                } else {
                    panel.style.display = 'none';
                    panel.querySelectorAll('input, select').forEach(el => el.disabled = true);
                }
            }
        } else {
            checkbox.checked = !isChecked;
            showError(data.message);
        }
    } catch {
        checkbox.checked = !isChecked;
        showError('An unexpected error occurred. Please try again.');
    } finally {
        checkbox.disabled = false;
    }
}

// ── SAVE CONSTRAINT ───────────────────────────────────────────────────────────
async function saveConstraint(rolePermissionId, constraintId, value, input) {
    const row    = input.closest('[id^="constraint-row-"]');
    const permId = row ? row.id.split('-').pop() : null;
    const indEl  = permId ? document.getElementById(`save-${constraintId}-${permId}`) : null;

    if (indEl) indEl.innerHTML = '<span class="text-gray-300">…</span>';

    try {
        // 2026-03-19: Generate the constraint endpoint from Symfony so this page
        // does not depend on hardcoded tenant paths.
        const res  = await fetch(`{{ path('admin_roles_set_constraint', {subdomain: tenant_subdomain, domain: tenant_domain, id: role.id}) }}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({
                role_permission_id: rolePermissionId,
                key:                constraintId,
                value:              value,
            }).toString(),
        });
        const data = await res.json();

        if (data.success) {
            if (indEl) indEl.innerHTML = `
                <svg width="14" height="14" fill="none" stroke="#10b981" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="20 6 9 13 4 10"/>
                </svg>`;
            const labelEl = document.getElementById(`cv-label-${constraintId}-${permId}`);
            if (labelEl) labelEl.textContent = value === '1' ? 'Enabled' : 'Disabled';
        } else {
            if (indEl) indEl.innerHTML = '<span class="text-red-400">!</span>';
            showError(data.message);
        }
    } catch {
        if (indEl) indEl.innerHTML = '<span class="text-red-400">!</span>';
        showError('An unexpected error occurred. Please try again.');
    }
}

// ── SAVE SHORTCODES (multi-checkbox → comma-separated) ────────────────────────
async function saveShortcodes(rolePermissionId, constraintId, permId, changedCheckbox) {
    const checked = [...document.querySelectorAll(`.shortcode-cb-${constraintId}-${permId}:checked`)]
        .map(cb => cb.value);
    const value = checked.join(',');
    await saveConstraint(rolePermissionId, constraintId, value, changedCheckbox);
}
</script>
{% endblock %}
