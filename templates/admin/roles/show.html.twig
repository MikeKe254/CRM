{% extends 'layouts/admin.html.twig' %}

{% block admin_title %}{{ role.name }}{% endblock %}
{% block admin_subtitle %}Manage permissions assigned to this role{% endblock %}

{% block admin_actions %}
    <a href="{{ path('admin_roles') }}" class="btn-ghost" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Roles
    </a>
{% endblock %}

{% block admin_content %}

<div class="grid gap-6" style="grid-template-columns:1fr 320px;">

    {# ── LEFT: ASSIGNED PERMISSIONS ── #}
    <div>
        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
            <div style="padding:16px 20px;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between;">
                <div>
                    <div class="font-semibold text-gray-900" style="font-size:14px;">Assigned Permissions</div>
                    <div style="font-size:12px;color:#9ca3af;margin-top:2px;">
                        {% set total = 0 %}
                        {% for section in assigned %}{% set total = total + section.permissions|length %}{% endfor %}
                        {{ total }} permission{{ total != 1 ? 's' : '' }} assigned
                    </div>
                </div>
            </div>

            {% if assigned|length > 0 %}
                {% for section in assigned %}
                <div style="padding:12px 20px 4px;">
                    <div style="font-size:10px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">
                        {{ section.category }}
                    </div>
                    {% for p in section.permissions %}
                    <div id="assigned-perm-{{ p.role_permission_id }}"
                         style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:8px;border:1px solid #f3f4f6;margin-bottom:6px;background:#fafafa;">
                        <div>
                            <div style="font-size:13px;font-weight:500;color:#111827;">{{ p.name }}</div>
                            <div style="font-size:11px;color:#9ca3af;">{{ p.action_key }}</div>
                        </div>
                        <div class="flex items-center gap-2">
                            {% if p.constraints|length > 0 %}
                            <span class="badge badge-amber">{{ p.constraints|length }} constraint{{ p.constraints|length != 1 ? 's' : '' }}</span>
                            {% endif %}
                            {% if can.assign %}
                            <button class="row-action danger" style="padding:3px 8px;font-size:11px;"
                                    onclick="revokePermission({{ role.id }}, {{ p.id }}, '{{ p.name|e('js') }}')">
                                Remove
                            </button>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% endfor %}
            {% else %}
            <div style="padding:40px;text-align:center;color:#9ca3af;">
                <svg width="32" height="32" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 8px;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <div style="font-size:13px;">No permissions assigned yet.</div>
                <div style="font-size:12px;margin-top:4px;">Add permissions from the panel on the right.</div>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── RIGHT: ADD PERMISSION ── #}
    <div>
        <div class="bg-white rounded-xl border border-gray-100 overflow-hidden" style="position:sticky;top:72px;">
            <div style="padding:16px 20px;border-bottom:1px solid #f3f4f6;">
                <div class="font-semibold text-gray-900" style="font-size:14px;">Add Permission</div>
                <div style="font-size:12px;color:#9ca3af;margin-top:2px;">Click a permission to assign it</div>
            </div>

            <div style="padding:12px;">
                <div style="position:relative;margin-bottom:10px;">
                    <svg width="13" height="13" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24"
                         style="position:absolute;left:9px;top:50%;transform:translateY(-50%);pointer-events:none;">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <input class="filter-input" id="perm-search" placeholder="Filter permissions…"
                           style="width:100%;padding-left:28px;box-sizing:border-box;">
                </div>

                <div id="available-perms" style="max-height:500px;overflow-y:auto;">
                    {% for category, perms in all %}
                    <div class="perm-category" style="margin-bottom:8px;">
                        <div style="font-size:10px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:0.06em;padding:4px 4px 6px;">
                            {{ category }}
                        </div>
                        {% for p in perms %}
                        <button class="perm-item" data-perm-id="{{ p.id }}" data-perm-name="{{ p.name }}"
                                onclick="assignPermission({{ role.id }}, {{ p.id }}, '{{ p.name|e('js') }}')"
                                style="width:100%;text-align:left;padding:7px 10px;border-radius:6px;border:none;background:none;cursor:pointer;transition:background 0.12s;margin-bottom:2px;font-family:inherit;"
                                onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='none'">
                            <div style="font-size:12px;font-weight:500;color:#374151;">{{ p.name }}</div>
                            <div style="font-size:11px;color:#9ca3af;">{{ p.action_key }}</div>
                        </button>
                        {% endfor %}
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

</div>

{% endblock %}

{% block admin_scripts %}
{{ parent() }}
<script>
// Filter available permissions
document.getElementById('perm-search').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.perm-item').forEach(btn => {
        const match = btn.textContent.toLowerCase().includes(q);
        btn.style.display = match ? '' : 'none';
    });
    document.querySelectorAll('.perm-category').forEach(cat => {
        const visible = [...cat.querySelectorAll('.perm-item')].some(b => b.style.display !== 'none');
        cat.style.display = visible ? '' : 'none';
    });
});

async function assignPermission(roleId, permId, permName) {
    try {
        const res  = await fetch(`/dashboard/admin/roles/${roleId}/assign-permission`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ permission_id: permId }).toString(),
        });
        const data = await res.json();
        if (data.success) {
            location.reload();
        } else {
            alert(data.message);
        }
    } catch {
        alert('An unexpected error occurred.');
    }
}

async function revokePermission(roleId, permId, permName) {
    if (!confirm(`Remove "${permName}" from this role?`)) return;
    try {
        const res  = await fetch(`/dashboard/admin/roles/${roleId}/revoke-permission`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ permission_id: permId }).toString(),
        });
        const data = await res.json();
        if (data.success) {
            location.reload();
        } else {
            alert(data.message);
        }
    } catch {
        alert('An unexpected error occurred.');
    }
}
</script>
{% endblock %}
