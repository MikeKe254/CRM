{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% block admin_title %}Services &amp; Items{% endblock %}
{% block admin_subtitle %}Tag transactions to classify what generated each sale — not a product or inventory system{% endblock %}

{% block admin_actions %}
<a href="?inactive={{ showInactive ? '0' : '1' }}"
   class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
    {{ showInactive ? 'Hide inactive' : 'Show inactive' }}
</a>
{% if can.create %}
<button onclick="openCreateItem()"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Item
</button>
{% endif %}
{% endblock %}

{% block admin_content %}

{# ── Type filter tabs ──────────────────────────────────────────────────────── #}
<div class="flex gap-1 mb-4">
    <button onclick="filterType('')"         id="tab-all"     class="catalog-tab px-3 h-8 rounded-lg text-xs font-semibold transition-colors bg-indigo-600 text-white">All</button>
    <button onclick="filterType('service')"  id="tab-service" class="catalog-tab px-3 h-8 rounded-lg text-xs font-semibold transition-colors bg-white border border-gray-200 text-gray-600 hover:bg-gray-50">Services</button>
    <button onclick="filterType('product')"  id="tab-product" class="catalog-tab px-3 h-8 rounded-lg text-xs font-semibold transition-colors bg-white border border-gray-200 text-gray-600 hover:bg-gray-50">Products</button>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden"
     data-catalog-base="{{ path('admin_catalog', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="catalog-search" type="text" placeholder="Search items…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
        <span class="ml-auto text-xs text-gray-400" id="catalog-count">{{ items|length }} item{{ items|length != 1 ? 's' : '' }}</span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full min-w-0" id="catalog-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Item</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Type</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Price</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Terminal</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Status</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody>
            {% for item in items %}
            <tr id="catalog-row-{{ item.id }}"
                data-type="{{ item.type }}"
                class="border-b border-gray-50 hover:bg-gray-50 transition-colors {{ item.status == 'inactive' ? 'opacity-60' : '' }}">
                <td class="px-4 py-3 min-w-0">
                    <div class="flex items-start gap-2.5">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5
                            {{ item.type == 'service' ? 'bg-violet-50' : 'bg-sky-50' }}">
                            {% if item.type == 'service' %}
                            <svg width="14" height="14" fill="none" stroke="#7c3aed" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
                            </svg>
                            {% else %}
                            <svg width="14" height="14" fill="none" stroke="#0284c7" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
                            </svg>
                            {% endif %}
                        </div>
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-1.5">
                                <span class="text-sm font-medium text-gray-900">{{ item.name }}</span>
                                <span class="sm:hidden text-xs px-1.5 py-0.5 rounded font-semibold
                                    {{ item.type == 'service' ? 'bg-violet-50 text-violet-700' : 'bg-sky-50 text-sky-700' }}">
                                    {{ item.type|capitalize }}
                                </span>
                            </div>
                            {% if item.category %}
                            <p class="text-xs text-gray-400 mt-0.5">{{ item.category }}</p>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell whitespace-nowrap">
                    <span class="text-xs px-2 py-0.5 rounded font-semibold
                        {{ item.type == 'service' ? 'bg-violet-50 text-violet-700' : 'bg-sky-50 text-sky-700' }}">
                        {{ item.type|capitalize }}
                    </span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell whitespace-nowrap">
                    {% if item.price is not null %}
                        <span class="text-sm font-semibold text-gray-800">KES {{ item.price|number_format(0) }}</span>
                    {% else %}
                        <span class="text-xs text-gray-400">—</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden md:table-cell whitespace-nowrap">
                    {% if item.show_in_terminal %}
                        <span class="text-xs bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded font-semibold">Shown</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-400 px-2 py-0.5 rounded font-semibold">Hidden</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden sm:table-cell whitespace-nowrap">
                    {% if item.status == 'active' %}
                        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded font-semibold">Active</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded font-semibold">Inactive</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                    <div class="flex items-center justify-end gap-1">
                        {% if can.edit %}
                        <button onclick="openEditItem({{ item|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        <button onclick="toggleItemStatus({{ item.id }}, '{{ item.status }}', '{{ item.name|e('js') }}')"
                                class="text-xs {{ item.status == 'active' ? 'text-amber-600 border-amber-200 hover:bg-amber-50' : 'text-emerald-600 border-emerald-200 hover:bg-emerald-50' }} border bg-white px-2.5 py-1 rounded transition-colors hidden sm:inline-flex">
                            {{ item.status == 'active' ? 'Deactivate' : 'Activate' }}
                        </button>
                        {% endif %}
                        {% if can.delete %}
                        <button onclick="deleteItem({{ item.id }}, '{{ item.name|e('js') }}')"
                                class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="px-4 py-12 text-center text-sm text-gray-400">No items found. Add services and products to classify revenue.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block admin_scripts %}{# JS in assets/js/admin/catalog.js #}{% endblock %}
