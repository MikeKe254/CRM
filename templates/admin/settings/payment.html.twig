            requires_receipt:    chk('ca-receipt'),
            requires_approval:   chk('ca-approval'),
            approval_threshold:  val('ca-approval-threshold'),
            float_amount:        val('ca-float'),
            reconciliation_email:val('ca-email'),
            notes:               val('ca-notes'),
            is_active:           chk('ca-active'),
        },
