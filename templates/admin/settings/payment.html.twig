                    <p style="font-size:.75rem;color:#9ca3af;margin-top:2px;">Transactions above the threshold need manager sign-off.</p>
                </div>
                <label class="s-toggle">
                    <input type="checkbox" id="ca-approval" ${cfg.requires_approval?'checked':''}>
                    <span class="s-toggle-track"><span class="s-toggle-knob"></span></span>
