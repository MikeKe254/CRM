        'Add Bank Account',
        html,
        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitCreateBank()" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Create</button>`
    );
}

function submitCreateBank() {
    adminFetch(_createBankUrl, {
        account_name:        val('cbk-name'),
        bank_name:           val('cbk-bank-name'),
        account_holder_name: val('cbk-holder'),
        account_number:      val('cbk-accno'),
        currency:            val('cbk-currency'),
    }, () => { closeDrawer(); turboReload(); });
}

/* ════════════════════════════════════════════
   CREATE PESAPAL DRAWER
════════════════════════════════════════════ */
function openCreatePesapalDrawer() {
    const html = `
    <div id="drawer-error" class="hidden mb-4 px-3.5 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>

    <div class="d-group">
        <div class="d-group-title">Environment</div>
        <div class="s-select-wrap">
            <select id="cpp-env" class="s-input" style="width:100%;padding-right:2.25rem;">
                <option value="sandbox">Sandbox — testing only</option>
                <option value="production">Production — live transactions</option>
            </select>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
    </div>

    <p style="font-size:.75rem;color:#9ca3af;line-height:1.6;">
        Only one Pesapal integration is allowed per company. The config will be created inactive.
        Add your API credentials after creation.
    </p>`;

    openDrawer(
        'Add Pesapal Integration',
        html,
        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitCreatePesapal()" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Create</button>`
    );
}

function submitCreatePesapal() {
    adminFetch(_createPesapalUrl, {
        environment: val('cpp-env'),
    }, () => { closeDrawer(); turboReload(); });
}

/* ════════════════════════════════════════════
   CARD
════════════════════════════════════════════ */
const _CARD_NETWORKS = [
    { key: 'visa',       label: 'Visa' },
    { key: 'mastercard', label: 'Mastercard' },
    { key: 'amex',       label: 'Amex' },
    { key: 'unionpay',   label: 'UnionPay' },
    { key: 'discover',   label: 'Discover' },
];

function cardNetworkCheckboxes(selected) {
    return _CARD_NETWORKS.map(n => `
        <label style="display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:#374151;cursor:pointer;">
            <input type="checkbox" name="accepted_cards[]" value="${n.key}" ${selected.includes(n.key) ? 'checked' : ''}
                   style="width:1rem;height:1rem;accent-color:#6d28d9;">
            ${n.label}
        </label>`).join('');
}

const _CARD_TYPES = [
    { key: 'pdq',     label: 'PDQ Machine',      hint: 'Countertop or portable card terminal' },
    { key: 'mpos',    label: 'Mobile POS',        hint: 'Phone-attached reader (SumUp, iZettle, etc.)' },
    { key: 'tap',     label: 'Tap & Pay',         hint: 'Contactless / NFC terminal' },
    { key: 'virtual', label: 'Virtual Terminal',  hint: 'Manual card-not-present entry' },
];

function cardTypeOptions(selected) {
    return _CARD_TYPES.map(t => `<option value="${t.key}" ${selected === t.key ? 'selected' : ''}>${t.label} — ${t.hint}</option>`).join('');
}

function openCreateCardDrawer() {
    const html = `
        <div class="space-y-3">
            <div><label class="s-label">Terminal Type</label>
                <select id="ccd-type" class="s-input">${cardTypeOptions('pdq')}</select></div>
            <div><label class="s-label">Account / Terminal Label <span class="text-gray-400 font-normal">(optional)</span></label>
                <input id="ccd-name" class="s-input" placeholder="e.g. Main Counter PDQ"></div>
            <div><label class="s-label">Acquiring Bank <span class="text-gray-400 font-normal">(optional)</span></label>
                <input id="ccd-bank" class="s-input" placeholder="e.g. KCB, Equity, NCBA"></div>
        </div>`;

    openDrawer(
        'Add Card Terminal',
        html,
        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitCreateCard()" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Create</button>`
    );
}

function submitCreateCard() {
    adminFetch(_createCardUrl, {
        type:           val('ccd-type'),
        account_name:   val('ccd-name'),
        acquiring_bank: val('ccd-bank'),
    }, () => { closeDrawer(); turboReload(); });
}

function openCardDrawer(cfg) {
    const selected = cfg.accepted_cards_decoded ?? [];
    const html = `
        <div class="space-y-3">
            <div><label class="s-label">Terminal Type</label>
                <select id="cd-type" class="s-input">${cardTypeOptions(cfg.type ?? 'pdq')}</select></div>
            <div><label class="s-label">Account / Terminal Label</label>
                <input id="cd-name" class="s-input" value="${esc(cfg.account_name ?? '')}"></div>
            <div><label class="s-label">Acquiring Bank</label>
                <input id="cd-bank" class="s-input" value="${esc(cfg.acquiring_bank ?? '')}" placeholder="e.g. KCB, Equity, NCBA"></div>
            <div><label class="s-label">Merchant ID</label>
                <input id="cd-mid" class="s-input font-mono" value="${esc(cfg.merchant_id ?? '')}" placeholder="MID from your bank"></div>
            <div><label class="s-label">Terminal ID</label>
                <input id="cd-tid" class="s-input font-mono" value="${esc(cfg.terminal_id ?? '')}" placeholder="TID from your terminal"></div>
            <div>
                <label class="s-label">Accepted Card Networks</label>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.375rem .75rem;margin-top:.375rem;" id="cd-networks">
                    ${cardNetworkCheckboxes(selected)}
                </div>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:.75rem 1.5rem;">
                <label style="display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:#374151;cursor:pointer;">
                    <input type="checkbox" id="cd-active" ${cfg.is_active ? 'checked' : ''} style="width:1rem;height:1rem;accent-color:#6d28d9;">
                    Active
                </label>
                <label style="display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:#374151;cursor:pointer;">
                    <input type="checkbox" id="cd-receipt" ${cfg.requires_receipt ? 'checked' : ''} style="width:1rem;height:1rem;accent-color:#6d28d9;">
                    Require receipt
                </label>
                <label style="display:flex;align-items:center;gap:.5rem;font-size:.8125rem;color:#374151;cursor:pointer;">
                    <input type="checkbox" id="cd-code-req" ${cfg.transaction_code_required ? 'checked' : ''} style="width:1rem;height:1rem;accent-color:#6d28d9;">
                    Transaction code required
                </label>
            </div>
            <div><label class="s-label">Notes / Instructions</label>
                <textarea id="cd-notes" class="s-input" rows="2" placeholder="Optional staff-facing instructions">${esc(cfg.notes ?? '')}</textarea></div>
        </div>`;

    openDrawer(
        'Configure Card Terminal',
        html,
        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitCard(${cfg.id})" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save</button>`
    );
}

function submitCard(id) {
    const params = new URLSearchParams();
    params.set('type',           val('cd-type'));
    params.set('account_name',   val('cd-name'));
    params.set('acquiring_bank', val('cd-bank'));
    params.set('merchant_id',    val('cd-mid'));
    params.set('terminal_id',    val('cd-tid'));
    params.set('currency',       'KES');
    params.set('is_active',                   document.getElementById('cd-active')?.checked   ? '1' : '0');
    params.set('requires_receipt',            document.getElementById('cd-receipt')?.checked  ? '1' : '0');
    params.set('transaction_code_required',   document.getElementById('cd-code-req')?.checked ? '1' : '0');
    params.set('notes',          val('cd-notes'));

    document.querySelectorAll('#cd-networks input[type=checkbox]:checked').forEach(cb => {
        params.append('accepted_cards[]', cb.value);
    });

    adminFetch(replaceId(_cardBaseUrl, id), params, () => { closeDrawer(); turboReload(); });
}

/* ════════════════════════════════════════════
   OTHER TOGGLE
════════════════════════════════════════════ */
function toggleOtherPayment(enable) {
    const label = enable ? 'enable' : 'disable';
    window.adminConfirm({
        title:   (enable ? 'Enable' : 'Disable') + ' Other payments?',
        message: enable
            ? 'Cashiers at this branch will be able to record ad-hoc payments with a description.'
            : 'Other will be removed from this branch\'s payment options.',
        confirmLabel: enable ? 'Enable' : 'Disable',
        onConfirm: () => {
            adminFetch(_toggleOtherUrl, { enabled: enable ? '1' : '0' }, () => { turboReload(); });
        },
    });
}

/* ════════════════════════════════════════════
   DELETE
════════════════════════════════════════════ */
function confirmDelete(type, id, label) {
    const urlMap = { mpesa: _deleteMpesaUrl, bank: _deleteBankUrl, pesapal: _deletePesapalUrl, card: _deleteCardUrl };
    const url    = urlMap[type].replace(/\/0\/delete/, '/' + id + '/delete');

    window.adminConfirm({
        title:   'Delete ' + label + '?',
        message: 'This will permanently remove this configuration.',
        type:    'danger',
        confirm: 'Delete',
        onConfirm: () => {
            adminFetch(url, {}, () => { turboReload(); });
        },
    });
}
</script>

{% endblock %}
