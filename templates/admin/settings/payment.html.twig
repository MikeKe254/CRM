        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitCash(${cfg.id})" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save changes</button>`
    );
}

function submitCash(id) {
    adminFetch(
        replaceId(_cashBaseUrl, id),
        {
            account_name:        val('ca-name'),
            currency:            val('ca-currency'),
            min_amount:          val('ca-min'),
