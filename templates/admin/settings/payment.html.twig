function submitCreateMpesa() {
    const type = val('cmp-type');
    const payload = {
        type:        type,
        account_name:val('cmp-name'),
        shortcode:   val('cmp-shortcode'),
        environment: val('cmp-env'),
    };
    if (type === 'buygoods') {
        payload.till_number = val('cmp-till');
    }
    adminFetch(_createMpesaUrl, payload, () => { closeDrawer(); turboReload(); });
}

