function openPesapalDrawer(cfg) {
    const envOpts = [
        {v:'sandbox',    l:'Sandbox — testing only'},
        {v:'production', l:'Production — live transactions'},
    ].map(e => `<option value="${e.v}" ${cfg.environment===e.v?'selected':''}>${e.l}</option>`).join('');

    const html = `
    <div id="drawer-error" class="hidden mb-4 px-3.5 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>

    <div class="d-group">
        <div class="d-group-title">Environment</div>
        <div class="s-select-wrap">
            <select id="pp-env" class="s-input" style="width:100%;padding-right:2.25rem;">${envOpts}</select>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
    </div>

    <div class="d-group">
        <div class="d-group-title">API Credentials</div>
        <div class="space-y-3">
            ${secretField('pp-consumer-key',    'Consumer Key',    cfg.consumer_key_value??'',    true)}
            ${secretField('pp-consumer-secret', 'Consumer Secret', cfg.consumer_secret_value??'', true)}
        </div>
    </div>

    <div class="d-group">
        <div class="d-group-title">Callback URLs</div>
        <div class="space-y-3">
            ${urlInput('pp-ipn', 'IPN URL', cfg.ipn_url, 'https://yourdomain.com/pesapal/ipn')}
            ${urlInput('pp-callback', 'Callback URL', cfg.callback_url, 'https://yourdomain.com/pesapal/callback')}
            ${urlInput('pp-cancel', 'Cancellation URL', cfg.cancellation_url, 'https://yourdomain.com/pesapal/cancel')}
        </div>
    </div>

    <div class="d-group">
        <div class="d-group-title">Accepted Methods</div>
        <div class="space-y-2">
            ${['cards','mpesa','airtel','bank'].map(m => `
            <label style="display:flex;align-items:center;gap:.75rem;padding:.625rem .875rem;border-radius:.5rem;border:1px solid #e5e7eb;background:#f9fafb;cursor:pointer;">
                <input type="checkbox" id="pp-${m}" ${cfg['accepts_'+m]?'checked':''} style="accent-color:#4f46e5;width:15px;height:15px;flex-shrink:0;">
                <span style="font-size:.875rem;font-weight:600;color:#111827;">${m==='mpesa'?'M-Pesa':m==='airtel'?'Airtel Money':m==='cards'?'Cards (Visa/Mastercard)':'Bank Transfer'}</span>
            </label>`).join('')}
        </div>
    </div>

    <div class="d-group">
        <div class="d-group-title">Status</div>
        <div class="space-y-2">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.75rem 1rem;border-radius:.5rem;border:1px solid #e5e7eb;background:#f9fafb;">
                <div>
                    <p style="font-size:.875rem;font-weight:600;color:#111827;">Integration enabled</p>
                    <p style="font-size:.75rem;color:#9ca3af;margin-top:2px;">Process payments via Pesapal gateway.</p>
                </div>
                <label class="s-toggle">
                    <input type="checkbox" id="pp-enabled" ${cfg.integration_enabled?'checked':''}>
                    <span class="s-toggle-track"><span class="s-toggle-knob"></span></span>
                </label>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.75rem 1rem;border-radius:.5rem;border:1px solid #e5e7eb;background:#f9fafb;">
                <div>
                    <p style="font-size:.875rem;font-weight:600;color:#111827;">Active</p>
                    <p style="font-size:.75rem;color:#9ca3af;margin-top:2px;">Pesapal is selectable as a payment method at checkout.</p>
                </div>
                <label class="s-toggle">
                    <input type="checkbox" id="pp-active" ${cfg.is_active?'checked':''}>
                    <span class="s-toggle-track"><span class="s-toggle-knob"></span></span>
                </label>
            </div>
        </div>
    </div>`;

    openDrawer(
        'Configure Pesapal',
        html,
        `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
         <button data-primary onclick="submitPesapal(${cfg.id})" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save changes</button>`
    );
}

function submitPesapal(id) {
    adminFetch(
