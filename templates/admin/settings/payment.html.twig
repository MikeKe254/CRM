        <div class="s-select-wrap">
            <select id="cmp-env" class="s-input" style="width:100%;padding-right:2.25rem;">
                <option value="sandbox">Sandbox — testing only</option>
                <option value="production">Production — live transactions</option>
            </select>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
