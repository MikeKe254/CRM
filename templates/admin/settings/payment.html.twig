        </div>
    </div>

    <div class="d-group">
        <div class="d-group-title">Notes</div>
        <textarea id="ca-notes" rows="3"
                  placeholder="Internal notes about this cash account..."
                  style="width:100%;padding:.5rem .875rem;font-size:.875rem;color:#111827;background:#fff;border:1px solid #d1d5db;border-radius:.5rem;outline:none;resize:none;transition:border-color .15s,box-shadow .15s;box-sizing:border-box;"
