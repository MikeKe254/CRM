{% extends 'admin/settings/_layout.html.twig' %}

{% block settings_content %}

{% set sub = subscription %}
{% set current_plan_id = sub.plan_id ?? null %}

<style>
.bill-hero,
.bill-card,
.bill-compare { max-width: 960px; }
.bill-hero {
    padding: 1.5rem 1.5rem 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background:
        radial-gradient(circle at top right, rgba(99,102,241,.10), transparent 36%),
        linear-gradient(135deg, #ffffff 0%, #f8fafc 55%, #eef2ff 100%);
    box-shadow: 0 1px 4px rgba(0,0,0,.05);
}
.bill-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:.875rem; margin-top:1.25rem; }
.bill-stat { border:1px solid #e5e7eb; border-radius:.875rem; background:rgba(255,255,255,.85); padding:.9rem 1rem; }
.bill-stat-label { font-size:.6875rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:#9ca3af; }
.bill-stat-value { margin-top:.3rem; font-size:1rem; font-weight:700; color:#111827; }
.bill-card {
    margin-top:1.25rem; border:1px solid #e5e7eb; border-radius:1rem; background:#fff;
    box-shadow:0 1px 4px rgba(0,0,0,.05); overflow:hidden;
}
.bill-card-head { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:1rem 1.25rem; border-bottom:1px solid #f3f4f6; }
.bill-card-body { padding:1.25rem; }
.bill-plan-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:1rem; }
.bill-plan-card {
    position:relative; display:flex; flex-direction:column; gap:.9rem; height:100%;
    border:1px solid #e5e7eb; border-radius:1rem; background:#fff; padding:1rem;
}
.bill-plan-card.is-current {
    border-color:#c7d2fe; background:linear-gradient(180deg, #eef2ff 0%, #ffffff 70%);
    box-shadow:0 12px 30px rgba(99,102,241,.10);
}
.bill-pill { display:inline-flex; align-items:center; gap:.35rem; padding:.28rem .65rem; border-radius:999px; font-size:.6875rem; font-weight:700; letter-spacing:.05em; text-transform:uppercase; }
.bill-limit-box {
    display:grid; gap:.55rem; border:1px solid #e5e7eb; border-radius:.85rem; background:#f8fafc; padding:.85rem .9rem;
}
.bill-limit-row { display:flex; align-items:center; justify-content:space-between; gap:1rem; font-size:.8125rem; }
.bill-limit-row span:first-child { color:#6b7280; }
.bill-limit-row strong { color:#111827; font-weight:700; }
.bill-list { display:grid; gap:.65rem; }
.bill-list-item { display:flex; align-items:flex-start; gap:.6rem; font-size:.8125rem; color:#4b5563; line-height:1.45; }
.bill-dot {
    width:1.1rem; height:1.1rem; border-radius:999px; display:inline-flex; align-items:center; justify-content:center;
    flex-shrink:0; margin-top:.05rem; background:#eef2ff; color:#4f46e5;
}
.bill-override-list { display:grid; gap:.875rem; }
.bill-override-item { border:1px solid #e5e7eb; border-radius:.9rem; background:#fff; padding:.95rem 1rem; }
.bill-override-meta { display:flex; align-items:center; gap:.55rem; flex-wrap:wrap; }
.bill-table-wrap { overflow-x:auto; }
.bill-table { min-width:760px; width:100%; border-collapse:collapse; }
.bill-table th, .bill-table td { padding:.9rem 1rem; border-top:1px solid #f1f5f9; text-align:left; vertical-align:top; }
.bill-table thead th { border-top:none; background:#f8fafc; font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; color:#94a3b8; font-weight:700; }
.bill-table td:first-child, .bill-table th:first-child { position:sticky; left:0; background:#fff; z-index:1; }
.bill-table thead th:first-child { background:#f8fafc; z-index:2; }
.bill-table-section td { background:#f8fafc !important; font-size:.72rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:#94a3b8; }

@media (max-width: 1024px) {
    .bill-grid,
    .bill-plan-grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
}

@media (max-width: 767px) {
    .bill-hero { padding:1rem; }
    .bill-grid,
    .bill-plan-grid { grid-template-columns:1fr; }
    .bill-card-head,
    .bill-card-body { padding:1rem; }
}
</style>

<div class="bill-hero">
    <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div class="max-w-2xl">
            <span class="inline-flex items-center rounded-full border border-indigo-100 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-indigo-700">
                Billing &amp; Plan
            </span>
            <h2 class="mt-4 text-xl font-bold tracking-tight text-gray-900 md:text-2xl">
                Understand what your company is running on.
            </h2>
            <p class="mt-2 text-sm leading-6 text-gray-500">
                Your current subscription, included capabilities, operational limits, and any active platform overrides are all visible here.
            </p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white/90 px-4 py-3 text-sm shadow-sm">
            <div class="text-[11px] font-semibold uppercase tracking-[0.14em] text-gray-400">Plan changes</div>
            <div class="mt-1 font-semibold text-gray-800">Managed by platform support</div>
            <div class="mt-1 text-xs text-gray-500">Reach out if you need an upgrade, downgrade, or temporary override.</div>
        </div>
    </div>

    <div class="bill-grid">
        <div class="bill-stat">
            <div class="bill-stat-label">Current Plan</div>
            <div class="bill-stat-value">{{ sub.plan_name ?? 'No active plan' }}</div>
        </div>
        <div class="bill-stat">
            <div class="bill-stat-label">Status</div>
            <div class="bill-stat-value">
                {% if sub %}
                    {{ sub.status|replace({'_':' '})|title }}
                {% else %}
                    Inactive
                {% endif %}
            </div>
        </div>
        <div class="bill-stat">
            <div class="bill-stat-label">Billing Cycle</div>
            <div class="bill-stat-value">
                {% if sub %}
                    {{ sub.billing_cycle|title }}
                {% else %}
                    —
                {% endif %}
            </div>
        </div>
        <div class="bill-stat">
            <div class="bill-stat-label">Current Period</div>
            <div class="bill-stat-value">
                {% if sub and sub.ends_at %}
                    Until {{ sub.ends_at|date('d M Y') }}
                {% elseif sub %}
                    Ongoing
                {% else %}
                    —
                {% endif %}
            </div>
        </div>
    </div>
</div>

<section class="bill-card">
    <div class="bill-card-head">
        <div>
            <h3 class="text-sm font-semibold text-gray-900">Available plans</h3>
            <p class="mt-0.5 text-xs text-gray-500">Your current plan is highlighted. The full comparison stays visible below for context.</p>
        </div>
    </div>
    <div class="bill-card-body">
        <div class="bill-plan-grid">
            {% for plan in plans %}
                {% set users = plan.limit_summary.users ?? null %}
                {% set branches = plan.limit_summary.branches ?? null %}
                {% set sms = plan.limit_summary.sms ?? null %}
                <article class="bill-plan-card {{ plan.is_current ? 'is-current' }}">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <div class="flex items-center gap-2 flex-wrap">
                                <h4 class="text-lg font-bold tracking-tight text-gray-900">{{ plan.name }}</h4>
                                {% if plan.is_current %}
                                    <span class="bill-pill bg-indigo-100 text-indigo-700">Current</span>
                                {% elseif plan.featured %}
                                    <span class="bill-pill bg-slate-100 text-slate-600">Popular</span>
                                {% endif %}
                            </div>
                            {% if plan.description %}
                                <p class="mt-2 text-sm leading-6 text-gray-500">{{ plan.description }}</p>
                            {% endif %}
                        </div>
                        <span class="rounded-full bg-gray-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-gray-500">
                            {{ plan.slug }}
                        </span>
                    </div>

                    <div>
                        {% if plan.monthly_price == 0 %}
                            <div class="text-3xl font-black tracking-tight text-gray-900">Free</div>
                            <p class="mt-1 text-xs text-gray-500">No billing required.</p>
                        {% else %}
                            <div class="flex items-end gap-2">
                                <span class="text-3xl font-black tracking-tight text-gray-900">{{ plan.currency }} {{ plan.monthly_price|number_format(0) }}</span>
                                <span class="pb-1 text-xs text-gray-500">/ month</span>
                            </div>
                            <p class="mt-1 text-xs text-gray-500">
                                Annual {{ plan.currency }} {{ plan.annual_price|number_format(0) }}
                                {% if plan.trial_days > 0 %}· {{ plan.trial_days }}-day trial{% endif %}
                            </p>
                        {% endif %}
                    </div>

                    <div class="bill-limit-box">
                        <div class="bill-limit-row">
                            <span>Users</span>
                            <strong>{{ users == -1 ? 'Unlimited' : (users is null ? '—' : users|number_format(0)) }}</strong>
                        </div>
                        <div class="bill-limit-row">
                            <span>Branches</span>
                            <strong>{{ branches == -1 ? 'Unlimited' : (branches is null ? '—' : branches|number_format(0)) }}</strong>
                        </div>
                        <div class="bill-limit-row">
                            <span>SMS / month</span>
                            <strong>{{ sms == -1 ? 'Unlimited' : (sms is null ? '—' : sms|number_format(0)) }}</strong>
                        </div>
                    </div>

                    <div class="bill-list">
                        {% for highlight in plan.highlights|slice(0, 5) %}
                            <div class="bill-list-item">
                                <span class="bill-dot">
                                    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                </span>
                                <span>{{ highlight }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="bill-card">
    <div class="bill-card-head">
        <div>
            <h3 class="text-sm font-semibold text-gray-900">Current subscription</h3>
            <p class="mt-0.5 text-xs text-gray-500">This reflects the active subscription record currently driving plan entitlement.</p>
        </div>
        {% if sub %}
            <span class="bill-pill {{ sub.status in ['active','trial'] ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-600' }}">
                {{ sub.status|replace({'_':' '})|title }}
            </span>
        {% endif %}
    </div>
    <div class="bill-card-body">
        {% if sub %}
            <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-400">Plan</div>
                    <div class="mt-1 text-lg font-bold text-gray-900">{{ sub.plan_name }}</div>
                    {% if sub.plan_description %}
                        <p class="mt-2 text-sm leading-6 text-gray-500">{{ sub.plan_description }}</p>
                    {% endif %}
                </div>
                <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-400">Billing details</div>
                    <div class="mt-3 space-y-2 text-sm text-gray-600">
                        <div class="flex items-center justify-between gap-3"><span>Cycle</span><strong class="text-gray-900">{{ sub.billing_cycle|title }}</strong></div>
                        <div class="flex items-center justify-between gap-3"><span>Started</span><strong class="text-gray-900">{{ sub.started_at ? sub.started_at|date('d M Y, H:i') : '—' }}</strong></div>
                        <div class="flex items-center justify-between gap-3"><span>Ends</span><strong class="text-gray-900">{{ sub.ends_at ? sub.ends_at|date('d M Y, H:i') : 'Ongoing' }}</strong></div>
                        {% if sub.trial_ends_at %}
                            <div class="flex items-center justify-between gap-3"><span>Trial ends</span><strong class="text-gray-900">{{ sub.trial_ends_at|date('d M Y, H:i') }}</strong></div>
                        {% endif %}
                        {% if sub.amount_paid is not null %}
                            <div class="flex items-center justify-between gap-3"><span>Amount paid</span><strong class="text-gray-900">{{ sub.currency }} {{ sub.amount_paid|number_format(2) }}</strong></div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {% if sub.notes %}
                <div class="mt-4 rounded-xl border border-indigo-100 bg-indigo-50 px-4 py-3 text-sm leading-6 text-indigo-900">
                    <strong class="font-semibold">Internal note:</strong> {{ sub.notes }}
                </div>
            {% endif %}
        {% else %}
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm leading-6 text-amber-800">
                No active subscription record was found for this company. Contact platform support to assign a plan and restore entitlements cleanly.
            </div>
        {% endif %}
    </div>
</section>

<section class="bill-card">
    <div class="bill-card-head">
        <div>
            <h3 class="text-sm font-semibold text-gray-900">Active overrides</h3>
            <p class="mt-0.5 text-xs text-gray-500">These override the normal plan defaults for your company until they expire or are removed.</p>
        </div>
    </div>
    <div class="bill-card-body">
        {% if active_overrides is empty %}
            <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-4 text-sm text-gray-500">
                No active feature overrides are currently applied to this company.
            </div>
        {% else %}
            <div class="bill-override-list">
                {% for override in active_overrides %}
                    <div class="bill-override-item">
                        <div class="bill-override-meta">
                            <span class="bill-pill {{ override.is_enabled ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-700' }}">
                                {{ override.is_enabled ? 'Override On' : 'Override Off' }}
                            </span>
                            <span class="text-sm font-semibold text-gray-900">{{ override.feature_name }}</span>
                            <span class="text-xs text-gray-400">{{ override.module_name }} / {{ override.submodule_name }}</span>
                        </div>
                        {% if override.reason %}
                            <p class="mt-2 text-sm leading-6 text-gray-600">{{ override.reason }}</p>
                        {% endif %}
                        <div class="mt-2 text-xs text-gray-500">
                            {% if override.expires_at %}
                                Expires {{ override.expires_at|date('d M Y, H:i') }}
                            {% else %}
                                No expiry set
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<section class="bill-card bill-compare">
    <div class="bill-card-head">
        <div>
            <h3 class="text-sm font-semibold text-gray-900">Detailed plan comparison</h3>
            <p class="mt-0.5 text-xs text-gray-500">A direct side-by-side view of public plans, feature coverage, and operational limits.</p>
        </div>
    </div>
    <div class="bill-card-body">
        <div class="bill-table-wrap">
            <table class="bill-table">
                <thead>
                    <tr>
                        <th>Capability</th>
                        {% for plan in plans %}
                            <th>
                                <div class="text-sm font-bold normal-case tracking-normal text-gray-900">{{ plan.name }}</div>
                                <div class="mt-1 text-[11px] font-medium normal-case tracking-normal text-gray-400">
                                    {% if plan.monthly_price == 0 %}
                                        Free
                                    {% else %}
                                        {{ plan.currency }} {{ plan.monthly_price|number_format(0) }}/mo
                                    {% endif %}
                                </div>
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for section in comparison_sections %}
                        <tr class="bill-table-section">
                            <td colspan="{{ plans|length + 1 }}">{{ section.title }}</td>
                        </tr>
                        {% for row in section.rows %}
                            <tr>
                                <td class="text-sm font-medium text-gray-700">{{ row.label }}</td>
                                {% for plan in plans %}
                                    <td>
                                        {% if row.plans[plan.id] %}
                                            <span class="bill-pill bg-emerald-50 text-emerald-700">Included</span>
                                        {% else %}
                                            <span class="bill-pill bg-gray-100 text-gray-500">Not included</span>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                    {% endfor %}

                    <tr class="bill-table-section">
                        <td colspan="{{ plans|length + 1 }}">Plan limits</td>
                    </tr>
                    {% for row in limit_rows %}
                        <tr>
                            <td class="text-sm font-medium text-gray-700">{{ row.label }}</td>
                            {% for plan in plans %}
                                <td class="text-sm text-gray-600">{{ row.values[plan.id] }}</td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

{% endblock %}
