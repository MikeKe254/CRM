{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% block admin_title %}Events &amp; Offers{% endblock %}
{% block admin_subtitle %}Revenue context and promotions — appear at checkout automatically based on the clock. One record per recurring item, forever.{% endblock %}

{% block admin_actions %}
<a href="?all={{ showAll ? '0' : '1' }}"
   class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
    {{ showAll ? 'Hide past &amp; cancelled' : 'Show all' }}
</a>
{% if can.create %}
<button onclick="openCreateEvent()"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add
</button>
{% endif %}
{% endblock %}

{% block admin_content %}

{# ── Entry type tabs ───────────────────────────────────────────────────────── #}
<div class="flex gap-1 mb-4">
    <button onclick="filterEntryType('')"       data-tab=""       class="ev-entry-tab px-3 h-8 rounded-lg border text-xs font-semibold transition-colors" style="background:#4f46e5;color:#fff;border-color:#4f46e5;">All</button>
    <button onclick="filterEntryType('event')"  data-tab="event"  class="ev-entry-tab px-3 h-8 rounded-lg border text-xs font-semibold transition-colors" style="background:#fff;color:#4b5563;border-color:#e5e7eb;">Events</button>
    <button onclick="filterEntryType('offer')"  data-tab="offer"  class="ev-entry-tab px-3 h-8 rounded-lg border text-xs font-semibold transition-colors" style="background:#fff;color:#4b5563;border-color:#e5e7eb;">Offers</button>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden"
     data-events-base="{{ path('admin_events', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="events-search" type="text" placeholder="Search events…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
        <span class="ml-auto text-xs text-gray-400" id="events-count">{{ events|length }} item{{ events|length != 1 ? 's' : '' }}</span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full min-w-0" id="events-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Event</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Schedule</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">State</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody>
            {% for event in events %}
            <tr id="event-row-{{ event.id }}"
                data-entry-type="{{ event.entry_type ?? 'event' }}"
                class="border-b border-gray-50 hover:bg-gray-50 transition-colors {{ event.status == 'cancelled' ? 'opacity-50' : '' }}">

                <td class="px-4 py-3 min-w-0">
                    <div class="flex items-start gap-2.5">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5
                            {{ event._is_running ? 'bg-emerald-50' : (event.recurrence_type != 'none' ? 'bg-indigo-50' : 'bg-amber-50') }}">
                            {% if event.recurrence_type != 'none' %}
                            <svg width="14" height="14" fill="none" stroke="{{ event._is_running ? '#059669' : '#6366f1' }}" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
                            </svg>
                            {% else %}
                            <svg width="14" height="14" fill="none" stroke="{{ event._is_running ? '#059669' : '#d97706' }}" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                            </svg>
                            {% endif %}
                        </div>
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-1.5">
                                <span class="text-sm font-medium text-gray-900">{{ event.name }}</span>
                                {% if (event.entry_type ?? 'event') == 'offer' %}
                                    <span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded font-semibold">Offer</span>
                                {% endif %}
                                {% if event._is_running %}
                                    <span class="inline-flex items-center gap-1 text-xs bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded font-semibold">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse inline-block"></span>Running now
                                    </span>
                                {% elseif event.status == 'cancelled' %}
                                    <span class="text-xs bg-red-50 text-red-500 px-1.5 py-0.5 rounded font-semibold">Cancelled</span>
                                {% endif %}
                            </div>
                            {% if event.description %}
                            <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{{ event.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                </td>

                <td class="px-4 py-3 hidden md:table-cell">
                    <div class="text-xs space-y-0.5">
                        {% if event.recurrence_type != 'none' %}
                            <div class="font-semibold text-indigo-700">{{ event._recurrence }}</div>
                            {% if event.recurrence_valid_from or event.recurrence_valid_until %}
                            <div class="text-gray-400">
                                {{ event.recurrence_valid_from ? 'From ' ~ event.recurrence_valid_from|date('d M Y') : 'Started' }}
                                {{ event.recurrence_valid_until ? ' · Until ' ~ event.recurrence_valid_until|date('d M Y') : ' · Ongoing' }}
                            </div>
                            {% else %}
                                <div class="text-gray-400">Ongoing indefinitely</div>
                            {% endif %}
                        {% else %}
                            {% if event.starts_at %}
                            <div class="text-gray-600">From <span class="font-medium">{{ event.starts_at|date('d M Y, H:i') }}</span></div>
                            {% endif %}
                            {% if event.ends_at %}
                            <div class="text-gray-600">Until <span class="font-medium">{{ event.ends_at|date('d M Y, H:i') }}</span>
                                {% if event.ends_at|date('Y-m-d') > event.starts_at|date('Y-m-d') %}
                                <span class="text-amber-500 font-semibold">(next day)</span>
                                {% endif %}
                            </div>
                            {% endif %}
                            {% if not event.starts_at and not event.ends_at %}
                            <span class="text-gray-400 italic">No schedule — manually controlled</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </td>

                <td class="px-4 py-3 hidden sm:table-cell whitespace-nowrap">
                    {% if event._is_running %}
                        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded font-semibold">Running</span>
                    {% elseif event.status == 'cancelled' %}
                        <span class="text-xs bg-red-50 text-red-500 px-2 py-0.5 rounded font-semibold">Cancelled</span>
                    {% elseif event.recurrence_type != 'none' %}
                        <span class="text-xs bg-indigo-50 text-indigo-600 px-2 py-0.5 rounded font-semibold">Recurring</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded font-semibold">Scheduled</span>
                    {% endif %}
                </td>

                <td class="px-4 py-3 whitespace-nowrap">
                    <div class="flex items-center justify-end gap-1">
                        {% if can.edit %}
                        <button onclick="openEditEvent({{ event|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        {% if event.status != 'cancelled' %}
                        <button onclick="setStatus({{ event.id }}, 'cancelled', '{{ event.name|e('js') }}')"
                                class="text-xs text-red-500 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors hidden sm:inline-flex">Cancel</button>
                        {% else %}
                        <button onclick="setStatus({{ event.id }}, 'draft', '{{ event.name|e('js') }}')"
                                class="text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 px-2.5 py-1 rounded transition-colors hidden sm:inline-flex">Restore</button>
                        {% endif %}
                        {% endif %}
                        {% if can.delete %}
                        <button onclick="deleteEvent({{ event.id }}, '{{ event.name|e('js') }}')"
                                class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="px-4 py-12 text-center text-sm text-gray-400">No events. Create recurring events or one-off events to tag transaction revenue.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block admin_scripts %}{# JS in assets/js/admin/events.js #}{% endblock %}
