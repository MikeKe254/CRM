{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = session.branch is defined and session.branch ? session.branch.slug : app.request.attributes.get('branch') %}

{% block admin_title %}Branches{% endblock %}
{% block admin_subtitle %}Manage the organisational hierarchy for {{ session.company.name }}{% endblock %}

{% block admin_actions %}
{% if can.create %}
<button onclick="openCreateBranch(null, null)"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Branch
</button>
{% endif %}
{% endblock %}

{# ── BRANCH TREE MACRO ──────────────────────────────────────────────────────── #}
{% macro branchRow(node, can, depth) %}
<div class="branch-node" id="branch-node-{{ node.id }}" data-id="{{ node.id }}" data-depth="{{ depth }}" data-name="{{ node.name|e('html_attr') }}" data-status="{{ node.status }}">
    <div class="branch-row group flex items-center gap-2 py-2.5 hover:bg-gray-50 transition-colors border-b border-gray-50"
         style="padding-left: {{ (depth * 24) + 16 }}px; padding-right: 16px;">

        {# Expand / collapse toggle #}
        {% if node.children|length > 0 %}
        <button class="branch-toggle flex-shrink-0 w-5 h-5 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-colors rounded"
                onclick="toggleBranchChildren(this, {{ node.id }})" title="Expand/collapse">
            <svg class="branch-chevron transition-transform duration-150" style="transform: rotate(90deg);"
                 width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </button>
        {% else %}
        <span class="flex-shrink-0 w-5 h-5"></span>
        {% endif %}

        {# Branch icon #}
        <div class="flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0
            {% if node.isHq %}bg-purple-100 text-purple-700
            {% elseif node.status == 'inactive' %}bg-gray-100 text-gray-400
            {% else %}bg-indigo-50 text-indigo-600{% endif %}">
            {% if node.isHq %}
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {% else %}
                {{ node.name|first|upper }}
            {% endif %}
        </div>

        {# Name and badges #}
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 flex-wrap">
                <span class="text-sm font-medium {% if node.status == 'inactive' %}line-through text-gray-400{% else %}text-gray-900{% endif %}">
                    {{ node.name }}
                </span>
                {% if node.isHq %}
                    <span class="text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded bg-purple-50 text-purple-600">HQ</span>
                {% endif %}
                {% if node.status == 'inactive' %}
                    <span class="text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded bg-amber-50 text-amber-600">Inactive</span>
                {% endif %}
                <span class="text-[10px] font-medium px-1.5 py-0.5 rounded bg-gray-100 text-gray-500 capitalize">{{ node.type }}</span>
                <span class="text-xs text-gray-400 font-mono">/{{ node.slug }}</span>
            </div>
        </div>

        {# Action buttons — shown on hover #}
        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
            {% if can.create and (node.isHq or node.type == 'region') %}
            <button onclick="openCreateBranch({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 rounded transition-colors">
                + Child
            </button>
            {% endif %}
            {% if can.edit and not node.isHq %}
            <button onclick="openRenameBranch({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 rounded transition-colors">
                Rename
            </button>
            <button onclick="openMoveBranch({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 rounded transition-colors">
                Move
            </button>
            {% endif %}
            {% if can.deactivate and not node.isHq %}
            {% if node.status == 'active' %}
            <button onclick="doDeactivate({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-amber-600 border border-amber-200 bg-white hover:bg-amber-50 rounded transition-colors">
                Deactivate
            </button>
            {% else %}
            <button onclick="doActivate({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-green-600 border border-green-200 bg-white hover:bg-green-50 rounded transition-colors">
                Activate
            </button>
            {% endif %}
            {% endif %}
            {% if can.delete and not node.isHq %}
            <button onclick="doDelete({{ node.id }}, '{{ node.name|e('js') }}')"
                    class="h-7 px-2 text-xs text-red-500 border border-red-200 bg-white hover:bg-red-50 rounded transition-colors">
                Delete
            </button>
            {% endif %}
        </div>
    </div>

    {# Children #}
    {% if node.children|length > 0 %}
    <div class="branch-children" id="branch-children-{{ node.id }}">
        {% for child in node.children %}
            {{ _self.branchRow(child, can, depth + 1) }}
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endmacro %}

{% block admin_content %}
{% import _self as treeMacro %}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    {# Toolbar #}
    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="flex items-center gap-1.5">
            <button onclick="expandAll()"
                    class="h-8 px-3 text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 rounded-lg transition-colors">
                Expand all
            </button>
            <button onclick="collapseAll()"
                    class="h-8 px-3 text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 rounded-lg transition-colors">
                Collapse all
            </button>
        </div>
        <span class="ml-auto text-xs text-gray-400">
            {{ allBranches|length }} branch{{ allBranches|length != 1 ? 'es' : '' }}
        </span>
    </div>

    {# Tree #}
    <div id="branch-tree">
        {% for root in tree %}
            {{ treeMacro.branchRow(root, can, 0) }}
        {% else %}
        <div class="px-6 py-12 text-center text-sm text-gray-400">
            No branches found.
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}

{% block admin_scripts %}
<script>
// ── Route stubs ──────────────────────────────────────────────────────────────
const BRANCH_BASE = '{{ path('admin_branches', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}';
const CREATE_URL  = '{{ path('admin_branches_create', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}';

// id→name map for the "move" parent selector
const ALL_BRANCHES = {{ allBranches|json_encode|raw }};

// ── Tree expand / collapse ───────────────────────────────────────────────────
function toggleBranchChildren(btn, nodeId) {
    const children = document.getElementById('branch-children-' + nodeId);
    if (!children) return;
    const chevron = btn.querySelector('.branch-chevron');
    const isOpen  = !children.classList.contains('hidden');
    if (isOpen) {
        children.classList.add('hidden');
        chevron.style.transform = 'rotate(0deg)';
    } else {
        children.classList.remove('hidden');
        chevron.style.transform = 'rotate(90deg)';
    }
}
function expandAll() {
    document.querySelectorAll('.branch-children').forEach(el => el.classList.remove('hidden'));
    document.querySelectorAll('.branch-chevron').forEach(el => el.style.transform = 'rotate(90deg)');
}
function collapseAll() {
    document.querySelectorAll('.branch-children').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.branch-chevron').forEach(el => el.style.transform = 'rotate(0deg)');
}

// ── Auto-slug from name ──────────────────────────────────────────────────────
function autoSlug(nameId, slugId) {
    const name = document.getElementById(nameId)?.value ?? '';
    document.getElementById(slugId).value = name.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-').replace(/-+/g, '-');
}

// ── Drawer helpers ───────────────────────────────────────────────────────────
function di(label, id, type = 'text', value = '', placeholder = '', hint = '') {
    return `<div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">${label}</label>
        <input id="${id}" type="${type}" value="${escHtml(String(value))}" placeholder="${placeholder}"
               class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
        ${hint ? `<p class="text-xs text-gray-400 mt-1">${hint}</p>` : ''}
    </div>`;
}
function ds(label, id, options, selected = '') {
    const opts = options.map(o =>
        `<option value="${o.id}" ${o.id == selected ? 'selected' : ''}>${'—'.repeat(o.depth)}${o.depth > 0 ? ' ' : ''}${escHtml(o.name)}${o.is_hq ? ' (HQ)' : ''}</option>`
    ).join('');
    return `<div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">${label}</label>
        <select id="${id}" class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
            <option value="">— Select parent —</option>${opts}
        </select>
    </div>`;
}
function drawerFooter(onSave, saveLabel = 'Save') {
    return `
        <button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        <button data-primary onclick="${onSave}" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">${saveLabel}</button>
    `;
}
function drawerError() {
    return `<div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>`;
}
function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Create ───────────────────────────────────────────────────────────────────
function openCreateBranch(parentId, parentName) {
    const label      = parentName ? `Under: ${parentName}` : 'Company HQ (default parent)';
    const parentNode = parentId ? ALL_BRANCHES.find(b => b.id == parentId) : null;
    const parentIsHq = parentNode ? !!parentNode.is_hq : false;

    // Branches are leaf nodes — guard against any path that gets here with a branch parent
    if (parentNode && !parentIsHq && parentNode.type === 'branch') {
        alert('Branch nodes cannot have children. Add children under a Region or HQ node.');
        return;
    }

    // When adding under HQ, let the user choose Region vs HQ Branch.
    // For all other parents, the type is always 'branch' (auto-derived).
    const typeHtml = parentIsHq
        ? `<div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Type <span class="text-red-500">*</span></label>
            <select id="c-type" class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="region">Region — manages a group of branches</option>
                <option value="branch">HQ Branch — the physical Head Office branch (max 1)</option>
            </select>
            <p class="text-xs text-gray-400 mt-1">HQ can have one operational branch plus any number of regions.</p>
           </div>`
        : `<div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
            <div class="text-sm text-gray-500 bg-gray-50 rounded-lg px-3 py-2 border border-gray-200">
                ${parentId ? 'Branch — inferred from parent' : 'Region — direct child of HQ'}
            </div>
            <p class="text-xs text-gray-400 mt-1">HQ → Region → Branch. Type is set by the hierarchy.</p>
           </div>`;

    const body = `${drawerError()}
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Parent Branch</label>
            <div class="text-sm text-gray-700 bg-gray-50 rounded-lg px-3 py-2 border border-gray-200">${escHtml(label)}</div>
            <input type="hidden" id="c-parent-id"     value="${parentId ?? ''}">
            <input type="hidden" id="c-parent-is-hq"  value="${parentIsHq ? '1' : '0'}">
        </div>
        ${di('Branch Name <span class="text-red-500">*</span>', 'c-name', 'text', '', 'e.g. Nairobi Branch')}
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Slug <span class="text-red-500">*</span></label>
            <div class="flex items-center gap-1.5">
                <span class="text-sm text-gray-400">/</span>
                <input id="c-slug" type="text" placeholder="nairobi-branch"
                       class="flex-1 h-9 px-3 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
            </div>
            <p class="text-xs text-gray-400 mt-1">Immutable after creation. Lowercase letters, numbers and hyphens only.</p>
        </div>
        ${typeHtml}`;

    openDrawer('Add Branch', body, drawerFooter('submitCreate()', 'Create Branch'));

    // Wire auto-slug
    document.getElementById('c-name').addEventListener('input', () => autoSlug('c-name', 'c-slug'));
}

async function submitCreate() {
    const parentId   = document.getElementById('c-parent-id').value;
    const parentIsHq = document.getElementById('c-parent-is-hq')?.value === '1';
    const name       = document.getElementById('c-name').value.trim();
    const slug       = document.getElementById('c-slug').value.trim();

    // Only send 'type' when adding under HQ — otherwise server derives it
    const payload = { name, slug, parent_id: parentId };
    if (parentIsHq) {
        payload.type = document.getElementById('c-type')?.value ?? 'region';
    }

    await adminFetch(CREATE_URL, payload, () => turboReload());
}

// ── Rename ───────────────────────────────────────────────────────────────────
function openRenameBranch(id, currentName) {
    const body = `${drawerError()}
        ${di('New Name <span class="text-red-500">*</span>', 'r-name', 'text', currentName, '', 'The URL slug does not change.')}`;
    openDrawer('Rename Branch', body, drawerFooter(`submitRename(${id})`));
}

async function submitRename(id) {
    const name = document.getElementById('r-name').value.trim();
    const url  = BRANCH_BASE + '/' + id + '/rename';
    await adminFetch(url, { name }, () => turboReload());
}

// ── Move ─────────────────────────────────────────────────────────────────────
function openMoveBranch(id, name) {
    // Filter out the branch itself and its own subtree from options
    const options = ALL_BRANCHES.filter(b => b.id != id);
    const body = `${drawerError()}
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Moving</label>
            <div class="text-sm font-medium text-gray-700 bg-gray-50 rounded-lg px-3 py-2 border border-gray-200">${escHtml(name)}</div>
        </div>
        ${ds('New Parent <span class="text-red-500">*</span>', 'm-parent', options)}`;
    openDrawer('Move Branch', body, drawerFooter(`submitMove(${id})`));
}

async function submitMove(id) {
    const parentId = document.getElementById('m-parent').value;
    if (!parentId) {
        const err = document.getElementById('drawer-error');
        if (err) { err.textContent = 'Please select a target parent.'; err.classList.remove('hidden'); }
        return;
    }
    const url = BRANCH_BASE + '/' + id + '/move';
    await adminFetch(url, { parent_id: parentId }, () => turboReload());
}

// ── Deactivate / Activate ────────────────────────────────────────────────────
async function doDeactivate(id, name) {
    await adminDelete(
        BRANCH_BASE + '/' + id + '/deactivate',
        `Deactivate "${name}" and all its sub-branches?\n\nUsers assigned here will lose access until it is reactivated.`,
        () => turboReload(),
    );
}

async function doActivate(id, name) {
    await adminDelete(
        BRANCH_BASE + '/' + id + '/activate',
        `Reactivate "${name}"?`,
        () => turboReload(),
    );
}

// ── Delete ───────────────────────────────────────────────────────────────────
async function doDelete(id, name) {
    await adminDelete(
        BRANCH_BASE + '/' + id + '/delete',
        `Permanently delete "${name}"?\n\nThis also deletes all sub-branches and cannot be undone.\n\nNote: branches with active user assignments cannot be deleted.`,
        () => turboReload(),
    );
}
</script>
{% endblock %}
