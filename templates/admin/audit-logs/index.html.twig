{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% block admin_title %}Audit Logs{% endblock %}
{% block admin_subtitle %}Track all system activity — super admin only{% endblock %}

{% block admin_content %}

<form method="GET" class="bg-white rounded-xl border border-gray-200 p-4 mb-4">
    <div class="flex flex-wrap items-end gap-3">
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">User</label>
            <select name="user_id" class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-44">
                <option value="">All users</option>
                {% for u in users %}
                <option value="{{ u.id }}" {{ filters.user_id == u.id ? 'selected' : '' }}>{{ u.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Action</label>
            <input name="action" type="text" value="{{ filters.action ?? '' }}" placeholder="e.g. assign_permission"
                   class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-48">
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">From</label>
            <input name="date_from" type="date" value="{{ filters.date_from ?? '' }}"
                   class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-40">
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">To</label>
            <input name="date_to" type="date" value="{{ filters.date_to ?? '' }}"
                   class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-40">
        </div>
        <button type="submit" class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Filter</button>
        {% if filters|filter(v => v is not empty)|length > 0 %}
        {# 2026-03-19: Pass the current base domain so tenant admin links remain valid on both localhost and public hosts. #}
        <a href="{{ path('admin_audit_logs', {subdomain: tenant_subdomain, domain: tenant_domain, branch: app.request.attributes.get('branch')}) }}" class="h-9 px-4 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center">Clear</a>
        {% endif %}
    </div>
</form>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <span class="text-xs text-gray-400">{{ total }} log{{ total != 1 ? 's' : '' }}</span>
        {% if pages > 1 %}<span class="text-xs text-gray-400">Page {{ page }} of {{ pages }}</span>{% endif %}
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Time</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">User</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Action</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Target</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Notes</th>
                </tr>
            </thead>
            <tbody>
            {% for log in logs %}
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">
                    {{ log.created_at|date('d M Y') }}<br>
                    <span class="text-gray-400">{{ log.created_at|date('H:i:s') }}</span>
                </td>
                <td class="px-4 py-3">
                    {% if log.user_name %}
                    <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center text-xs font-semibold flex-shrink-0">
                            {{ log.user_name|first|upper }}
                        </div>
                        <span class="text-sm text-gray-700">{{ log.user_name }}</span>
                    </div>
                    {% else %}<span class="text-xs text-gray-400">System</span>{% endif %}
                </td>
                <td class="px-4 py-3">
                    <code class="text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded font-mono">{{ log.action }}</code>
                </td>
                <td class="px-4 py-3 text-xs text-gray-500">
                    {% if log.target_table %}{{ log.target_table }}{% if log.target_id %} #{{ log.target_id }}{% endif %}{% else %}—{% endif %}
                </td>
                <td class="px-4 py-3 text-xs text-gray-500 max-w-xs truncate">{{ log.notes ?? '—' }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">No logs found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
    <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-gray-100">
        {% for p in 1..pages %}
        <a href="?{{ app.request.query.all|merge({page: p})|url_encode }}"
           class="w-8 h-8 flex items-center justify-center rounded-lg text-sm transition-colors {{ p == page ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' }}">
            {{ p }}
        </a>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
