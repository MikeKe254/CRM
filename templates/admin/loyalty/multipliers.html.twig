{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}

{% block admin_title %}Point Multipliers{% endblock %}
{% block admin_subtitle %}Boost earn rates for specific days, times, or date ranges{% endblock %}

{% block admin_actions %}
{% if program %}
<button onclick="openCreateMultiplier()"
        class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Multiplier
</button>
{% endif %}
{% endblock %}

{% block admin_content %}

{% if not program %}
<div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-sm text-gray-400">No loyalty programme configured. <a href="{{ path('admin_settings_loyalty', _rp) }}" class="text-indigo-600 hover:underline">Set it up →</a></p>
</div>
{% else %}

{# Info banner #}
<div class="bg-indigo-50 border border-indigo-200 rounded-xl px-5 py-4 mb-5">
    <div class="flex items-start gap-3">
        <svg class="flex-shrink-0 mt-0.5" width="15" height="15" fill="none" stroke="#4f46e5" stroke-width="1.75" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="text-sm text-indigo-700 leading-relaxed">
            Multipliers temporarily boost the earn rate for qualifying transactions.
            The <strong>highest active multiplier</strong> at the time of the transaction is applied.
            The base rate is <strong>{{ program.points_per_unit }} {{ program.points_name ?? 'pts' }} per {{ program.unit_amount }} KES</strong>.
        </p>
    </div>
</div>

{% if multipliers|length == 0 %}
<div class="bg-white rounded-xl border border-gray-200 flex flex-col items-center justify-center py-20 text-center px-6">
    <div class="w-14 h-14 rounded-2xl bg-purple-50 flex items-center justify-center mb-4">
        <svg width="24" height="24" fill="none" stroke="#8b5cf6" stroke-width="1.5" viewBox="0 0 24 24">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
    </div>
    <p class="text-sm font-medium text-gray-700 mb-1">No multipliers yet</p>
    <p class="text-sm text-gray-400 mb-5">Create a double-points weekend or a happy-hour boost.</p>
    <button onclick="openCreateMultiplier()"
            class="h-9 px-5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
        Add first multiplier
    </button>
</div>
{% else %}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <span class="text-xs text-gray-400">{{ multipliers|length }} rule{{ multipliers|length != 1 ? 's' : '' }}</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Name</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Multiplier</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Days</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Time window</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden lg:table-cell">Date range</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Status</th>
                    <th class="px-4 py-3 w-32"></th>
                </tr>
            </thead>
            <tbody>
            {% for m in multipliers %}
            {% set day_map = {mon:'Mon',tue:'Tue',wed:'Wed',thu:'Thu',fri:'Fri',sat:'Sat',sun:'Sun'} %}
            <tr id="mult-row-{{ m.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3">
                    <span class="text-sm font-semibold text-gray-900">{{ m.name }}</span>
                </td>
                <td class="px-4 py-3">
                    <span class="text-lg font-bold text-indigo-700">{{ m.multiplier }}×</span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                    {% if m.applies_on %}
                    <span class="text-xs text-gray-500">
                        {% for key in m.applies_on|split(',') %}
                            <span class="inline-block bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded text-[11px] font-medium mr-0.5">{{ day_map[key]|default(key)|upper }}</span>
                        {% endfor %}
                    </span>
                    {% else %}
                    <span class="text-xs text-gray-300">Every day</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                    {% if m.time_from or m.time_to %}
                    <span class="text-xs text-gray-500 font-mono">{{ m.time_from ?? '00:00' }} – {{ m.time_to ?? '23:59' }}</span>
                    {% else %}
                    <span class="text-xs text-gray-300">All day</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                    {% if m.valid_from or m.valid_to %}
                    <span class="text-xs text-gray-500">{{ m.valid_from ? m.valid_from|date('d M Y') : '∞' }} – {{ m.valid_to ? m.valid_to|date('d M Y') : '∞' }}</span>
                    {% else %}
                    <span class="text-xs text-gray-300">No limit</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3">
                    <label class="s-toggle" title="{{ m.is_active ? 'Active — click to pause' : 'Paused — click to activate' }}">
                        <input type="checkbox" {{ m.is_active ? 'checked' : '' }}
                               onchange="toggleMultiplier({{ m.id }}, this)">
                        <span class="s-toggle-track"><span class="s-toggle-knob"></span></span>
                    </label>
                </td>
                <td class="px-4 py-3">
                    <div class="flex items-center gap-1">
                        <button onclick="openEditMultiplier({{ m|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        <button onclick="deleteMultiplier({{ m.id }}, '{{ m.name|e('js') }}')"
                                class="text-xs text-red-500 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                    </div>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endif %}
{% endif %}
{% endblock %}

{% block admin_scripts %}
<style>
.s-toggle { position:relative; display:inline-flex; align-items:center; cursor:pointer; flex-shrink:0; }
.s-toggle input { position:absolute; opacity:0; width:0; height:0; pointer-events:none; }
.s-toggle-track { display:block; width:40px; height:22px; border-radius:100px; background:#e5e7eb; transition:background .18s ease; }
.s-toggle-knob { position:absolute; top:3px; left:3px; width:16px; height:16px; border-radius:50%; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.18); transition:transform .18s ease; pointer-events:none; }
.s-toggle input:checked ~ .s-toggle-track { background:#4f46e5; }
.s-toggle input:checked ~ .s-toggle-track .s-toggle-knob { transform:translateX(18px); }
</style>
<script>
const _multCreateUrl = '{{ path('admin_loyalty_multipliers_create', _rp) }}';
const _multUpdateUrl = (id) => `{{ path('admin_loyalty_multipliers_update', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);
const _multToggleUrl = (id) => `{{ path('admin_loyalty_multipliers_toggle', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);
const _multDeleteUrl = (id) => `{{ path('admin_loyalty_multipliers_delete', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);

const DAYS = ['mon','tue','wed','thu','fri','sat','sun'];
const DAY_LABELS = { mon:'Mon', tue:'Tue', wed:'Wed', thu:'Thu', fri:'Fri', sat:'Sat', sun:'Sun' };

function multiplierFormHtml(m = {}) {
    const activeDays = m.applies_on ? m.applies_on.split(',') : [];
    const dayChecks = DAYS.map(d => `
        <label class="cursor-pointer">
            <input type="checkbox" name="applies_on" value="${d}" ${activeDays.includes(d)?'checked':''} class="sr-only peer">
            <span class="block px-2.5 py-1 border rounded-lg text-xs font-semibold transition-colors peer-checked:bg-indigo-600 peer-checked:text-white peer-checked:border-indigo-600 border-gray-200 text-gray-600 hover:bg-gray-50">${DAY_LABELS[d]}</span>
        </label>`).join('');
    return `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
            <input id="m-name" type="text" value="${m.name??''}" maxlength="100" placeholder="e.g. Double Points Weekend"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Multiplier *</label>
            <input id="m-mult" type="number" value="${m.multiplier??2}" min="1.01" max="10" step="0.01"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            <p class="text-xs text-gray-400 mt-1">Minimum 1.01 — e.g. 2 means double points.</p>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">Applies on days <span class="text-gray-400 font-normal">(leave blank for all days)</span></label>
            <div class="flex flex-wrap gap-1.5">${dayChecks}</div>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Time from</label>
                <input id="m-tfrom" type="time" value="${m.time_from??''}"
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Time to</label>
                <input id="m-tto" type="time" value="${m.time_to??''}"
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            </div>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-1">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Valid from</label>
                <input id="m-dfrom" type="date" value="${m.valid_from??''}"
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Valid to</label>
                <input id="m-dto" type="date" value="${m.valid_to??''}"
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
            </div>
        </div>`;
}

function collectMultiplierParams() {
    const p   = new URLSearchParams();
    const days = [...document.querySelectorAll('input[name=applies_on]:checked')].map(el => el.value);
    p.append('name',       document.getElementById('m-name').value);
    p.append('multiplier', document.getElementById('m-mult').value);
    if (days.length) p.append('applies_on', days.join(','));
    p.append('time_from',  document.getElementById('m-tfrom').value);
    p.append('time_to',    document.getElementById('m-tto').value);
    p.append('valid_from', document.getElementById('m-dfrom').value);
    p.append('valid_to',   document.getElementById('m-dto').value);
    return p;
}

function drawerFooter(onClick) {
    return `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
            <button data-primary onclick="${onClick}" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save</button>`;
}

async function submitMultiplierForm(url, params) {
    const btn = document.querySelector('#admin-drawer-footer button[data-primary]');
    const err = document.getElementById('drawer-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
    try {
        const res  = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString() });
        const data = await res.json();
        if (data.success) { closeDrawer(); turboReload(); }
        else if (err) { err.textContent = data.message ?? 'An error occurred.'; err.classList.remove('hidden'); }
    } catch {
        if (err) { err.textContent = 'Network error.'; err.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Save'; }
    }
}

function openCreateMultiplier() { openDrawer('Add Multiplier', multiplierFormHtml(), drawerFooter('submitCreateMultiplier()')); }
function openEditMultiplier(m)   { openDrawer('Edit Multiplier', multiplierFormHtml(m), drawerFooter(`submitEditMultiplier(${m.id})`)); }
function submitCreateMultiplier() { submitMultiplierForm(_multCreateUrl, collectMultiplierParams()); }
function submitEditMultiplier(id) { submitMultiplierForm(_multUpdateUrl(id), collectMultiplierParams()); }

async function toggleMultiplier(id, checkbox) {
    try {
        const res  = await fetch(_multToggleUrl(id), { method: 'POST' });
        const data = await res.json();
        if (!data.success) {
            checkbox.checked = !checkbox.checked; // revert
            alert(data.message ?? 'Failed to toggle multiplier.');
        }
    } catch {
        checkbox.checked = !checkbox.checked;
    }
}

function deleteMultiplier(id, name) {
    adminDelete(_multDeleteUrl(id), `Delete multiplier "${name}"? This cannot be undone.`, () => {
        document.getElementById(`mult-row-${id}`)?.remove();
    });
}
</script>
{% endblock %}
