{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}
{% set pages = per_page > 0 and total > 0 ? ((total / per_page)|round(0, 'ceil')) : 1 %}

{% block admin_title %}Points Ledger{% endblock %}
{% block admin_subtitle %}Every earn, redeem, and adjustment — company-wide{% endblock %}

{% block admin_actions %}
{% if can.export %}
<a href="{{ path('admin_loyalty_ledger_export', _rp) }}?{{ app.request.query.all|url_encode }}"
   class="h-9 px-3 border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Export CSV
</a>
{% endif %}
{% endblock %}

{% block admin_content %}

{# ── Filters ─────────────────────────────────────────────────────────── #}
<form method="GET" class="bg-white rounded-xl border border-gray-200 p-4 mb-4">
    <div class="flex flex-wrap items-end gap-3">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" value="{{ search }}" placeholder="Member name or phone…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-52">
        </div>
        <div>
            <select name="type" class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="">All types</option>
                <option value="earn"         {{ type == 'earn'         ? 'selected' : '' }}>Earn</option>
                <option value="redeem"       {{ type == 'redeem'       ? 'selected' : '' }}>Redeem</option>
                <option value="adjust"       {{ type == 'adjust'       ? 'selected' : '' }}>Adjustment</option>
                <option value="enroll_bonus" {{ type == 'enroll_bonus' ? 'selected' : '' }}>Enrol bonus</option>
                <option value="expire"       {{ type == 'expire'       ? 'selected' : '' }}>Expire</option>
            </select>
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">From</label>
            <input type="date" name="from" value="{{ date_from }}"
                   class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-40">
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">To</label>
            <input type="date" name="to" value="{{ date_to }}"
                   class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-40">
        </div>
        <button type="submit"
                class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
            Filter
        </button>
        {% if search or type or date_from or date_to %}
        <a href="{{ path('admin_loyalty_ledger', _rp) }}"
           class="h-9 px-4 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center">
            Clear
        </a>
        {% endif %}
    </div>
</form>

{# ── Ledger table ────────────────────────────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <span class="text-xs text-gray-400">{{ total|number_format }} entr{{ total != 1 ? 'ies' : 'y' }}</span>
        {% if pages > 1 %}<span class="text-xs text-gray-400">Page {{ page }} of {{ pages }}</span>{% endif %}
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Date</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Member</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Type</th>
                    <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Points</th>
                    <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Balance after</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Note</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden lg:table-cell">Cashier</th>
                </tr>
            </thead>
            <tbody>
            {% for entry in entries %}
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">
                    {{ entry.created_at|date('d M Y') }}<br>
                    <span class="text-gray-400">{{ entry.created_at|date('H:i') }}</span>
                </td>
                <td class="px-4 py-3">
                    <div class="text-sm font-medium text-gray-900">{{ entry.first_name ?? '—' }}</div>
                    <div class="text-xs text-gray-400 font-mono">
                        {% if can.view_full_phone %}
                            {{ entry.msisdn }}
                        {% else %}
                            {{ (entry.msisdn|slice(0,5)) ~ '••••' ~ (entry.msisdn|slice(-3)) }}
                        {% endif %}
                    </div>
                </td>
                <td class="px-4 py-3">
                    {% set type_classes = {
                        'earn':         'bg-emerald-50 text-emerald-700',
                        'redeem':       'bg-amber-50 text-amber-700',
                        'adjust':       'bg-blue-50 text-blue-700',
                        'enroll_bonus': 'bg-purple-50 text-purple-700',
                        'expire':       'bg-red-50 text-red-500',
                    } %}
                    <span class="text-xs font-semibold px-2 py-0.5 rounded {{ type_classes[entry.type] ?? 'bg-gray-100 text-gray-600' }}">
                        {{ entry.type|replace({'_': ' '})|capitalize }}
                    </span>
                </td>
                <td class="px-4 py-3 text-right">
                    <span class="text-sm font-semibold {{ entry.points >= 0 ? 'text-emerald-600' : 'text-red-500' }}">
                        {{ entry.points >= 0 ? '+' : '' }}{{ entry.points|number_format(2) }}
                    </span>
                </td>
                <td class="px-4 py-3 text-right hidden sm:table-cell">
                    <span class="text-sm text-gray-500 font-mono">{{ entry.balance_after|number_format(0) }}</span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                    <span class="text-xs text-gray-400 max-w-xs truncate inline-block">
                        {% if entry.note %}{{ entry.note|length > 50 ? entry.note|slice(0, 47) ~ '…' : entry.note }}
                        {% elseif entry.pos_transaction_id %}POS #{{ entry.pos_transaction_id }}
                        {% else %}—{% endif %}
                    </span>
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                    <span class="text-xs text-gray-400">{{ entry.cashier_name ?? '—' }}</span>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="7" class="px-4 py-12 text-center text-sm text-gray-400">
                {% if search or type or date_from or date_to %}No entries match your filters.
                {% else %}No ledger entries yet.{% endif %}
            </td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
    <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-gray-100">
        {% for p in 1..pages %}
        <a href="?{{ app.request.query.all|merge({page: p})|url_encode }}"
           class="w-8 h-8 flex items-center justify-center rounded-lg text-sm transition-colors
                  {{ p == page ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' }}">
            {{ p }}
        </a>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}
