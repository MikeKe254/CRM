{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}

{% block admin_title %}Loyalty Tiers{% endblock %}
{% block admin_subtitle %}{{ program.program_name ?? 'Tier levels' }} — reward thresholds{% endblock %}

{% block admin_actions %}
{% if can.manage %}
<button onclick="openCreateTier()"
        class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Tier
</button>
{% endif %}
{% endblock %}

{% block admin_content %}

{% if not program %}
<div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-sm text-gray-400">No loyalty programme configured.
        {% if isSuperAdmin() or can('edit_loyalty_program') is defined %}
        <a href="{{ path('admin_settings_loyalty', _rp) }}" class="text-indigo-600 hover:underline">Set it up →</a>
        {% endif %}
    </p>
</div>
{% else %}

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <div>
            <span class="text-xs text-gray-500 font-medium">{{ tiers|length }} tier{{ tiers|length != 1 ? 's' : '' }}</span>
            <span class="text-xs text-gray-300 ml-2">·</span>
            <span class="text-xs text-gray-400 ml-2">Customers advance automatically when their balance crosses a threshold.</span>
        </div>
        {% if can.manage and tiers|length > 1 %}
        <button onclick="saveOrder()" id="reorder-btn"
                class="hidden h-7 px-3 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold rounded-lg transition-colors">
            Save order
        </button>
        {% endif %}
    </div>

    <div class="overflow-x-auto">
        <table class="w-full" id="tiers-table">
            <thead>
                <tr class="border-b border-gray-100">
                    {% if can.manage and tiers|length > 1 %}
                    <th class="w-8 px-3 py-3"></th>
                    {% endif %}
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Tier</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Min {{ program.points_name ?? 'Points' }}</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Members</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Perks</th>
                    <th class="px-4 py-3 w-28"></th>
                </tr>
            </thead>
            <tbody id="tiers-body">
            {% for tier in tiers %}
            <tr id="tier-row-{{ tier.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0"
                data-tier-id="{{ tier.id }}">
                {% if can.manage and tiers|length > 1 %}
                <td class="px-3 py-3 text-gray-300 cursor-grab drag-handle">
                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20">
                        <circle cx="7" cy="5" r="1.5"/><circle cx="13" cy="5" r="1.5"/>
                        <circle cx="7" cy="10" r="1.5"/><circle cx="13" cy="10" r="1.5"/>
                        <circle cx="7" cy="15" r="1.5"/><circle cx="13" cy="15" r="1.5"/>
                    </svg>
                </td>
                {% endif %}
                <td class="px-4 py-3">
                    <div class="flex items-center gap-2.5">
                        <span class="w-3 h-3 rounded-full flex-shrink-0"
                              style="background:{{ tier.color ?? '#6366f1' }};"></span>
                        <span class="text-sm font-semibold text-gray-900">{{ tier.name }}</span>
                    </div>
                </td>
                <td class="px-4 py-3">
                    <span class="text-sm text-gray-700 font-mono">{{ tier.min_points|number_format }}</span>
                </td>
                <td class="px-4 py-3">
                    <span class="text-sm text-gray-600">{{ tier.member_count|number_format }}</span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                    <span class="text-sm text-gray-400 truncate max-w-xs inline-block">
                        {{ tier.perks_description ? (tier.perks_description|length > 60 ? tier.perks_description|slice(0, 57) ~ '…' : tier.perks_description) : '—' }}
                    </span>
                </td>
                <td class="px-4 py-3">
                    {% if can.manage %}
                    <div class="flex items-center gap-1">
                        <button onclick="openEditTier({{ tier|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        <button onclick="deleteTier({{ tier.id }}, '{{ tier.name|e('js') }}', {{ tier.member_count }})"
                                class="text-xs text-red-500 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                    </div>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="{{ can.manage ? '6' : '5' }}" class="px-4 py-16 text-center">
                    <p class="text-sm text-gray-400 mb-3">No tiers configured yet.</p>
                    {% if can.manage %}
                    <button onclick="openCreateTier()"
                            class="h-8 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold rounded-lg transition-colors">
                        Add your first tier
                    </button>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>

{% endif %}
{% endblock %}

{% block admin_scripts %}
<script>
const _tiersUrl    = '{{ path('admin_loyalty_tiers', _rp) }}';
const _tierUpdUrl  = (id) => `{{ path('admin_loyalty_tiers_update', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);
const _tierDelUrl  = (id) => `{{ path('admin_loyalty_tiers_delete', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);
const _reorderUrl  = '{{ path('admin_loyalty_tiers_reorder', _rp) }}';

const COLOR_PRESETS = ['#6366f1','#f59e0b','#10b981','#3b82f6','#ef4444','#8b5cf6','#ec4899','#14b8a6','#f97316','#a3a3a3'];

function tierFormHtml(t = {}) {
    const colorOpts = COLOR_PRESETS.map(c =>
        `<label class="relative cursor-pointer" title="${c}">
            <input type="radio" name="color" value="${c}" ${(t.color??'#6366f1')===c?'checked':''} class="sr-only">
            <span class="block w-6 h-6 rounded-full ring-2 ${(t.color??'#6366f1')===c?'ring-gray-900 ring-offset-2':'ring-transparent hover:ring-gray-400'}" style="background:${c};"></span>
         </label>`).join('');
    return `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Tier name *</label>
            <input id="t-name" type="text" value="${t.name??''}" placeholder="e.g. Bronze" maxlength="50"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Minimum points *</label>
            <input id="t-pts" type="number" value="${t.min_points??0}" min="0"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
            <p class="text-xs text-gray-400 mt-1">Customers are moved to this tier when their balance reaches this amount.</p>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">Colour</label>
            <div class="flex flex-wrap gap-2" id="color-swatches">${colorOpts}</div>
        </div>
        <div class="mb-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Perks description</label>
            <textarea id="t-perks" rows="3" placeholder="What does this tier get? (optional)"
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 resize-none">${t.perks_description??''}</textarea>
        </div>`;
}

function collectTierParams() {
    const p = new URLSearchParams();
    p.append('name',              document.getElementById('t-name').value);
    p.append('min_points',        document.getElementById('t-pts').value);
    p.append('color',             document.querySelector('#color-swatches input[name=color]:checked')?.value ?? '#6366f1');
    p.append('perks_description', document.getElementById('t-perks').value);
    return p;
}

function drawerFooter(onClick) {
    return `<button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
            <button data-primary onclick="${onClick}" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save</button>`;
}

async function submitTierForm(url, params) {
    const btn = document.querySelector('#admin-drawer-footer button[data-primary]');
    const err = document.getElementById('drawer-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
    try {
        const res  = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString() });
        const data = await res.json();
        if (data.success) { closeDrawer(); turboReload(); }
        else if (err) { err.textContent = data.message ?? 'An error occurred.'; err.classList.remove('hidden'); }
    } catch {
        if (err) { err.textContent = 'Network error.'; err.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Save'; }
    }
}

function openCreateTier() { openDrawer('Add Tier', tierFormHtml(), drawerFooter('submitCreateTier()')); }
function openEditTier(t)   { openDrawer('Edit Tier', tierFormHtml(t), drawerFooter(`submitEditTier(${t.id})`)); }
function submitCreateTier() { submitTierForm(_tiersUrl, collectTierParams()); }
function submitEditTier(id) { submitTierForm(_tierUpdUrl(id), collectTierParams()); }

function deleteTier(id, name, count) {
    if (count > 0) {
        adminModal('Cannot delete tier', `"${name}" has ${count} member(s). Move them to another tier first.`, 'error', [{ label:'OK', primary:false, fn:()=>{} }]);
        return;
    }
    adminDelete(_tierDelUrl(id), `Delete tier "${name}"? This cannot be undone.`, () => {
        document.getElementById(`tier-row-${id}`)?.remove();
    });
}

// ── Drag-to-reorder ──────────────────────────────────────────────────────────
{% if can.manage and tiers|length > 1 %}
(function () {
    const tbody = document.getElementById('tiers-body');
    const btn   = document.getElementById('reorder-btn');
    if (!tbody) return;
    let dragging = null;
    tbody.querySelectorAll('tr').forEach(row => {
        row.addEventListener('dragstart', e => { dragging = row; row.style.opacity = '0.5'; });
        row.addEventListener('dragend',   e => { dragging = null; row.style.opacity = ''; });
        row.addEventListener('dragover',  e => { e.preventDefault(); const after = getDragAfterEl(tbody, e.clientY); after ? tbody.insertBefore(dragging, after) : tbody.appendChild(dragging); btn.classList.remove('hidden'); });
        row.setAttribute('draggable', 'true');
    });
    function getDragAfterEl(container, y) {
        return [...container.querySelectorAll('tr:not([style*="opacity"])')].reduce((closest, child) => {
            const box = child.getBoundingClientRect();
            const offset = y - box.top - box.height / 2;
            return offset < 0 && offset > closest.offset ? { offset, el: child } : closest;
        }, { offset: Number.NEGATIVE_INFINITY }).el;
    }
})();

async function saveOrder() {
    const ids = [...document.querySelectorAll('#tiers-body tr')].map(r => r.dataset.tierId);
    const p   = new URLSearchParams();
    ids.forEach(id => p.append('ids[]', id));
    const res  = await fetch(_reorderUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: p.toString() });
    const data = await res.json();
    if (data.success) { document.getElementById('reorder-btn').classList.add('hidden'); }
    else { alert(data.message ?? 'Failed to save order.'); }
}
{% endif %}
</script>
{% endblock %}
