{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}
{% set ledger_pages = ledger_per_page > 0 and ledger_total > 0 ? ((ledger_total / ledger_per_page)|round(0, 'ceil')) : 1 %}

{% block admin_title %}{{ account.first_name ?? 'Member Profile' }}{% endblock %}
{% block admin_subtitle %}Loyalty account · {{ account.program_name }}{% endblock %}

{% block admin_actions %}
<div class="flex items-center gap-2">
    <a href="{{ path('admin_loyalty_members', _rp) }}"
       class="h-9 px-4 border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
        ← Members
    </a>
    {% if can.adjust %}
    <button onclick="openAdjustDrawer()"
            class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
        Adjust Points
    </button>
    {% endif %}
</div>
{% endblock %}

{% block admin_content %}

{# ── Member header ───────────────────────────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-200 p-6 mb-5">
    <div class="flex flex-wrap items-start gap-5">

        {# Avatar #}
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-2xl font-bold flex-shrink-0"
             style="background:{{ account.tier_color ?? '#e0e7ff' }}33;color:{{ account.tier_color ?? '#4f46e5' }};">
            {{ account.first_name|default('?')|first|upper }}
        </div>

        {# Name + meta #}
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 flex-wrap">
                <h2 class="text-lg font-bold text-gray-900">{{ account.first_name ?? 'Unknown Customer' }}</h2>
                {% if account.tier_name %}
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full"
                      style="background:{{ account.tier_color ?? '#e0e7ff' }}33;color:{{ account.tier_color ?? '#4f46e5' }};">
                    <span class="w-2 h-2 rounded-full" style="background:{{ account.tier_color ?? '#4f46e5' }};"></span>
                    {{ account.tier_name }}
                </span>
                {% endif %}
            </div>
            <p class="text-sm text-gray-500 mt-0.5 font-mono">
                {% if can.view_full_phone %}
                    {{ account.phone ?? account.msisdn }}
                {% else %}
                    {{ (account.msisdn|slice(0,5)) ~ '••••' ~ (account.msisdn|slice(-3)) }}
                {% endif %}
            </p>
            <p class="text-xs text-gray-400 mt-1">
                Member since {{ account.enrolled_at ? account.enrolled_at|date('d M Y') : '—' }}
            </p>
        </div>

        {# Point stats #}
        <div class="flex gap-6 flex-wrap">
            <div class="text-center">
                <p class="text-2xl font-bold text-gray-900">{{ account.points_balance|number_format(0) }}</p>
                <p class="text-xs text-gray-400 mt-0.5">Balance</p>
            </div>
            <div class="text-center">
                <p class="text-xl font-bold text-emerald-600">{{ account.total_points_earned|number_format(0) }}</p>
                <p class="text-xs text-gray-400 mt-0.5">Total earned</p>
            </div>
            <div class="text-center">
                <p class="text-xl font-bold text-amber-500">{{ account.total_points_redeemed|number_format(0) }}</p>
                <p class="text-xs text-gray-400 mt-0.5">Total redeemed</p>
            </div>
            {% if account.redemption_enabled and account.kes_per_point %}
            <div class="text-center">
                <p class="text-xl font-bold text-gray-700">KES {{ (account.points_balance * account.kes_per_point)|number_format(0) }}</p>
                <p class="text-xs text-gray-400 mt-0.5">Redeemable value</p>
            </div>
            {% endif %}
        </div>

    </div>

    {# Tier progress bar #}
    {% if account.next_tier_name and account.next_tier_min_points %}
    {% set _raw_pct = account.next_tier_min_points > 0 ? (account.points_balance / account.next_tier_min_points * 100)|round : 100 %}
    {% set progress = _raw_pct > 100 ? 100 : _raw_pct %}
    <div class="mt-5 pt-5 border-t border-gray-100">
        <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-semibold text-gray-500">Progress to {{ account.next_tier_name }}</span>
            <span class="text-xs text-gray-400">{{ account.points_balance|number_format(0) }} / {{ account.next_tier_min_points|number_format(0) }} {{ account.points_symbol ?? 'pts' }}</span>
        </div>
        <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
            <div class="h-2.5 rounded-full transition-all duration-500"
                 style="width:{{ progress }}%;background:{{ account.tier_color ?? '#4f46e5' }};"></div>
        </div>
    </div>
    {% endif %}
</div>

{# ── Ledger ──────────────────────────────────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <h3 class="text-sm font-semibold text-gray-900">Transaction History</h3>
        <div class="flex items-center gap-3">
            <span class="text-xs text-gray-400">{{ ledger_total|number_format }} entr{{ ledger_total != 1 ? 'ies' : 'y' }}</span>
            {% if ledger_pages > 1 %}
            <span class="text-xs text-gray-400">Page {{ ledger_page }} of {{ ledger_pages }}</span>
            {% endif %}
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Date</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Type</th>
                    <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Points</th>
                    <th class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Balance after</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Note / source</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden lg:table-cell">Cashier</th>
                </tr>
            </thead>
            <tbody>
            {% for entry in ledger %}
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap">
                    {{ entry.created_at|date('d M Y') }}<br>
                    <span class="text-gray-400">{{ entry.created_at|date('H:i') }}</span>
                </td>
                <td class="px-4 py-3">
                    {% set type_classes = {
                        'earn':         'bg-emerald-50 text-emerald-700',
                        'redeem':       'bg-amber-50 text-amber-700',
                        'adjust':       'bg-blue-50 text-blue-700',
                        'enroll_bonus': 'bg-purple-50 text-purple-700',
                        'expire':       'bg-red-50 text-red-500',
                    } %}
                    <span class="text-xs font-semibold px-2 py-0.5 rounded {{ type_classes[entry.type] ?? 'bg-gray-100 text-gray-600' }}">
                        {{ entry.type|replace({'_': ' '})|capitalize }}
                    </span>
                </td>
                <td class="px-4 py-3 text-right">
                    <span class="text-sm font-semibold {{ entry.points >= 0 ? 'text-emerald-600' : 'text-red-500' }}">
                        {{ entry.points >= 0 ? '+' : '' }}{{ entry.points|number_format(2) }}
                    </span>
                </td>
                <td class="px-4 py-3 text-right hidden sm:table-cell">
                    <span class="text-sm text-gray-600 font-mono">{{ entry.balance_after|number_format(0) }}</span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                    <span class="text-xs text-gray-500">
                        {% if entry.note %}{{ entry.note }}{% elseif entry.pos_transaction_id %}POS #{{ entry.pos_transaction_id }}{% else %}—{% endif %}
                    </span>
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                    <span class="text-xs text-gray-400">{{ entry.cashier_name ?? '—' }}</span>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="6" class="px-4 py-12 text-center text-sm text-gray-400">No transactions yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if ledger_pages > 1 %}
    <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-gray-100">
        {% for p in 1..ledger_pages %}
        <a href="?{{ app.request.query.all|merge({page: p})|url_encode }}"
           class="w-8 h-8 flex items-center justify-center rounded-lg text-sm transition-colors
                  {{ p == ledger_page ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' }}">
            {{ p }}
        </a>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}

{% block admin_scripts %}
<script>
const _adjustUrl = '{{ path('admin_loyalty_member_adjust', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: account.id}) }}';

function openAdjustDrawer() {
    const html = `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <p class="text-sm text-gray-500 mb-4">Current balance: <strong class="text-gray-900">{{ account.points_balance|number_format(0) }}</strong> {{ account.points_symbol ?? 'pts' }}</p>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">Action</label>
            <div class="flex gap-2">
                <label class="flex-1 cursor-pointer">
                    <input type="radio" name="direction" value="add" checked class="sr-only peer">
                    <span class="block text-center py-2 border rounded-lg text-sm font-medium transition-colors peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600 border-gray-200 text-gray-600 hover:bg-gray-50">Add</span>
                </label>
                <label class="flex-1 cursor-pointer">
                    <input type="radio" name="direction" value="deduct" class="sr-only peer">
                    <span class="block text-center py-2 border rounded-lg text-sm font-medium transition-colors peer-checked:bg-red-600 peer-checked:text-white peer-checked:border-red-600 border-gray-200 text-gray-600 hover:bg-gray-50">Deduct</span>
                </label>
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Amount *</label>
            <input id="adj-amount" type="number" min="0.01" step="0.01" placeholder="0"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        <div class="mb-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Reason *</label>
            <input id="adj-note" type="text" maxlength="255" placeholder="e.g. Correction, goodwill"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>`;
    const footer = `
        <button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        <button data-primary onclick="submitAdjust()" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Apply</button>`;
    openDrawer('Adjust Points', html, footer);
}

async function submitAdjust() {
    const btn = document.querySelector('#admin-drawer-footer button[data-primary]');
    const err = document.getElementById('drawer-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
    const p = new URLSearchParams();
    p.append('direction', document.querySelector('input[name=direction]:checked').value);
    p.append('amount',    document.getElementById('adj-amount').value);
    p.append('note',      document.getElementById('adj-note').value);
    try {
        const res  = await fetch(_adjustUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: p.toString() });
        const data = await res.json();
        if (data.success) { closeDrawer(); turboReload(); }
        else if (err) { err.textContent = data.message ?? 'Failed.'; err.classList.remove('hidden'); }
    } catch {
        if (err) { err.textContent = 'Network error.'; err.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Apply'; }
    }
}
</script>
{% endblock %}
