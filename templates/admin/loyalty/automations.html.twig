{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}

{% block admin_title %}Loyalty Automations{% endblock %}
{% block admin_subtitle %}Automated triggers that reach members at the right moment{% endblock %}

{% block admin_actions %}
<a href="{{ path('admin_loyalty_segments', _rp) }}"
   class="h-9 px-4 border border-gray-200 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-2">
    ← Segments
</a>
{% endblock %}

{% block admin_content %}

{% if not program %}
<div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-sm text-gray-400">No loyalty programme configured. <a href="{{ path('admin_settings_loyalty', _rp) }}" class="text-indigo-600 hover:underline">Set it up →</a></p>
</div>
{% else %}

{% for message in app.flashes('success') %}
<div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-lg flex items-center gap-2">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
    {{ message }}
</div>
{% endfor %}

<div class="mb-5 bg-indigo-50 border border-indigo-100 rounded-xl px-5 py-4 text-sm text-indigo-700">
    <strong>How automations work:</strong> When a trigger condition is met, Patronr queues an SMS to the member using the message template.
    Use <code class="bg-indigo-100 px-1 rounded">{first_name}</code>, <code class="bg-indigo-100 px-1 rounded">{tier_name}</code>,
    <code class="bg-indigo-100 px-1 rounded">{balance}</code>, and <code class="bg-indigo-100 px-1 rounded">{gap}</code> as variables.
    Outcomes are tracked on the Segments page.
</div>

<form method="post" action="{{ path('admin_loyalty_automations', _rp) }}">

{% set _triggers = [
    {
        type: 'win_back',
        label: 'Win-Back',
        icon: '<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>',
        description: 'Sent to members who haven\'t visited in a set number of days. Reminds them their points are waiting.',
        has_days: true,
        has_points: false,
        default_days: 60,
        default_tpl: 'Hi {first_name}, we miss you! You have {balance} points waiting at ' ~ program.program_name ~ '. Come in and earn more today.'
    },
    {
        type: 'almost_tier',
        label: 'Almost There (Tier Upgrade)',
        icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
        description: 'Nudges members who are within a configurable number of points of the next tier. Drives the final few visits.',
        has_days: false,
        has_points: true,
        default_points: 100,
        default_tpl: 'Hi {first_name}, you\'re only {gap} points away from {tier_name} status! Visit us soon to get there.'
    },
    {
        type: 'tier_upgrade',
        label: 'Tier Upgrade Congratulations',
        icon: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
        description: 'Sent automatically when a member\'s points balance pushes them into a higher tier. No threshold needed.',
        has_days: false,
        has_points: false,
        default_tpl: 'Congratulations {first_name}! You\'ve reached {tier_name} status on ' ~ program.program_name ~ '. Enjoy your new benefits!'
    },
    {
        type: 'expiry_warning',
        label: 'Points Expiry Warning',
        icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
        description: 'Warns members before their points expire due to inactivity. Only relevant when points expiry is enabled in settings.',
        has_days: true,
        has_points: false,
        default_days: 14,
        default_tpl: 'Hi {first_name}, your ' ~ program.program_name ~ ' points are about to expire! Visit us to keep your balance.'
    },
    {
        type: 'birthday_bonus',
        label: 'Birthday Bonus',
        icon: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
        description: 'Awards bonus points during a member\'s birth month (first transaction in that month). Requires birth month to be on file.',
        has_days: false,
        has_points: true,
        default_points: 50,
        default_tpl: 'Happy Birthday {first_name}! We\'ve added bonus points to your ' ~ program.program_name ~ ' account as our gift to you.'
    }
] %}

<div class="flex flex-col gap-4">
{% for trigger in _triggers %}
{% set _saved = automations[trigger.type] ?? null %}
{% set _active = _saved ? _saved.is_active : 0 %}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0">
                <svg width="16" height="16" fill="none" stroke="#6366f1" stroke-width="1.5" viewBox="0 0 24 24">{{ trigger.icon|raw }}</svg>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-gray-900">{{ trigger.label }}</h3>
                <p class="text-xs text-gray-400 mt-0.5 max-w-lg">{{ trigger.description }}</p>
            </div>
        </div>
        {# Toggle #}
        <label class="s-toggle flex-shrink-0">
            <input type="checkbox" name="automations[{{ trigger.type }}][is_active]" value="1" {{ _active ? 'checked' : '' }}>
            <span class="s-toggle-track"><span class="s-toggle-knob"></span></span>
        </label>
    </div>
    <div class="px-5 py-4 grid grid-cols-1 md:grid-cols-2 gap-4">

        {% if trigger.has_days %}
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">
                {% if trigger.type == 'win_back' %}Inactivity threshold (days){% else %}Days before expiry{% endif %}
            </label>
            <input type="number" name="automations[{{ trigger.type }}][threshold_days]"
                   value="{{ _saved.threshold_days ?? trigger.default_days }}"
                   min="1" max="365"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        {% else %}
        <input type="hidden" name="automations[{{ trigger.type }}][threshold_days]" value="">
        {% endif %}

        {% if trigger.has_points %}
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">
                {% if trigger.type == 'birthday_bonus' %}Bonus points to award{% else %}Points gap threshold{% endif %}
            </label>
            <input type="number" name="automations[{{ trigger.type }}][threshold_points]"
                   value="{{ _saved.threshold_points ?? trigger.default_points }}"
                   min="1" max="10000"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        {% else %}
        <input type="hidden" name="automations[{{ trigger.type }}][threshold_points]" value="">
        {% endif %}

        <div class="{{ (trigger.has_days or trigger.has_points) ? 'md:col-span-1' : 'md:col-span-2' }}">
            <label class="block text-xs font-medium text-gray-600 mb-1">Message template <span class="text-red-400">*</span></label>
            <textarea name="automations[{{ trigger.type }}][message_template]" rows="3" maxlength="320"
                      placeholder="Write your message..."
                      class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 resize-none">{{ _saved.message_template ?? trigger.default_tpl }}</textarea>
        </div>

    </div>
</div>
{% endfor %}
</div>

<div class="mt-5 flex justify-end">
    <button type="submit"
            class="h-10 px-6 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
        Save Automations
    </button>
</div>

</form>

{% endif %}
{% endblock %}

{% block admin_styles %}
<style>
.s-toggle { position:relative; display:inline-flex; align-items:center; cursor:pointer; }
.s-toggle input { position:absolute; opacity:0; width:0; height:0; pointer-events:none; }
.s-toggle-track { display:block; width:40px; height:22px; border-radius:100px; background:#e5e7eb; transition:background .18s ease; position:relative; }
.s-toggle-knob { position:absolute; top:3px; left:3px; width:16px; height:16px; border-radius:50%; background:#fff; box-shadow:0 1px 3px rgba(0,0,0,.18); transition:transform .18s ease; }
.s-toggle input:checked ~ .s-toggle-track { background:#4f46e5; }
.s-toggle input:checked ~ .s-toggle-track .s-toggle-knob { transform:translateX(18px); }
</style>
{% endblock %}
