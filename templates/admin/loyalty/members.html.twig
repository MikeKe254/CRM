{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% set _rp = {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch} %}
{% set pages = per_page > 0 and total > 0 ? ((total / per_page)|round(0, 'ceil')) : 1 %}

{% block admin_title %}Loyalty Members{% endblock %}
{% block admin_subtitle %}{{ total|number_format }} enrolled customer{{ total != 1 ? 's' : '' }}{% endblock %}

{% block admin_actions %}
<div class="flex items-center gap-2">
    {% if can.export %}
    <a href="{{ path('admin_loyalty_members_export', _rp) }}?{{ app.request.query.all|url_encode }}"
       class="h-9 px-3 border border-gray-200 bg-white hover:bg-gray-50 text-gray-600 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Export CSV
    </a>
    {% endif %}
    {% if can.enroll %}
    <button onclick="openEnrollDrawer()"
            class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
        + Enroll Member
    </button>
    {% endif %}
</div>
{% endblock %}

{% block admin_content %}

{# ── Filters ─────────────────────────────────────────────────────────── #}
<form method="GET" class="bg-white rounded-xl border border-gray-200 p-4 mb-4">
    <div class="flex flex-wrap items-end gap-3">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="q" value="{{ search }}" placeholder="Search name or phone…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 w-56">
        </div>
        {% if tiers|length > 0 %}
        <div>
            <select name="tier" class="h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="">All tiers</option>
                {% for t in tiers %}
                <option value="{{ t.id }}" {{ tier_id == t.id ? 'selected' : '' }}>{{ t.name }}</option>
                {% endfor %}
            </select>
        </div>
        {% endif %}
        <button type="submit"
                class="h-9 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
            Filter
        </button>
        {% if search or tier_id %}
        <a href="{{ path('admin_loyalty_members', _rp) }}"
           class="h-9 px-4 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center">
            Clear
        </a>
        {% endif %}
    </div>
</form>

{# ── Members table ───────────────────────────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <span class="text-xs text-gray-400">{{ total|number_format }} member{{ total != 1 ? 's' : '' }}</span>
        {% if pages > 1 %}
        <span class="text-xs text-gray-400">Page {{ page }} of {{ pages }}</span>
        {% endif %}
    </div>

    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Member</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Phone</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Tier</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Balance</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Status</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden lg:table-cell">Enrolled</th>
                    <th class="px-4 py-3 w-28"></th>
                </tr>
            </thead>
            <tbody>
            {% for m in members %}
            <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3">
                    <div class="flex items-center gap-2.5">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0
                                    {{ m.tier_color ? '' : 'bg-indigo-50 text-indigo-600' }}"
                             style="{{ m.tier_color ? 'background:' ~ m.tier_color ~ '22;color:' ~ m.tier_color ~ ';' : '' }}">
                            {{ m.first_name|default('?')|first|upper }}
                        </div>
                        <span class="text-sm font-medium text-gray-900">{{ m.first_name ?? 'Unknown' }}</span>
                    </div>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                    <span class="text-sm text-gray-500 font-mono">
                        {% if can.view_full_phone %}
                            {{ m.phone ?? m.msisdn }}
                        {% else %}
                            {{ (m.msisdn|slice(0,5)) ~ '••••' ~ (m.msisdn|slice(-3)) }}
                        {% endif %}
                    </span>
                </td>
                <td class="px-4 py-3">
                    {% if m.tier_name %}
                    <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full"
                          style="background:{{ m.tier_color ?? '#e0e7ff' }}22;color:{{ m.tier_color ?? '#4f46e5' }};">
                        <span class="w-1.5 h-1.5 rounded-full" style="background:{{ m.tier_color ?? '#4f46e5' }};"></span>
                        {{ m.tier_name }}
                    </span>
                    {% else %}
                    <span class="text-xs text-gray-300">—</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3">
                    <span class="text-sm font-semibold text-gray-900">{{ m.points_balance|number_format(0) }}</span>
                    <span class="text-xs text-gray-400 ml-0.5">{{ program.points_symbol ?? 'pts' }}</span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                    {% set _stage = m.lifecycle_stage ?? 'new' %}
                    {% if _stage == 'active' %}
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Active</span>
                    {% elseif _stage == 'new' %}
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-indigo-700 bg-indigo-50 px-2 py-0.5 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>New</span>
                    {% elseif _stage == 'at_risk' %}
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-50 px-2 py-0.5 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>At-Risk</span>
                    {% elseif _stage == 'lapsing' %}
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-orange-700 bg-orange-50 px-2 py-0.5 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>Lapsing</span>
                    {% else %}
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full"><span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Churned</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                    <span class="text-xs text-gray-400">{{ m.enrolled_at ? m.enrolled_at|date('d M Y') : '—' }}</span>
                </td>
                <td class="px-4 py-3">
                    <div class="flex items-center gap-1">
                        {% if can.view_detail %}
                        <a href="{{ path('admin_loyalty_member_profile', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: m.account_id}) }}"
                           class="text-xs text-gray-600 border border-gray-200 bg-white hover:bg-gray-50 px-2.5 py-1 rounded transition-colors">View</a>
                        {% endif %}
                        {% if can.adjust %}
                        <button onclick="openAdjustDrawer({{ m.account_id }}, '{{ m.first_name|default('member')|e('js') }}')"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Adjust</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="px-4 py-16 text-center">
                    <p class="text-sm text-gray-400 mb-3">
                        {% if search or tier_id %}No members match your filters.
                        {% else %}No members enrolled yet.{% endif %}
                    </p>
                    {% if can.enroll and not search and not tier_id %}
                    <button onclick="openEnrollDrawer()"
                            class="h-8 px-4 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold rounded-lg transition-colors">
                        Enroll first member
                    </button>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pages > 1 %}
    <div class="flex items-center justify-center gap-1 px-4 py-3 border-t border-gray-100">
        {% for p in 1..pages %}
        <a href="?{{ app.request.query.all|merge({page: p})|url_encode }}"
           class="w-8 h-8 flex items-center justify-center rounded-lg text-sm transition-colors
                  {{ p == page ? 'bg-indigo-600 text-white font-semibold' : 'text-gray-600 hover:bg-gray-100' }}">
            {{ p }}
        </a>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}

{% block admin_scripts %}
<script>
const _enrollUrl = '{{ path('admin_loyalty_member_enroll', _rp) }}';
const _adjustUrl = (id) => `{{ path('admin_loyalty_member_adjust', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch, id: 9999999}) }}`.replace('9999999', id);

function openEnrollDrawer() {
    const html = `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone number *</label>
            <input id="e-phone" type="tel" placeholder="+254712345678"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        <div class="mb-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">First name <span class="text-gray-400 font-normal">(optional)</span></label>
            <input id="e-name" type="text" placeholder="e.g. Jane"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>`;
    const footer = `
        <button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        <button data-primary onclick="submitEnroll()" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Enroll</button>`;
    openDrawer('Enroll Member', html, footer);
}

async function submitEnroll() {
    const btn = document.querySelector('#admin-drawer-footer button[data-primary]');
    const err = document.getElementById('drawer-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Enrolling…'; }
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
    const p = new URLSearchParams();
    p.append('phone',      document.getElementById('e-phone').value);
    p.append('first_name', document.getElementById('e-name').value);
    try {
        const res  = await fetch(_enrollUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: p.toString() });
        const data = await res.json();
        if (data.success) { closeDrawer(); turboReload(); }
        else if (err) { err.textContent = data.message ?? 'Enrollment failed.'; err.classList.remove('hidden'); }
    } catch {
        if (err) { err.textContent = 'Network error.'; err.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Enroll'; }
    }
}

function openAdjustDrawer(accountId, name) {
    const html = `
        <div id="drawer-error" class="hidden mb-3 px-3 py-2 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg"></div>
        <p class="text-sm text-gray-500 mb-4">Manually add or deduct points for <strong>${name}</strong>.</p>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">Action</label>
            <div class="flex gap-2">
                <label class="flex-1 cursor-pointer">
                    <input type="radio" name="direction" value="add" checked class="sr-only peer">
                    <span class="block text-center py-2 border rounded-lg text-sm font-medium transition-colors peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600 border-gray-200 text-gray-600 hover:bg-gray-50">Add points</span>
                </label>
                <label class="flex-1 cursor-pointer">
                    <input type="radio" name="direction" value="deduct" class="sr-only peer">
                    <span class="block text-center py-2 border rounded-lg text-sm font-medium transition-colors peer-checked:bg-red-600 peer-checked:text-white peer-checked:border-red-600 border-gray-200 text-gray-600 hover:bg-gray-50">Deduct points</span>
                </label>
            </div>
        </div>
        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Amount *</label>
            <input id="adj-amount" type="number" min="0.01" step="0.01" placeholder="0"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>
        <div class="mb-1">
            <label class="block text-sm font-medium text-gray-700 mb-1">Reason / note *</label>
            <input id="adj-note" type="text" maxlength="255" placeholder="e.g. Correction, goodwill adjustment"
                   class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300">
        </div>`;
    const footer = `
        <button onclick="closeDrawer()" class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        <button data-primary onclick="submitAdjust(${accountId})" class="flex-1 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Apply</button>`;
    openDrawer('Adjust Points', html, footer);
}

async function submitAdjust(accountId) {
    const btn = document.querySelector('#admin-drawer-footer button[data-primary]');
    const err = document.getElementById('drawer-error');
    if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }
    if (err) { err.textContent = ''; err.classList.add('hidden'); }
    const p = new URLSearchParams();
    p.append('direction', document.querySelector('input[name=direction]:checked').value);
    p.append('amount',    document.getElementById('adj-amount').value);
    p.append('note',      document.getElementById('adj-note').value);
    try {
        const res  = await fetch(_adjustUrl(accountId), { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: p.toString() });
        const data = await res.json();
        if (data.success) { closeDrawer(); turboReload(); }
        else if (err) { err.textContent = data.message ?? 'Adjustment failed.'; err.classList.remove('hidden'); }
    } catch {
        if (err) { err.textContent = 'Network error.'; err.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Apply'; }
    }
}
</script>
{% endblock %}
