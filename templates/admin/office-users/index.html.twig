// Delete button
document.querySelectorAll('.delete-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    if (!confirm('Delete this user?')) return;
    const userId = btn.dataset.userId;
    // TODO: Call delete endpoint
  });
