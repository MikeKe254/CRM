{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% block admin_title %}Areas{% endblock %}
{% block admin_subtitle %}Where your staff work — group people by physical location{% endblock %}

{% block admin_actions %}
<a href="?inactive={{ showInactive ? '0' : '1' }}"
   class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
    {{ showInactive ? 'Hide inactive' : 'Show inactive' }}
</a>
{% if can.create %}
<button onclick="openCreate()"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Area
</button>
{% endif %}
{% endblock %}

{% block admin_content %}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="area-search" type="text" placeholder="Search areas…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
        <span class="ml-auto text-xs text-gray-400">{{ areas|length }} area{{ areas|length != 1 ? 's' : '' }}</span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full min-w-0" id="area-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Area</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Staff</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden md:table-cell">Transactional</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Status</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody>
            {% for area in areas %}
            <tr id="area-row-{{ area.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors {{ area.status == 'inactive' ? 'opacity-60' : '' }}">
                <td class="px-4 py-3 min-w-0">
                    <div class="flex items-start gap-2.5">
                        <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg width="14" height="14" fill="none" stroke="#0d9488" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        </div>
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-1.5">
                                <span class="text-sm font-medium text-gray-900">{{ area.name }}</span>
                                {% if area.is_system %}
                                    <span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded font-semibold">System</span>
                                {% endif %}
                                <span class="sm:hidden text-xs {% if area.status == 'active' %}bg-emerald-50 text-emerald-700{% else %}bg-gray-100 text-gray-500{% endif %} px-1.5 py-0.5 rounded font-semibold">
                                    {{ area.status|capitalize }}
                                </span>
                            </div>
                            {% if area.description %}
                            <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{{ area.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell whitespace-nowrap">
                    <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded font-semibold">
                        {{ area.user_count }} staff
                    </span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell whitespace-nowrap">
                    {% if area.is_transactional %}
                        <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded font-semibold">Yes</span>
                    {% else %}
                        <span class="text-xs text-gray-400">—</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 hidden sm:table-cell whitespace-nowrap">
                    {% if area.status == 'active' %}
                        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded font-semibold">Active</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded font-semibold">Inactive</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                    <div class="flex items-center justify-end gap-1">
                        {% if can.edit %}
                        <button onclick="openEdit({{ area|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        <button onclick="toggleStatus({{ area.id }}, '{{ area.status }}', '{{ area.name|e('js') }}')"
                                class="text-xs {{ area.status == 'active' ? 'text-amber-600 border-amber-200 hover:bg-amber-50' : 'text-emerald-600 border-emerald-200 hover:bg-emerald-50' }} border bg-white px-2.5 py-1 rounded transition-colors hidden sm:inline-flex">
                            {{ area.status == 'active' ? 'Deactivate' : 'Activate' }}
                        </button>
                        {% endif %}
                        {% if can.delete and not area.is_system %}
                        <button onclick="deleteArea({{ area.id }}, '{{ area.name|e('js') }}')"
                                class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">No areas found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Create Modal ────────────────────────────────────────── #}
<div id="create-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-sm font-semibold text-gray-900">Add Area</h3>
            <button onclick="closeCreate()" class="text-gray-400 hover:text-gray-600">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form id="create-form" onsubmit="submitCreate(event)" class="px-6 py-5 space-y-4">
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
                <input id="create-name" type="text" maxlength="120" required
                       placeholder="e.g. Kitchen Area, Bar Area, Poolside / Deck"
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Description <span class="text-gray-400 font-normal">(optional)</span></label>
                <textarea id="create-description" rows="2" maxlength="255"
                          placeholder="Brief description of this area"
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm resize-none focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400"></textarea>
            </div>
            <div>
                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg bg-gray-50 hover:border-indigo-300 hover:bg-white cursor-pointer transition-colors">
                    <input id="create-transactional" type="checkbox" class="w-4 h-4 accent-indigo-600">
                    <div>
                        <div class="text-sm font-medium text-gray-800">Transactional area</div>
                        <div class="text-xs text-gray-400">Customers make payments in this area</div>
                    </div>
                </label>
            </div>
            <div id="create-error" class="hidden text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
            <div class="flex justify-end gap-2 pt-1">
                <button type="button" onclick="closeCreate()"
                        class="px-4 h-9 border border-gray-200 text-sm text-gray-600 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
                <button type="submit" id="create-submit"
                        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
                    Create Area
                </button>
            </div>
        </form>
    </div>
</div>

{# ── Edit Modal ──────────────────────────────────────────── #}
<div id="edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-sm font-semibold text-gray-900">Edit Area</h3>
            <button onclick="closeEdit()" class="text-gray-400 hover:text-gray-600">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form id="edit-form" onsubmit="submitEdit(event)" class="px-6 py-5 space-y-4">
            <input type="hidden" id="edit-id">
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
                <input id="edit-name" type="text" maxlength="120" required
                       class="w-full h-9 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Description <span class="text-gray-400 font-normal">(optional)</span></label>
                <textarea id="edit-description" rows="2" maxlength="255"
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm resize-none focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400"></textarea>
            </div>
            <div>
                <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg bg-gray-50 hover:border-indigo-300 hover:bg-white cursor-pointer transition-colors">
                    <input id="edit-transactional" type="checkbox" class="w-4 h-4 accent-indigo-600">
                    <div>
                        <div class="text-sm font-medium text-gray-800">Transactional area</div>
                        <div class="text-xs text-gray-400">Customers make payments in this area</div>
                    </div>
                </label>
            </div>
            <div id="edit-error" class="hidden text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
            <div class="flex justify-end gap-2 pt-1">
                <button type="button" onclick="closeEdit()"
                        class="px-4 h-9 border border-gray-200 text-sm text-gray-600 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
                <button type="submit" id="edit-submit"
                        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block admin_scripts %}
<script>
const BASE = '{{ path('admin_areas', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}';

// ── Search ───────────────────────────────────────────────
document.getElementById('area-search')?.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#area-table tbody tr[id]').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});

// ── Create ───────────────────────────────────────────────
function openCreate() {
    document.getElementById('create-name').value = '';
    document.getElementById('create-description').value = '';
    document.getElementById('create-transactional').checked = false;
    document.getElementById('create-error').classList.add('hidden');
    document.getElementById('create-modal').classList.remove('hidden');
    document.getElementById('create-modal').classList.add('flex');
    document.getElementById('create-name').focus();
}
function closeCreate() {
    document.getElementById('create-modal').classList.add('hidden');
    document.getElementById('create-modal').classList.remove('flex');
}
async function submitCreate(e) {
    e.preventDefault();
    const btn = document.getElementById('create-submit');
    const err = document.getElementById('create-error');
    btn.disabled = true; btn.textContent = 'Creating…';
    err.classList.add('hidden');

    const body = new FormData();
    body.append('name', document.getElementById('create-name').value);
    body.append('description', document.getElementById('create-description').value);
    body.append('is_transactional', document.getElementById('create-transactional').checked ? 1 : 0);

    const res = await fetch(BASE + '/create', { method: 'POST', body });
    const data = await res.json();

    if (data.success) {
        closeCreate();
        turboReload();
    } else {
        err.textContent = data.message;
        err.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Create Area';
    }
}

// ── Edit ─────────────────────────────────────────────────
function openEdit(area) {
    document.getElementById('edit-id').value = area.id;
    document.getElementById('edit-name').value = area.name;
    document.getElementById('edit-description').value = area.description ?? '';
    document.getElementById('edit-transactional').checked = !!parseInt(area.is_transactional);
    document.getElementById('edit-error').classList.add('hidden');
    document.getElementById('edit-modal').classList.remove('hidden');
    document.getElementById('edit-modal').classList.add('flex');
    document.getElementById('edit-name').focus();
}
function closeEdit() {
    document.getElementById('edit-modal').classList.add('hidden');
    document.getElementById('edit-modal').classList.remove('flex');
}
async function submitEdit(e) {
    e.preventDefault();
    const id  = document.getElementById('edit-id').value;
    const btn = document.getElementById('edit-submit');
    const err = document.getElementById('edit-error');
    btn.disabled = true; btn.textContent = 'Saving…';
    err.classList.add('hidden');

    const body = new FormData();
    body.append('name', document.getElementById('edit-name').value);
    body.append('description', document.getElementById('edit-description').value);
    body.append('is_transactional', document.getElementById('edit-transactional').checked ? 1 : 0);

    const res = await fetch(`${BASE}/${id}/update`, { method: 'POST', body });
    const data = await res.json();

    if (data.success) {
        closeEdit();
        turboReload();
    } else {
        err.textContent = data.message;
        err.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Save Changes';
    }
}

// ── Toggle Status ────────────────────────────────────────
function toggleStatus(id, currentStatus, name) {
    const label = currentStatus === 'active' ? 'Deactivate' : 'Activate';
    adminConfirm({
        title: label + ' area',
        message: label + ' "' + name + '"?',
        confirmText: label,
        danger: currentStatus === 'active',
        onConfirm: async () => {
            const res  = await fetch(`${BASE}/${id}/toggle-status`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                turboReload();
            } else {
                adminAlert({ title: 'Could not update status', message: data.message, type: 'error' });
            }
        },
    });
}

// ── Delete ───────────────────────────────────────────────
function deleteArea(id, name) {
    adminConfirm({
        title: 'Delete area',
        message: 'Delete "' + name + '"? Staff currently assigned to this area will be unassigned.',
        confirmText: 'Delete',
        danger: true,
        onConfirm: async () => {
            const res  = await fetch(`${BASE}/${id}/delete`, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                document.getElementById(`area-row-${id}`)?.remove();
            } else {
                adminAlert({ title: 'Could not delete area', message: data.message, type: 'error' });
            }
        },
    });
}

// Close modals on backdrop click
['create-modal', 'edit-modal'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', function (e) {
        if (e.target === this) { this.classList.add('hidden'); this.classList.remove('flex'); }
    });
});
</script>
{% endblock %}
