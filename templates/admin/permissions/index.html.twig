{% extends 'layouts/admin.html.twig' %}
{% block admin_title %}Permissions{% endblock %}
{% block admin_subtitle %}All available system permissions grouped by category{% endblock %}

{% block admin_content %}

<div class="flex flex-wrap items-center gap-2 mb-4">
    <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="perm-search" type="text" placeholder="Search permissions…"
               class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
    </div>
    <button data-cat="" onclick="filterByCategory(this)"
            class="cat-btn h-8 px-3 border border-indigo-300 bg-indigo-50 text-indigo-700 text-xs font-medium rounded-lg transition-colors">
        All
    </button>
    {% for cat in categories %}
    <button data-cat="{{ cat }}" onclick="filterByCategory(this)"
            class="cat-btn h-8 px-3 border border-gray-200 bg-white text-gray-600 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700 text-xs font-medium rounded-lg transition-colors">
        {{ cat }}
    </button>
    {% endfor %}
</div>

<div id="perm-sections">
{% for category, perms in grouped %}
<div class="perm-section bg-white rounded-xl border border-gray-200 overflow-hidden mb-4" data-category="{{ category }}">
    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
        <span class="text-sm font-semibold text-gray-900">{{ category }}</span>
        <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded font-semibold">{{ perms|length }}</span>
    </div>
    <div class="divide-y divide-gray-50">
    {% for p in perms %}
    <div class="perm-row px-5 py-3.5 hover:bg-gray-50 transition-colors">
        <div class="text-sm font-medium text-gray-900">{{ p.name }}</div>
        {% if p.description is defined and p.description %}
        <div class="text-xs text-gray-400 mt-0.5">{{ p.description }}</div>
        {% endif %}
    </div>
    {% endfor %}
    </div>
</div>
{% endfor %}
</div>

{% endblock %}

{% block admin_scripts %}
<script>
document.getElementById('perm-search').oninput = function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.perm-row').forEach(r => r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none');
    document.querySelectorAll('.perm-section').forEach(s => {
        s.style.display = [...s.querySelectorAll('.perm-row')].some(r => r.style.display !== 'none') ? '' : 'none';
    });
};

function filterByCategory(btn) {
    const cat = btn.dataset.cat;
    document.querySelectorAll('.perm-section').forEach(s => {
        s.style.display = (!cat || s.dataset.category === cat) ? '' : 'none';
    });
    document.querySelectorAll('.cat-btn').forEach(b => {
        const active = b === btn;
        b.className = `cat-btn h-8 px-3 border text-xs font-medium rounded-lg transition-colors ${
            active ? 'border-indigo-300 bg-indigo-50 text-indigo-700' : 'border-gray-200 bg-white text-gray-600 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700'
        }`;
    });
}
</script>
{% endblock %}
