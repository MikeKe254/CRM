{% extends 'layouts/admin.html.twig' %}
{% block admin_title %}POS Terminals{% endblock %}
{% block admin_subtitle %}View and manage authorized POS devices{% endblock %}

{% block admin_actions %}
<a href="{{ path('mpesa_login_page') }}"
   class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors inline-flex items-center">
    + Authorize Terminal
</a>
{% endblock %}

{% block admin_content %}

{% set active_count = 0 %}{% set revoked_count = 0 %}
{% for t in terminals %}
    {% if t.revoked_at is not null %}{% set revoked_count = revoked_count + 1 %}
    {% else %}{% set active_count = active_count + 1 %}{% endif %}
{% endfor %}

<div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-xs text-gray-400 mb-1">Active</div>
        <div class="text-2xl font-semibold text-gray-900">{{ active_count }}</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-xs text-gray-400 mb-1">Total Authorized</div>
        <div class="text-2xl font-semibold text-gray-900">{{ terminals|length }}</div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="text-xs text-gray-400 mb-1">Revoked</div>
        <div class="text-2xl font-semibold text-gray-900">{{ revoked_count }}</div>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="terminal-search" type="text" placeholder="Search terminals…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full" id="terminals-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Device</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Terminal ID</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Authorized By</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Authorized</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Expires</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Status</th>
                    <th class="px-4 py-3 w-28"></th>
                </tr>
            </thead>
            <tbody>
            {% for t in terminals %}
            {% set isRevoked = t.revoked_at is not null %}
            <tr id="terminal-row-{{ t.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors last:border-0">
                <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                            <svg width="14" height="14" fill="none" stroke="#6b7280" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        </div>
                        <span class="text-sm font-medium text-gray-900">{{ t.device_name }}</span>
                    </div>
                </td>
                <td class="px-4 py-3">
                    <code class="text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded font-mono">{{ t.terminal_identifier }}</code>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">{{ t.authorized_by }}</td>
                <td class="px-4 py-3 text-xs text-gray-500">{{ t.authorized_at|date('d M Y, H:i') }}</td>
                <td class="px-4 py-3 text-xs text-gray-500">{{ t.expires_at ? t.expires_at|date('d M Y') : '—' }}</td>
                <td class="px-4 py-3">
                    {% if isRevoked %}
                        <span class="text-xs bg-red-50 text-red-700 px-2 py-0.5 rounded font-semibold">Revoked</span>
                    {% else %}
                        <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded font-semibold">Active</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3">
                    {% if not isRevoked %}
                    <button onclick="revokeTerminal({{ t.id }}, '{{ t.device_name|e('js') }}')"
                            class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Revoke</button>
                    {% else %}
                    <button onclick="reactivateTerminal({{ t.id }}, '{{ t.device_name|e('js') }}')"
                            class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Reactivate</button>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr><td colspan="7" class="px-4 py-12 text-center text-sm text-gray-400">No terminals authorized yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block admin_scripts %}
<script>
liveFilter('terminal-search', 'terminals-table');

function revokeTerminal(id, name) {
    adminDelete(
        `/dashboard/admin/terminals/${id}/revoke`,
        `Revoke "${name}"? Staff will no longer be able to PIN login on this device.`,
        () => turboReload()
    );
}

function reactivateTerminal(id, name) {
    if (!confirm(`Reactivate "${name}" for 30 days?`)) return;
    fetch(`/dashboard/admin/terminals/${id}/reactivate`, { method: 'POST' })
        .then(r => r.json())
        .then(d => { if (d.success) turboReload(); else alert(d.message); });
}
</script>
{% endblock %}
