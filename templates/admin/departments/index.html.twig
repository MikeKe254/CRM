{% extends 'layouts/admin.html.twig' %}
{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = (session.branch is defined and session.branch) ? session.branch.slug : app.request.attributes.get('branch') %}
{% block admin_title %}Departments{% endblock %}
{% block admin_subtitle %}What your staff do — group people by function{% endblock %}

{% block admin_actions %}
<a href="?inactive={{ showInactive ? '0' : '1' }}"
   class="px-4 h-9 border border-gray-200 text-gray-600 hover:bg-gray-50 text-sm font-medium rounded-lg transition-colors inline-flex items-center gap-1.5">
    {{ showInactive ? 'Hide inactive' : 'Show inactive' }}
</a>
{% if can.create %}
<button onclick="openCreate()"
        class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">
    + Add Department
</button>
{% endif %}
{% endblock %}

{% block admin_content %}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden"
     data-depts-base="{{ path('admin_departments', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}">

    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-100">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="dept-search" type="text" placeholder="Search departments…"
                   class="h-9 pl-8 pr-3 border border-gray-300 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 w-56">
        </div>
        <span class="ml-auto text-xs text-gray-400">{{ departments|length }} department{{ departments|length != 1 ? 's' : '' }}</span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full" id="dept-table">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3">Department</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Staff</th>
                    <th class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 hidden sm:table-cell">Status</th>
                    <th class="px-4 py-3 w-32 text-right"></th>
                </tr>
            </thead>
            <tbody>
            {% for dept in departments %}
            <tr id="dept-row-{{ dept.id }}" class="border-b border-gray-50 hover:bg-gray-50 transition-colors {{ dept.status == 'inactive' ? 'opacity-60' : '' }}">
                <td class="px-4 py-3">
                    <div class="flex items-start gap-2">
                        <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg width="14" height="14" fill="none" stroke="#7c3aed" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </div>
                        <div class="min-w-0">
                            <div class="flex items-center gap-1.5 flex-wrap">
                                <span class="text-sm font-medium text-gray-900">{{ dept.name }}</span>
                                {% if dept.is_system %}
                                    <span class="text-xs bg-amber-50 text-amber-700 px-1.5 py-0.5 rounded font-semibold">System</span>
                                {% endif %}
                                <span class="sm:hidden text-xs {{ dept.status == 'active' ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-500' }} px-1.5 py-0.5 rounded font-semibold">
                                    {{ dept.status == 'active' ? 'Active' : 'Inactive' }}
                                </span>
                            </div>
                            {% if dept.description %}
                                <p class="text-xs text-gray-400 mt-0.5 line-clamp-1">{{ dept.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                    <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded font-semibold">
                        {{ dept.user_count }} staff
                    </span>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                    {% if dept.status == 'active' %}
                        <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded font-semibold">Active</span>
                    {% else %}
                        <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded font-semibold">Inactive</span>
                    {% endif %}
                </td>
                <td class="px-4 py-3 text-right">
                    <div class="flex items-center justify-end gap-1">
                        {% if can.edit %}
                        <button onclick="openEdit({{ dept|json_encode|e('html_attr') }})"
                                class="text-xs text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 px-2.5 py-1 rounded transition-colors">Edit</button>
                        <button onclick="toggleStatus({{ dept.id }}, '{{ dept.status }}', '{{ dept.name|e('js') }}')"
                                class="hidden sm:inline-flex text-xs {{ dept.status == 'active' ? 'text-amber-600 border-amber-200 hover:bg-amber-50' : 'text-emerald-600 border-emerald-200 hover:bg-emerald-50' }} border bg-white px-2.5 py-1 rounded transition-colors">
                            {{ dept.status == 'active' ? 'Deactivate' : 'Activate' }}
                        </button>
                        {% endif %}
                        {% if can.delete and not dept.is_system %}
                        <button onclick="deleteDept({{ dept.id }}, '{{ dept.name|e('js') }}')"
                                class="text-xs text-red-600 border border-red-200 bg-white hover:bg-red-50 px-2.5 py-1 rounded transition-colors">Delete</button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="px-4 py-12 text-center text-sm text-gray-400">No departments found.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block admin_scripts %}{# JS in assets/js/admin/departments.js #}{% endblock %}
