<!-- ================= LOCK SCREEN ================= -->
<div id="lock-screen"
     class="{{ is_locked ? '' : 'hidden' }} fixed inset-0 z-50 flex items-center justify-center p-4">

    <img src="{{ asset('images/background.png') }}"
         class="absolute inset-0 w-full h-full object-cover opacity-40">

    <div class="absolute inset-0 bg-black/30"></div>

    <div class="relative z-10 flex flex-col items-center text-white w-full max-w-md">

        <img src="{{ asset('images/logo.png') }}"
             class="w-32 mb-4 md:w-36"
             alt="Koma Gardens Logo">

        <div class="bg-black/60 p-4 md:p-6 rounded-xl shadow-xl w-full">

            <h2 class="text-xl md:text-2xl font-bold mb-4">
                System Locked
            </h2>
			
<input type="password"
       id="user_pin"
       placeholder="Enter PIN"
       readonly
       class="w-full p-3 rounded text-center bg-white text-gray-500 mb-4 text-xl tracking-widest">
            
            <div class="grid grid-cols-3 gap-2 md:gap-3 mb-4">

                <button class="pin-key">1</button>
                <button class="pin-key">2</button>
                <button class="pin-key">3</button>

                <button class="pin-key">4</button>
                <button class="pin-key">5</button>
                <button class="pin-key">6</button>

                <button class="pin-key">7</button>
                <button class="pin-key">8</button>
                <button class="pin-key">9</button>

                <button id="pin-clear" class="bg-red-600">C</button>
                <button class="pin-key">0</button>
                <button id="pin-back" class="bg-yellow-500">⌫</button>

            </div>

            <button
                id="pin_login"
                class="w-full bg-green-600 hover:bg-green-700 py-2 rounded font-semibold">
                Unlock
            </button>

            <div id="pin_error"
                 class="text-red-400 mt-3 text-sm md:text-base"></div>

        </div>

    </div>

</div>