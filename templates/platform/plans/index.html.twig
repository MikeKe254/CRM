{% extends 'platform/layout.html.twig' %}

{% block title %}Plans · Platform · Angavu{% endblock %}
{% block platform_title %}Plans{% endblock %}
{% block platform_subtitle %}Manage subscription plans, pricing and feature sets{% endblock %}

{% block platform_content %}

{# ── FLASH ────────────────────────────────────────────────────── #}
{% for msg in app.flashes('success') %}
<div class="mb-4 flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
    {{ ux_icon('lucide:circle-check', {width:15,height:15}) }} {{ msg }}
</div>
{% endfor %}
{% for msg in app.flashes('error') %}
<div class="mb-4 flex items-center gap-2 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
    {{ ux_icon('lucide:circle-x', {width:15,height:15}) }} {{ msg }}
</div>
{% endfor %}

{# ── HEADER ───────────────────────────────────────────────────── #}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-5">
    <div>
        <h1 class="text-lg font-extrabold text-slate-900 tracking-tight">
            {{ plans|length }}
            <span class="font-normal text-slate-500">plan{{ plans|length != 1 ? 's' : '' }}</span>
        </h1>
        <p class="text-xs text-slate-400 mt-0.5">Define what each plan includes and how much it costs</p>
    </div>
    {% if canEdit %}
    <button onclick="openAddDrawer()"
            class="inline-flex items-center gap-1.5 rounded-lg bg-indigo-600 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700 transition-colors">
        {{ ux_icon('lucide:plus', {width:13,height:13}) }} Add Plan
    </button>
    {% endif %}
</div>

{# ── PLANS TABLE ──────────────────────────────────────────────── #}
<div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-100 text-left">
                    <th class="px-5 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Plan</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Monthly</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Annual</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400 hidden sm:table-cell">Trial</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400 hidden md:table-cell">Features</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Status</th>
                    <th class="px-4 py-3 text-[10.5px] font-bold uppercase tracking-wider text-slate-400 text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for plan in plans %}
                <tr id="plan-row-{{ plan.id }}"
                    class="border-b border-slate-50 last:border-0 hover:bg-slate-50/70 transition-colors">

                    <td class="px-5 py-3.5">
                        <div class="flex items-center gap-2.5">
                            <div class="h-8 w-8 rounded-lg flex items-center justify-center text-xs font-bold
                                {% if plan.slug == 'free' %}bg-slate-100 text-slate-500
                                {% elseif plan.slug == 'starter' %}bg-blue-50 text-blue-600
                                {% elseif plan.slug == 'growth' %}bg-indigo-50 text-indigo-600
                                {% elseif plan.slug == 'enterprise' %}bg-violet-50 text-violet-600
                                {% else %}bg-amber-50 text-amber-600{% endif %}">
                                {{ plan.name|first|upper }}
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800">{{ plan.name }}</div>
                                <div class="text-[10px] text-slate-400 font-mono">{{ plan.slug }}</div>
                            </div>
                        </div>
                    </td>

                    <td class="px-4 py-3.5">
                        <span class="text-sm font-semibold text-slate-700">
                            {% if plan.monthly_price == 0 %}
                                <span class="text-slate-400">Free</span>
                            {% else %}
                                {{ plan.currency }} {{ plan.monthly_price|number_format(0, '.', ',') }}
                            {% endif %}
                        </span>
                    </td>

                    <td class="px-4 py-3.5">
                        <span class="text-sm text-slate-600">
                            {% if plan.annual_price == 0 %}
                                <span class="text-slate-400">—</span>
                            {% else %}
                                {{ plan.currency }} {{ plan.annual_price|number_format(0, '.', ',') }}
                            {% endif %}
                        </span>
                    </td>

                    <td class="px-4 py-3.5 hidden sm:table-cell">
                        <span class="text-xs text-slate-500">
                            {% if plan.trial_days > 0 %}
                                {{ plan.trial_days }} days
                            {% else %}
                                <span class="text-slate-300">None</span>
                            {% endif %}
                        </span>
                    </td>

                    <td class="px-4 py-3.5 hidden md:table-cell">
                        <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600">
                            {{ ux_icon('lucide:boxes', {width:11,height:11}) }}
                            {{ plan.feature_count }} features
                        </span>
                    </td>

                    <td class="px-4 py-3.5">
                        {% if plan.is_active %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-[10.5px] font-semibold text-emerald-600">
                                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Active
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2 py-0.5 text-[10.5px] font-semibold text-slate-400">
                                <span class="h-1.5 w-1.5 rounded-full bg-slate-300"></span> Inactive
                            </span>
                        {% endif %}
                        {% if not plan.is_public %}
                            <span class="ml-1 inline-flex items-center rounded-full bg-amber-50 px-1.5 py-0.5 text-[9px] font-semibold text-amber-600">Internal</span>
                        {% endif %}
                    </td>

                    <td class="px-4 py-3.5 text-right">
                        <div class="flex items-center justify-end gap-1.5">
                            <a href="{{ path('platform_plan_features', {id: plan.id, domain: app.request.attributes.get('domain')}) }}"
                               class="inline-flex items-center gap-1 rounded-lg border border-indigo-200 bg-indigo-50 px-2.5 py-1 text-[10.5px] font-semibold text-indigo-600 hover:bg-indigo-100 transition-colors"
                               title="Manage features">
                                {{ ux_icon('lucide:layers', {width:11,height:11}) }} Features
                            </a>
                            {% if canEdit %}
                            <button onclick="openEditDrawer({{ plan|json_encode|e('html_attr') }})"
                                    class="inline-flex items-center gap-1 rounded-lg border border-slate-200 bg-white px-2.5 py-1 text-[10.5px] font-semibold text-slate-600 hover:bg-slate-50 transition-colors">
                                {{ ux_icon('lucide:pencil', {width:11,height:11}) }} Edit
                            </button>
                            <button onclick="deletePlan({{ plan.id }}, '{{ plan.name|e('js') }}')"
                                    class="inline-flex items-center gap-1 rounded-lg border border-red-100 bg-red-50 px-2.5 py-1 text-[10.5px] font-semibold text-red-500 hover:bg-red-100 transition-colors">
                                {{ ux_icon('lucide:trash-2', {width:11,height:11}) }}
                            </button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="px-5 py-12 text-center text-sm text-slate-400">
                        No plans yet. Add your first plan to get started.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── DRAWER ───────────────────────────────────────────────────── #}
<div id="plans-drawer-backdrop"
     onclick="closePlanDrawer()"
     style="display:none;position:fixed;inset:0;background:rgba(15,15,30,0.35);z-index:40;backdrop-filter:blur(2px);"></div>

<div id="plans-drawer"
     style="position:fixed;top:0;right:0;height:100vh;width:420px;max-width:100vw;background:#fff;z-index:50;
            box-shadow:-8px 0 40px rgba(0,0,0,0.12);transform:translateX(100%);transition:transform 0.25s ease;
            display:flex;flex-direction:column;overflow:hidden;">

    <div style="padding:20px 22px 16px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
        <div>
            <div id="drawer-title" style="font-size:14px;font-weight:700;color:#0f172a;"></div>
            <div id="drawer-subtitle" style="font-size:11px;color:#94a3b8;margin-top:2px;"></div>
        </div>
        <button onclick="closePlanDrawer()" style="background:none;border:none;cursor:pointer;color:#94a3b8;padding:4px;border-radius:6px;transition:color 0.15s;"
                onmouseover="this.style.color='#475569'" onmouseout="this.style.color='#94a3b8'">
            {{ ux_icon('lucide:x', {width:16,height:16}) }}
        </button>
    </div>

    <div style="flex:1;overflow-y:auto;padding:22px;">
        <form id="plan-form" method="POST">
            <input type="hidden" name="_token" value="">

            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Plan Name <span style="color:#ef4444;">*</span></label>
                <input name="name" id="f-name" type="text" required placeholder="e.g. Growth"
                       style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                       onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
            </div>

            <div id="slug-row" style="margin-bottom:16px;">
                <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Slug <span style="color:#ef4444;">*</span></label>
                <input name="slug" id="f-slug" type="text" required placeholder="e.g. growth"
                       style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;font-family:monospace;outline:none;transition:border-color 0.15s;"
                       onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                <div style="font-size:10px;color:#94a3b8;margin-top:4px;">Lowercase letters, numbers, hyphens only. Cannot be changed after creation.</div>
            </div>

            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Description</label>
                <input name="description" id="f-description" type="text" placeholder="Short description for this plan"
                       style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                       onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                <div>
                    <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Monthly Price (KES)</label>
                    <input name="monthly_price" id="f-monthly" type="number" min="0" step="0.01" placeholder="0.00"
                           style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                </div>
                <div>
                    <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Annual Price (KES)</label>
                    <input name="annual_price" id="f-annual" type="number" min="0" step="0.01" placeholder="0.00"
                           style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
                <div>
                    <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Trial Days</label>
                    <input name="trial_days" id="f-trial" type="number" min="0" placeholder="0"
                           style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                </div>
                <div>
                    <label style="display:block;font-size:11px;font-weight:600;color:#475569;margin-bottom:5px;">Sort Order</label>
                    <input name="sort_order" id="f-order" type="number" min="0" placeholder="0"
                           style="width:100%;height:38px;border:1px solid #e2e8f0;border-radius:8px;padding:0 12px;font-size:13px;outline:none;transition:border-color 0.15s;"
                           onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                </div>
            </div>

            <div style="display:flex;align-items:center;gap:20px;margin-bottom:20px;">
                <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:12px;color:#475569;font-weight:500;">
                    <input name="is_public" id="f-public" type="checkbox" value="1" style="width:14px;height:14px;accent-color:#6366f1;">
                    Show on pricing page
                </label>
                <label id="active-toggle" style="display:none;align-items:center;gap:7px;cursor:pointer;font-size:12px;color:#475569;font-weight:500;">
                    <input name="is_active" id="f-active" type="checkbox" value="1" style="width:14px;height:14px;accent-color:#6366f1;">
                    Active
                </label>
            </div>
        </form>
    </div>

    <div style="padding:16px 22px;border-top:1px solid #f1f5f9;display:flex;gap:10px;flex-shrink:0;">
        <button onclick="submitForm()" id="drawer-submit"
                style="flex:1;height:38px;background:#4f46e5;color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;transition:background 0.15s;"
                onmouseover="this.style.background='#4338ca'" onmouseout="this.style.background='#4f46e5'">
            Save Plan
        </button>
        <button onclick="closePlanDrawer()"
                style="height:38px;padding:0 18px;background:#f8fafc;color:#64748b;border:1px solid #e2e8f0;border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;transition:background 0.15s;"
                onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='#f8fafc'">
            Cancel
        </button>
    </div>
</div>

{% endblock %}

{% block javascripts %}{{ parent() }}
<script>
(function () {
    const CREATE_URL = '{{ path('platform_plans_create', {domain: app.request.attributes.get('domain')}) }}';

    function slideOpen() {
        document.getElementById('plans-drawer').style.transform = 'translateX(0)';
        document.getElementById('plans-drawer-backdrop').style.display = 'block';
    }
    function slideClose() {
        document.getElementById('plans-drawer').style.transform = 'translateX(100%)';
        document.getElementById('plans-drawer-backdrop').style.display = 'none';
    }

    window.openAddDrawer = function () {
        document.getElementById('drawer-title').textContent    = 'Add Plan';
        document.getElementById('drawer-subtitle').textContent = 'Create a new subscription plan';
        document.getElementById('plan-form').action            = CREATE_URL;
        document.getElementById('slug-row').style.display      = 'block';
        document.getElementById('active-toggle').style.display = 'none';
        document.getElementById('f-name').value        = '';
        document.getElementById('f-slug').value        = '';
        document.getElementById('f-description').value = '';
        document.getElementById('f-monthly').value     = '0';
        document.getElementById('f-annual').value      = '0';
        document.getElementById('f-trial').value       = '14';
        document.getElementById('f-order').value       = '0';
        document.getElementById('f-public').checked    = true;
        document.getElementById('drawer-submit').textContent = 'Save Plan';
        slideOpen();
    };

    window.openEditDrawer = function (p) {
        document.getElementById('drawer-title').textContent    = 'Edit Plan';
        document.getElementById('drawer-subtitle').textContent = 'Update ' + p.name;
        document.getElementById('plan-form').action            = '/platform/plans/' + p.id + '/edit';
        document.getElementById('slug-row').style.display      = 'none';
        document.getElementById('active-toggle').style.display = 'flex';
        document.getElementById('f-name').value        = p.name        || '';
        document.getElementById('f-description').value = p.description || '';
        document.getElementById('f-monthly').value     = p.monthly_price;
        document.getElementById('f-annual').value      = p.annual_price;
        document.getElementById('f-trial').value       = p.trial_days;
        document.getElementById('f-order').value       = p.sort_order;
        document.getElementById('f-public').checked    = p.is_public == 1;
        document.getElementById('f-active').checked    = p.is_active == 1;
        document.getElementById('drawer-submit').textContent = 'Save Changes';
        slideOpen();
    };

    window.closePlanDrawer = function () { slideClose(); };

    window.submitForm = function () {
        const btn = document.getElementById('drawer-submit');
        btn.disabled    = true;
        btn.textContent = 'Saving…';
        document.getElementById('plan-form').requestSubmit();
    };

    window.deletePlan = function (id, name) {
        platformConfirm({
            title:       'Delete plan?',
            message:     'Delete "' + name + '"? This cannot be undone. Plans assigned to companies will be unlinked.',
            confirmText: 'Delete',
            onConfirm: function () {
                fetch('/platform/plans/' + id + '/delete', { method: 'POST' })
                    .then(r => r.json())
                    .then(d => {
                        if (d.ok) {
                            const row = document.getElementById('plan-row-' + id);
                            if (row) row.remove();
                        } else {
                            platformAlert({ message: d.error || 'Could not delete plan.' });
                        }
                    })
                    .catch(() => platformAlert({ message: 'Request failed. Please try again.' }));
            },
        });
    };

    document.addEventListener('keydown', e => { if (e.key === 'Escape') slideClose(); });
}());
</script>
{% endblock %}
