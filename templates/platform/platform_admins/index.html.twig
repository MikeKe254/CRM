{% extends 'platform/layout.html.twig' %}

{% block title %}Platform Admins · Angavu{% endblock %}
{% block platform_title %}Platform Admins{% endblock %}
{% block platform_subtitle %}Who can operate across tenants and how much access each person holds{% endblock %}

{% block platform_content %}

{# ── HEADER ──────────────────────────────────────────────────── #}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
    <div>
        <h1 class="text-lg font-extrabold text-slate-900 tracking-tight">
            {{ admins|length }}
            <span class="font-normal text-slate-500">platform admin{{ admins|length != 1 ? 's' : '' }}</span>
        </h1>
        <p class="text-xs text-slate-400 mt-0.5">Accounts with cross-company platform access</p>
    </div>

    <div class="flex items-center gap-2 flex-wrap">
        {% set owners = admins|filter(a => a.is_platform_owner)|length %}
        {% set active = admins|filter(a => not a.is_platform_owner and a.status == 'active')|length %}
        <div class="flex items-center gap-1.5 px-3 py-1.5 bg-white border border-slate-200 rounded-lg">
            <span class="w-2 h-2 rounded-full bg-amber-400 flex-shrink-0"></span>
            <span class="text-xs font-semibold text-slate-600">{{ owners }} Owner{{ owners != 1 ? 's' : '' }}</span>
        </div>
        <div class="flex items-center gap-1.5 px-3 py-1.5 bg-white border border-slate-200 rounded-lg">
            <span class="w-2 h-2 rounded-full bg-emerald-500 flex-shrink-0"></span>
            <span class="text-xs font-semibold text-slate-600">{{ active }} Active</span>
        </div>
    </div>
</div>

{# ── ADMIN GRID ──────────────────────────────────────────────── #}
{% if admins|length > 0 %}
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        {% for admin in admins %}
            <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm hover:shadow-md hover:border-indigo-100 transition-all">

                <div class="flex items-start justify-between gap-3 mb-5">
                    <div class="flex items-center gap-3">
                        <div class="w-11 h-11 rounded-xl flex items-center justify-center text-base font-extrabold text-white flex-shrink-0"
                             style="background:{% if admin.is_platform_owner %}linear-gradient(135deg,#f59e0b,#d97706){% else %}linear-gradient(135deg,#4f46e5,#7c3aed){% endif %};">
                            {{ admin.name|first|upper }}
                        </div>
                        <div class="min-w-0">
                            <div class="text-sm font-bold text-slate-900 truncate max-w-[140px]">{{ admin.name }}</div>
                            <div class="text-xs text-slate-400 truncate max-w-[140px] mt-0.5">{{ admin.email }}</div>
                            {% if admin.mobile %}
                            <div class="text-xs text-slate-400 truncate max-w-[140px] mt-0.5">{{ admin.mobile }}</div>
                            {% endif %}
                        </div>
                    </div>

                    {% if admin.is_platform_owner %}
                        <span class="flex-shrink-0 inline-flex items-center gap-1 px-2 py-0.5 bg-amber-50 border border-amber-200 rounded-md text-[10px] font-bold text-amber-700">
                            {{ ux_icon('lucide:crown', {width: 10, height: 10}) }} OWNER
                        </span>
                    {% elseif admin.status == 'active' %}
                        <span class="flex-shrink-0 inline-flex items-center gap-1 px-2 py-0.5 bg-emerald-50 border border-emerald-200 rounded-md text-[10px] font-bold text-emerald-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> ACTIVE
                        </span>
                    {% else %}
                        <span class="flex-shrink-0 px-2 py-0.5 bg-slate-100 border border-slate-200 rounded-md text-[10px] font-bold text-slate-500">
                            {{ admin.status|title|upper }}
                        </span>
                    {% endif %}
                </div>

                <div class="space-y-2">
                    <div class="flex items-center justify-between px-3 py-2.5 bg-slate-50 rounded-xl border border-slate-100">
                        <div class="flex items-center gap-2 text-xs text-slate-500">
                            {{ ux_icon('lucide:phone', {width: 12, height: 12, class: 'flex-shrink-0'}) }}
                            Mobile
                        </div>
                        <span class="text-xs font-semibold text-slate-800">{{ admin.mobile ?? '—' }}</span>
                    </div>
                    <div class="flex items-center justify-between px-3 py-2.5 bg-slate-50 rounded-xl border border-slate-100">
                        <div class="flex items-center gap-2 text-xs text-slate-500">
                            {{ ux_icon('lucide:user-cog', {width: 12, height: 12, class: 'flex-shrink-0'}) }}
                            Roles
                        </div>
                        <span class="text-xs font-semibold text-slate-800">{{ admin.roles ?: '—' }}</span>
                    </div>

                    <div class="flex items-center justify-between px-3 py-2.5 bg-slate-50 rounded-xl border border-slate-100">
                        <div class="flex items-center gap-2 text-xs text-slate-500">
                            {{ ux_icon('lucide:key-round', {width: 12, height: 12, class: 'flex-shrink-0'}) }}
                            Permissions
                        </div>
                        {% if admin.permission_count > 0 %}
                            <span class="inline-flex items-center justify-center w-6 h-6 bg-indigo-50 rounded-md text-[11px] font-bold text-indigo-600">{{ admin.permission_count }}</span>
                        {% else %}
                            <span class="text-xs text-slate-400">None</span>
                        {% endif %}
                    </div>

                    <div class="flex items-center justify-between px-3 py-2.5 bg-slate-50 rounded-xl border border-slate-100">
                        <div class="flex items-center gap-2 text-xs text-slate-500">
                            {{ ux_icon('lucide:terminal', {width: 12, height: 12, class: 'flex-shrink-0'}) }}
                            System Account
                        </div>
                        {% if admin.is_system_account %}
                            <span class="text-[11px] font-semibold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-md">Yes</span>
                        {% else %}
                            <span class="text-xs text-slate-400">No</span>
                        {% endif %}
                    </div>
                </div>

                <div class="mt-4 pt-3 border-t border-slate-100">
                    <button onclick="openAdminEdit({{ admin|json_encode|e('html_attr') }})"
                            class="w-full h-8 text-xs font-semibold text-indigo-600 border border-indigo-200 bg-white hover:bg-indigo-50 rounded-lg transition-colors">
                        Edit
                    </button>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div class="bg-white border border-slate-200 rounded-2xl p-16 text-center shadow-sm">
        <div class="flex flex-col items-center gap-3 text-slate-400">
            {{ ux_icon('lucide:shield-off', {width: 40, height: 40, class: 'opacity-25'}) }}
            <p class="text-sm font-medium text-slate-500">No platform admins found</p>
            <p class="text-xs text-slate-300">Platform operators will appear here once added.</p>
        </div>
    </div>
{% endif %}

{# ── Edit Modal ──────────────────────────────────────────── #}
<div id="admin-edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
            <h3 class="text-sm font-semibold text-slate-900">Edit Admin</h3>
            <button onclick="closeAdminEdit()" class="text-slate-400 hover:text-slate-600">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="px-6 py-5 space-y-4">
            <input type="hidden" id="ae-id">
            <div>
                <label class="block text-xs font-semibold text-slate-700 mb-1">Name <span class="text-red-500">*</span></label>
                <input id="ae-name" type="text" maxlength="120"
                       class="w-full h-9 px-3 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-700 mb-1">Mobile Number</label>
                <input id="ae-mobile" type="tel" maxlength="20" placeholder="e.g. +254712345678"
                       class="w-full h-9 px-3 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400">
            </div>
            <div id="ae-error" class="hidden text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"></div>
        </div>
        <div class="flex justify-end gap-2 px-6 pb-5">
            <button type="button" onclick="closeAdminEdit()"
                    class="px-4 h-9 border border-slate-200 text-sm text-slate-600 rounded-lg hover:bg-slate-50 transition-colors">Cancel</button>
            <button type="button" id="ae-submit" onclick="submitAdminEdit()"
                    class="px-4 h-9 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors">Save Changes</button>
        </div>
    </div>
</div>

<script>
const ADMIN_EDIT_BASE = '{{ path('platform_admins', {domain: app.request.attributes.get('domain')}) }}';

function openAdminEdit(admin) {
    document.getElementById('ae-id').value     = admin.id;
    document.getElementById('ae-name').value   = admin.name ?? '';
    document.getElementById('ae-mobile').value = admin.mobile ?? '';
    document.getElementById('ae-error').classList.add('hidden');
    const modal = document.getElementById('admin-edit-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.getElementById('ae-name').focus();
}

function closeAdminEdit() {
    const modal = document.getElementById('admin-edit-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
}

async function submitAdminEdit() {
    const id  = document.getElementById('ae-id').value;
    const btn = document.getElementById('ae-submit');
    const err = document.getElementById('ae-error');
    btn.disabled = true; btn.textContent = 'Saving…';
    err.classList.add('hidden');

    const body = new FormData();
    body.append('name',   document.getElementById('ae-name').value);
    body.append('mobile', document.getElementById('ae-mobile').value);

    const res  = await fetch(`${ADMIN_EDIT_BASE}/${id}/edit`, { method: 'POST', body });
    const data = await res.json();

    if (data.success) {
        closeAdminEdit();
        Turbo.visit(window.location.pathname, { action: 'replace' });
    } else {
        err.textContent = data.message;
        err.classList.remove('hidden');
        btn.disabled = false; btn.textContent = 'Save Changes';
    }
}

document.getElementById('admin-edit-modal')?.addEventListener('click', function(e) {
    if (e.target === this) closeAdminEdit();
});
</script>
{% endblock %}
