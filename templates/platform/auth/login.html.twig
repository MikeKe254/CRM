{% extends 'base.html.twig' %}
{% set platform_domain = currentDomain() %}

{% block title %}Platform Login | Angavu{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(16, 185, 129, 0.12), transparent 24%),
                radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.14), transparent 28%),
                linear-gradient(135deg, #f5f7fb 0%, #eef3f8 100%);
            color: #0f172a;
        }
    </style>
{% endblock %}

{% block body %}
<div class="min-h-screen px-4 py-8 sm:px-6 lg:px-8">
    <div class="mx-auto flex min-h-screen max-w-5xl items-center justify-center">
        <section class="w-full max-w-lg rounded-[32px] border border-slate-200 bg-white p-6 shadow-[0_30px_100px_rgba(15,23,42,0.12)] sm:p-8">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-700">
                        {{ ux_icon('lucide:lock-keyhole', { width: 12, height: 12 }) }}
                        Platform Sign In
                    </div>
                    <h1 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Welcome back</h1>
                    <p class="mt-3 text-sm leading-6 text-slate-500">
                        Sign in with your platform admin account to continue.
                    </p>
                </div>

                <div class="hidden h-12 w-12 items-center justify-center rounded-2xl text-sm font-black tracking-[0.24em] text-white sm:flex"
                     style="background: #0f172a;">
                    AP
                </div>
            </div>

            <div id="login-error"
                 class="hidden mt-6 items-start gap-3 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                <span class="mt-0.5 text-rose-500">
                    {{ ux_icon('lucide:circle-alert', { width: 16, height: 16 }) }}
                </span>
                <span id="login-error-text" class="leading-6"></span>
            </div>

            <form id="platform-login-form" class="mt-6 space-y-5">
                <div>
                    <label for="login-email" class="mb-2 block text-sm font-medium text-slate-700">Platform email</label>
                    <input type="email"
                           id="login-email"
                           placeholder="name@angavu.com"
                           required
                           autocomplete="email"
                           class="h-14 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 text-[15px] text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:ring-4 focus:ring-slate-200/70">
                </div>

                <div>
                    <div class="mb-2 flex items-center justify-between gap-3">
                        <label for="login-password" class="block text-sm font-medium text-slate-700">Password</label>
                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-500"
                              title="Protected field"
                              aria-hidden="true">
                            {{ ux_icon('lucide:shield-check', { width: 14, height: 14 }) }}
                        </span>
                    </div>
                    <div class="relative">
                        <input type="password"
                               id="login-password"
                               placeholder="Enter your password"
                               required
                               autocomplete="current-password"
                               class="h-14 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 text-[15px] text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:ring-4 focus:ring-slate-200/70"
                               style="padding-right: 3.5rem;">
                        <button type="button"
                                onclick="togglePassword()"
                                class="flex items-center justify-center rounded-xl text-slate-500 transition hover:bg-slate-100 hover:text-slate-700"
                                style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); width: 2.25rem; height: 2.25rem;"
                                aria-label="Toggle password visibility">
                            {{ ux_icon('lucide:eye', { width: 18, height: 18 }) }}
                        </button>
                    </div>
                </div>

                <label for="login-remember" class="flex cursor-pointer items-center justify-between gap-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 transition hover:border-slate-300 hover:bg-white">
                    <span class="flex items-center gap-3">
                        <input type="checkbox"
                               id="login-remember"
                               class="h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-400">
                        <span>
                            <span class="block text-sm font-medium text-slate-700">Remember this browser</span>
                            <span class="block text-xs text-slate-500">Keep your platform session available for up to 30 days.</span>
                        </span>
                    </span>
                    <span class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500 ring-1 ring-slate-200">30 days</span>
                </label>

                <button type="submit"
                        id="login-btn"
                        class="flex h-14 w-full items-center justify-center rounded-2xl px-5 text-sm font-semibold text-white transition focus:outline-none focus:ring-4 focus:ring-slate-300 disabled:cursor-not-allowed disabled:opacity-75"
                        style="background: #0f172a;">
                    Continue to platform
                </button>
            </form>
        </section>
    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('login-password');
    input.type = input.type === 'password' ? 'text' : 'password';
}

function showError(msg) {
    const el = document.getElementById('login-error');
    document.getElementById('login-error-text').textContent = msg;
    el.classList.remove('hidden');
    el.classList.add('flex');
}

function clearError() {
    const el = document.getElementById('login-error');
    el.classList.add('hidden');
    el.classList.remove('flex');
}

function setLoading(loading) {
    const btn = document.getElementById('login-btn');
    btn.disabled = loading;
    btn.textContent = loading ? 'Signing in...' : 'Continue to platform';
}

document.getElementById('platform-login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    clearError();
    setLoading(true);

    try {
        const body = new URLSearchParams({
            email: document.getElementById('login-email').value,
            password: document.getElementById('login-password').value,
            remember: document.getElementById('login-remember').checked ? 1 : 0,
        });

        const res = await fetch('{{ path('platform_login_auth', {domain: platform_domain}) }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: body.toString(),
        });

        const data = await res.json();

        if (data.success) {
            window.location.href = data.redirect;
        } else {
            showError(data.message ?? 'Login failed. Please try again.');
        }
    } catch (err) {
        showError('An unexpected error occurred. Please try again.');
        console.error(err);
    } finally {
        setLoading(false);
    }
});
</script>
{% endblock %}
