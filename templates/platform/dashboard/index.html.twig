{% extends 'platform/layout.html.twig' %}
{% set platform_domain = currentDomain() %}

{% block title %}Platform Dashboard · Angavu{% endblock %}
{% block platform_title %}Platform Dashboard{% endblock %}
{% block platform_subtitle %}Cross-company view of tenants, operators, and operational health{% endblock %}

{% block platform_content %}

{# ── HERO BANNER ─────────────────────────────────────────────── #}
<div class="relative overflow-hidden rounded-2xl mb-6 p-6 sm:p-8"
     style="background:linear-gradient(135deg,#1e1b4b 0%,#312e81 50%,#1e1b4b 100%);">
    <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full pointer-events-none"
         style="background:radial-gradient(circle,rgba(99,102,241,0.3) 0%,transparent 70%)"></div>
    <div class="absolute -bottom-16 left-1/3 w-72 h-48 rounded-full pointer-events-none"
         style="background:radial-gradient(circle,rgba(124,58,237,0.2) 0%,transparent 70%)"></div>

    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0"
                      style="box-shadow:0 0 0 3px rgba(74,222,128,0.25)"></span>
                <span class="text-[11px] font-semibold uppercase tracking-widest" style="color:rgba(165,180,252,0.8);">All systems operational</span>
            </div>
            <h1 class="text-xl sm:text-2xl font-extrabold text-white mb-1 tracking-tight">Good to have you back.</h1>
            <p class="text-sm" style="color:rgba(199,210,254,0.7);">
                {% if session is defined and session.user is defined %}{{ session.user.name }} · {% endif %}Angavu Platform Console
            </p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            <a href="{{ path('platform_companies', {domain: platform_domain}) }}"
               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-semibold transition border"
               style="background:rgba(255,255,255,0.1);border-color:rgba(255,255,255,0.15);color:#e0e7ff;"
               onmouseover="this.style.background='rgba(255,255,255,0.18)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
                {{ ux_icon('lucide:building-2', {width: 13, height: 13}) }} Companies
            </a>
            <a href="{{ path('platform_activity_logs', {domain: platform_domain}) }}"
               class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-xs font-semibold text-white transition"
               style="background:rgba(99,102,241,0.8);border:1px solid rgba(99,102,241,0.9);"
               onmouseover="this.style.background='rgba(79,70,229,0.9)'" onmouseout="this.style.background='rgba(99,102,241,0.8)'">
                {{ ux_icon('lucide:scroll-text', {width: 13, height: 13}) }} Audit Log
            </a>
        </div>
    </div>
</div>

{# ── STAT CARDS ──────────────────────────────────────────────── #}
<div class="grid grid-cols-2 xl:grid-cols-4 gap-3 sm:gap-4 mb-6">

    <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm">
        <div class="flex items-center justify-between mb-3 sm:mb-4">
            <span class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-widest text-slate-400">Companies</span>
            <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 flex-shrink-0">
                {{ ux_icon('lucide:building-2', {width: 15, height: 15}) }}
            </div>
        </div>
        <div class="text-3xl font-extrabold text-slate-900 leading-none mb-1.5 tracking-tight">{{ stats.companies }}</div>
        <div class="text-xs text-slate-500"><span class="text-emerald-600 font-semibold">{{ stats.active_companies }}</span> active</div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm">
        <div class="flex items-center justify-between mb-3 sm:mb-4">
            <span class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-widest text-slate-400">Admins</span>
            <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 flex-shrink-0">
                {{ ux_icon('lucide:shield-check', {width: 15, height: 15}) }}
            </div>
        </div>
        <div class="text-3xl font-extrabold text-slate-900 leading-none mb-1.5 tracking-tight">{{ stats.platform_admins }}</div>
        <div class="text-xs text-slate-500">Internal operators</div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm">
        <div class="flex items-center justify-between mb-3 sm:mb-4">
            <span class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-widest text-slate-400">Users</span>
            <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 flex-shrink-0">
                {{ ux_icon('lucide:users', {width: 15, height: 15}) }}
            </div>
        </div>
        <div class="text-3xl font-extrabold text-slate-900 leading-none mb-1.5 tracking-tight">{{ stats.tenant_users }}</div>
        <div class="text-xs text-slate-500">Across all workspaces</div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 shadow-sm">
        <div class="flex items-center justify-between mb-3 sm:mb-4">
            <span class="text-[10px] sm:text-[11px] font-semibold uppercase tracking-widest text-slate-400">Terminals</span>
            <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 flex-shrink-0">
                {{ ux_icon('lucide:monitor-smartphone', {width: 15, height: 15}) }}
            </div>
        </div>
        <div class="text-3xl font-extrabold text-slate-900 leading-none mb-1.5 tracking-tight">{{ stats.active_terminals }}</div>
        <div class="text-xs text-slate-500">{{ stats.platform_logs }} audit entries</div>
    </div>

</div>

{# ── MAIN GRID ────────────────────────────────────────────────── #}
<div class="grid grid-cols-1 xl:grid-cols-[1fr_360px] gap-5">

    {# Companies table #}
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-slate-100">
            <div>
                <h2 class="text-sm font-bold text-slate-900">Recent Companies</h2>
                <p class="text-xs text-slate-400 mt-0.5">Latest tenant workspaces on the platform</p>
            </div>
            <a href="{{ path('platform_companies', {domain: platform_domain}) }}"
               class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-600 hover:text-indigo-700 px-3 py-1.5 rounded-lg bg-indigo-50 hover:bg-indigo-100 transition border border-indigo-100">
                View all {{ ux_icon('lucide:arrow-right', {width: 11, height: 11}) }}
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-100 text-left">
                        <th class="px-5 py-2.5 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Company</th>
                        <th class="px-4 py-2.5 text-[10.5px] font-bold uppercase tracking-wider text-slate-400">Plan</th>
                        <th class="px-4 py-2.5 text-[10.5px] font-bold uppercase tracking-wider text-slate-400 hidden sm:table-cell">Users</th>
                        <th class="px-4 py-2.5 text-[10.5px] font-bold uppercase tracking-wider text-slate-400 hidden sm:table-cell">Terminals</th>
                    </tr>
                </thead>
                <tbody>
                    {% for company in recent_companies %}
                        <tr class="border-b border-slate-50 last:border-0 hover:bg-slate-50/70 transition-colors">
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-2.5">
                                    <div class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0"
                                         style="background:linear-gradient(135deg,#4f46e5,#7c3aed);">
                                        {{ company.name|first|upper }}
                                    </div>
                                    <div class="min-w-0">
                                        <div class="text-sm font-semibold text-slate-900 truncate">{{ company.name }}</div>
                                        <div class="text-xs text-slate-400 font-mono truncate">{{ company.subdomain }}.angavu</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3.5">
                                <span class="inline-block px-2 py-0.5 bg-slate-100 rounded-md text-[11px] font-semibold text-slate-600">{{ company.plan|upper }}</span>
                            </td>
                            <td class="px-4 py-3.5 text-sm font-medium text-slate-700 hidden sm:table-cell">{{ company.user_count }}</td>
                            <td class="px-4 py-3.5 text-sm font-medium text-slate-700 hidden sm:table-cell">{{ company.terminal_count }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-5 py-10 text-center">
                                <div class="flex flex-col items-center gap-2 text-slate-400">
                                    {{ ux_icon('lucide:building-2', {width: 28, height: 28, class: 'opacity-30'}) }}
                                    <span class="text-sm">No companies yet.</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Platform team #}
    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <div>
                <h2 class="text-sm font-bold text-slate-900">Platform Team</h2>
                <p class="text-xs text-slate-400 mt-0.5">Cross-company operators</p>
            </div>
            <a href="{{ path('platform_admins', {domain: platform_domain}) }}" class="text-xs font-semibold text-indigo-600 hover:text-indigo-700 transition">View all</a>
        </div>
        <div class="p-4 space-y-2">
            {% for admin in recent_platform_admins %}
                <div class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-100 hover:border-indigo-100 transition-colors">
                    <div class="w-9 h-9 rounded-xl flex items-center justify-center text-sm font-bold text-white flex-shrink-0"
                         style="background:{% if admin.is_platform_owner %}linear-gradient(135deg,#f59e0b,#d97706){% else %}linear-gradient(135deg,#4f46e5,#7c3aed){% endif %};">
                        {{ admin.name|first|upper }}
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-semibold text-slate-900 truncate">{{ admin.name }}</div>
                        <div class="text-xs text-slate-400 truncate">{{ admin.email }}</div>
                    </div>
                    {% if admin.is_platform_owner %}
                        <span class="flex-shrink-0 px-2 py-0.5 bg-amber-100 rounded-md text-[10px] font-bold text-amber-700">OWNER</span>
                    {% else %}
                        <span class="flex-shrink-0 px-2 py-0.5 bg-emerald-100 rounded-md text-[10px] font-bold text-emerald-700">ACTIVE</span>
                    {% endif %}
                </div>
            {% else %}
                <p class="text-sm text-slate-400 text-center py-8">No platform admins yet.</p>
            {% endfor %}
        </div>
    </div>

</div>

{% endblock %}
