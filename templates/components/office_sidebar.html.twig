      <nav class="flex-1 overflow-y-auto px-2 py-3 space-y-1">

        {# Overview #}
        <div class="space-y-1">
          <h3 class="px-3 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wide">Overview</h3>
          <a href="#" class="group flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-700 hover:bg-gray-100">
            <svg class="mr-3 h-5 w-5 text-gray-400 group-hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
