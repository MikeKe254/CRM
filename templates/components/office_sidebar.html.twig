{# Office/Branch-aware sidebar #}
{# Detects branch type (hq, region, branch) and renders appropriate menu #}
{# Uses session.branch for context (populated by BranchPickerController) #}

{% if not session.branch %}
  <div class="p-4 text-sm text-gray-500">
    No branch selected
  </div>
{% else %}
  {% set branch_type = session.branch.type %}
  {% set current_route = app.request.attributes.get('_route') %}
  {% set is_hq = branch_type == 'hq' %}
  {% set is_region = branch_type == 'region' %}
  {% set is_branch = branch_type == 'branch' %}

  <div class="flex flex-col h-full">

    {# ── HEADER: Current Office ────────────────────────────────────────────── #}
    <div class="px-4 py-3 border-b border-gray-200">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">{{ branch_type }}</div>
      <div class="mt-1 text-sm font-semibold text-gray-900">{{ session.branch.name }}</div>
    </div>

    {# ── HQ OFFICE MENU ──────────────────────────────────────────────────────── #}
