        {# System group #}
        {% if can_view_settings or can_view_tenant_activity_logs %}
        {% set _sys = (_r starts with 'admin_settings' or _r starts with 'admin_activity') %}
        <div class="sidebar-group">
            <button class="sidebar-group-btn {% if _sys %}has-active{% endif %}"
                    data-group="br-system" data-tooltip="System" onclick="toggleGroup('br-system')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <span class="sidebar-label">System</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-br-system">
                {% if can_view_settings %}
                <a href="{{ path('admin_settings', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_settings' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Settings</span>
                </a>
                {% endif %}
                {% if can_view_tenant_activity_logs %}
                <a href="{{ path('admin_activity_logs', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_activity' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Activity Logs</span>
                </a>
                {% endif %}
            </div>
        </div>
        {% endif %}

    {% endif %}
    {# /nav context switch #}

    </nav>

    {# ── USER — STICKY BOTTOM ────────────────────────────────────────────── #}
    <div id="sidebar-user-footer">

        <div class="flex-shrink-0 flex items-center justify-center text-white font-semibold"
             style="width:32px;height:32px;border-radius:50%;background:#4f46e5;font-size:12px;">
            {% if session is defined and session.user is defined %}
                {{ session.user.name|first|upper }}
            {% else %}U{% endif %}
        </div>

        <div class="sidebar-label sidebar-user-info flex-1 min-w-0 overflow-hidden">
            <div class="text-white font-medium truncate" style="font-size:13px;">
                {% if session is defined and session.user is defined %}{{ session.user.name }}{% else %}User{% endif %}
            </div>
            <div class="truncate" style="font-size:11px;color:rgba(255,255,255,0.35);">
                {% if session is defined and session.company is defined %}{{ session.company.name }}{% endif %}
            </div>
        </div>

        <button class="sidebar-label sidebar-logout flex-shrink-0 flex items-center"
                onclick="sidebarLogout('{{ path('app_logout', {subdomain: tenant_subdomain, domain: tenant_domain}) }}', '{{ path('app_login', {subdomain: tenant_subdomain, domain: tenant_domain}) }}')"
                title="Sign out"
                style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.35);padding:4px;border-radius:4px;transition:color 0.15s;"
                onmouseover="this.style.color='#fff'"
                onmouseout="this.style.color='rgba(255,255,255,0.35)'">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </button>

    </div>

</aside>
