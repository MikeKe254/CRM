{% set tenant_subdomain = session.company.subdomain|default(app.request.attributes.get('subdomain')) %}
{% set tenant_domain = currentDomain() %}
{% set current_branch = session.branch is defined and session.branch ? session.branch.slug : app.request.attributes.get('branch') %}

{#
 # Multi-branch gate
 #}
{% set multi_branch_enabled = feature('branch_create') %}

{#
 # Navigation context
 #}
{% set nav_context   = session.context ?? 'operational' %}
{% set branch_type   = (session.branch is defined and session.branch) ? session.branch.type : 'branch' %}
{% set is_overall    = (nav_context == 'overall') and multi_branch_enabled %}
{% set is_hq_branch  = (nav_context == 'operational' and branch_type == 'hq') and multi_branch_enabled %}
{% set is_region     = (nav_context == 'operational' and branch_type == 'region') and multi_branch_enabled %}
{% set can_view_tenant_activity_logs = isSuperAdmin()
    ? (platformCan('view_superadmin_activity_logs') or platformCan('view_owner_activity_logs'))
    : can('view_user_activity') %}
{% set can_view_settings = isSuperAdmin() ? platformCan('view_settings') : can('view_settings') %}

{# Active route shorthand #}
{% set _r = app.request.attributes.get('_route') %}

<div id="sidebar-overlay"></div>

<aside id="sidebar">

    {# ── LOGO — STICKY TOP ───────────────────────────────────────────────── #}
    <div id="sidebar-logo-row">

        <div id="sidebar-logo-icon" onclick="logoIconClick()" title="Expand sidebar">
            A
        </div>

        <div id="sidebar-logo-text">
            <div style="font-weight:600;font-size:14px;color:#fff;line-height:1.2;">Angavu</div>
            <div style="font-size:11px;color:rgba(255,255,255,0.35);">Customer Intelligence</div>
        </div>

        <button id="collapse-btn" onclick="toggleSidebar()" title="Collapse sidebar">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>

    </div>

    {# ── CONTEXT BADGE ────────────────────────────────────────────────────── #}
    {% if session is defined and session.branch is defined and session.branch %}
    <div style="padding:6px 8px 0;">
        <div style="display:flex;align-items:center;gap:6px;padding:6px 10px;border-radius:8px;
                    background:{% if is_overall %}rgba(124,58,237,0.25){% elseif is_hq_branch %}rgba(79,70,229,0.2){% elseif is_region %}rgba(14,116,144,0.2){% else %}rgba(255,255,255,0.07){% endif %};
                    border:1px solid {% if is_overall %}rgba(124,58,237,0.4){% elseif is_hq_branch %}rgba(99,102,241,0.3){% elseif is_region %}rgba(6,182,212,0.3){% else %}rgba(255,255,255,0.1){% endif %};">
            <div style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:{% if is_overall %}#a78bfa{% elseif is_hq_branch %}#818cf8{% elseif is_region %}#22d3ee{% else %}#6ee7b7{% endif %};"></div>
            <span style="font-size:11px;font-weight:600;color:{% if is_overall %}#c4b5fd{% elseif is_hq_branch %}#a5b4fc{% elseif is_region %}#67e8f9{% else %}#6ee7b7{% endif %};letter-spacing:0.05em;text-transform:uppercase;">
                {% if is_overall %}Overall
                {% elseif is_hq_branch %}{{ session.branch.name }}
                {% elseif is_region %}{{ session.branch.name }}
                {% else %}{{ session.branch.name }}{% endif %}
            </span>
        </div>
    </div>
    {% endif %}

    {# ── CONTEXT SWITCHER ─────────────────────────────────────────────────── #}
    {% set has_overall_access = multi_branch_enabled and can('assign_branch_heads') %}
    {% set has_multiple = multi_branch_enabled and session is defined and session.availableBranches is defined and session.availableBranches|length > 1 %}
    {% if has_multiple or has_overall_access %}
    <div id="branch-switcher" style="padding:6px 8px 0;">
        <div class="relative">
            <button id="branch-switcher-btn"
                    onclick="toggleDropdown('branch-switcher-dropdown')"
                    style="width:100%;display:flex;align-items:center;gap:8px;padding:8px 10px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:8px;cursor:pointer;text-align:left;">
                <div style="width:24px;height:24px;border-radius:6px;background:{% if is_overall %}#7c3aed{% else %}#4f46e5{% endif %};display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;font-weight:700;color:#fff;">
                    {% if is_overall %}★{% else %}{{ current_branch ? current_branch|first|upper : '?' }}{% endif %}
                </div>
                <div class="sidebar-label flex-1 min-w-0 overflow-hidden">
                    <div style="font-size:12px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                        {% if is_overall %}Company Overview{% elseif session.branch is defined and session.branch %}{{ session.branch.name }}{% else %}Select Branch{% endif %}
                    </div>
                    <div style="font-size:10px;color:rgba(255,255,255,0.4);">Switch context</div>
                </div>
                <svg style="flex-shrink:0;color:rgba(255,255,255,0.35);" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>

            <div id="branch-switcher-dropdown" class="navbar-dropdown"
                 style="position:absolute;left:0;right:0;top:calc(100% + 4px);background:#1e1b4b;border:1px solid rgba(255,255,255,0.12);border-radius:8px;overflow:hidden;z-index:150;box-shadow:0 8px 24px rgba(0,0,0,0.4);">

                {% if has_overall_access %}
                <a href="{{ path('app_dashboard', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   style="display:flex;align-items:center;gap:8px;padding:9px 12px;text-decoration:none;transition:background 0.1s;{% if is_overall %}background:rgba(124,58,237,0.35);{% endif %}border-bottom:1px solid rgba(255,255,255,0.08);"
                   onmouseover="this.style.background='rgba(124,58,237,0.25)'"
                   onmouseout="this.style.background='{% if is_overall %}rgba(124,58,237,0.35){% endif %}'">
                    <div style="width:20px;height:20px;border-radius:5px;background:#7c3aed;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;font-weight:700;color:#fff;">★</div>
                    <div style="flex:1;min-width:0;overflow:hidden;">
                        <div style="font-size:12px;color:#e0e7ff;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                            Company Overview
                            <span style="font-size:9px;padding:1px 5px;background:rgba(124,58,237,0.5);border-radius:3px;margin-left:4px;">overall</span>
                        </div>
                        <div style="font-size:10px;color:rgba(255,255,255,0.35);">Strategic &amp; org management</div>
                    </div>
                    {% if is_overall %}
                    <svg style="flex-shrink:0;color:#a78bfa;" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {% endif %}
                </a>
                {% endif %}

                {% if session is defined and session.availableBranches is defined %}
                {% for branch in session.availableBranches %}
                <a href="{{ path('app_dashboard', {subdomain: tenant_subdomain, domain: tenant_domain, branch: branch.slug}) }}"
                   style="display:flex;align-items:center;gap:8px;padding:9px 12px;text-decoration:none;transition:background 0.1s;{% if not is_overall and session.branch is defined and session.branch and session.branch.id == branch.id %}background:rgba(99,102,241,0.3);{% endif %}"
                   onmouseover="this.style.background='rgba(255,255,255,0.08)'"
                   onmouseout="this.style.background='{% if not is_overall and session.branch is defined and session.branch and session.branch.id == branch.id %}rgba(99,102,241,0.3){% endif %}'">
                    <div style="width:20px;height:20px;border-radius:5px;background:{% if branch.isHq %}#4f46e5{% elseif branch.type == 'region' %}#0e7490{% else %}#374151{% endif %};display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:10px;font-weight:700;color:#fff;">
                        {{ branch.name|first|upper }}
                    </div>
                    <div style="flex:1;min-width:0;overflow:hidden;">
                        <div style="font-size:12px;color:#e0e7ff;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                            {{ branch.name }}
                            {% if branch.isHq %}<span style="font-size:9px;padding:1px 4px;background:rgba(79,70,229,0.4);border-radius:3px;margin-left:4px;">HQ</span>
                            {% elseif branch.type == 'region' %}<span style="font-size:9px;padding:1px 4px;background:rgba(14,116,144,0.4);border-radius:3px;margin-left:4px;">region</span>{% endif %}
                        </div>
                    </div>
                    {% if not is_overall and session.branch is defined and session.branch and session.branch.id == branch.id %}
                    <svg style="flex-shrink:0;color:#818cf8;" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {% endif %}
                </a>
                {% endfor %}
                {% endif %}

            </div>
        </div>
    </div>
    {% endif %}

    {# ── NAV — SCROLLABLE ────────────────────────────────────────────────── #}
    <nav class="flex-1 overflow-y-auto overflow-x-hidden" style="padding:8px;">

    {# =========================================================================
       OVERALL CONTEXT — Company-wide strategic view (/overall/)
    ========================================================================= #}
    {% if is_overall %}

        <a href="{{ path('app_dashboard', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
           class="sidebar-link {% if _r == 'app_dashboard' %}active{% endif %}"
           data-tooltip="Dashboard">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            <span class="sidebar-label">Dashboard</span>
        </a>

        {# Organisation group #}
        {% if can('assign_branch_heads') or can('manage_branches') %}
        {% set _oa = (_r starts with 'admin_org' or _r starts with 'admin_branches') %}
        <div class="sidebar-group">
            <button class="sidebar-group-btn {% if _oa %}has-active{% endif %}"
                    data-group="ov-org" data-tooltip="Organisation" onclick="toggleGroup('ov-org')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <rect x="8" y="2" width="8" height="4" rx="1"/>
                    <rect x="1" y="14" width="6" height="4" rx="1"/><rect x="9" y="14" width="6" height="4" rx="1"/>
                    <rect x="17" y="14" width="6" height="4" rx="1"/>
                    <path d="M4 14v-3h16v3M12 6v5"/>
                </svg>
                <span class="sidebar-label">Organisation</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-ov-org">
                {% if can('assign_branch_heads') %}
                <a href="{{ path('admin_org', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_org' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Org Chart</span>
                </a>
                {% endif %}
                {% if can('manage_branches') %}
                <a href="{{ path('admin_branches', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_branches' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Branches</span>
                </a>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {# Configuration group #}
        {% if can('view_roles') or can('view_permissions') or can('view_departments') or can('view_areas') or can('view_catalog') or can('view_events') or can_view_settings or can_view_tenant_activity_logs %}
        {% set _ca = (_r starts with 'admin_roles' or _r starts with 'admin_permissions' or _r starts with 'admin_departments' or _r starts with 'admin_areas' or _r starts with 'admin_catalog' or _r starts with 'admin_events' or _r starts with 'admin_settings' or _r starts with 'admin_activity') %}
        <div class="sidebar-group">
            <button class="sidebar-group-btn {% if _ca %}has-active{% endif %}"
                    data-group="ov-config" data-tooltip="Configuration" onclick="toggleGroup('ov-config')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                <span class="sidebar-label">Configuration</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-ov-config">
                {% if can('view_roles') %}
                <a href="{{ path('admin_roles', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_roles' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Roles</span>
                </a>
                {% endif %}
                {% if can('view_permissions') %}
                <a href="{{ path('admin_permissions', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_permissions' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Permissions</span>
                </a>
                {% endif %}
                {% if can('view_departments') %}
                <a href="{{ path('admin_departments', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_departments' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Departments</span>
                </a>
                {% endif %}
                {% if can('view_areas') %}
                <a href="{{ path('admin_areas', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_areas' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Areas</span>
                </a>
                {% endif %}
                {% if can('view_catalog') %}
                <a href="{{ path('admin_catalog', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_catalog' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Catalog</span>
                </a>
                {% endif %}
                {% if can('view_events') %}
                <a href="{{ path('admin_events', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_events' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Events &amp; Offers</span>
                </a>
                {% endif %}
                {% if can_view_settings %}
                <a href="{{ path('admin_settings', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_settings' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Settings</span>
                </a>
                {% endif %}
                {% if can_view_tenant_activity_logs %}
                <a href="{{ path('admin_activity_logs', {subdomain: tenant_subdomain, domain: tenant_domain, branch: 'overall'}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_activity' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Activity Logs</span>
                </a>
                {% endif %}
            </div>
        </div>
        {% endif %}

    {# =========================================================================
       HQ BRANCH CONTEXT — Head office administrative hub
    ========================================================================= #}
    {% elseif is_hq_branch %}

        <a href="{{ path('app_dashboard', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
           class="sidebar-link {% if _r == 'app_dashboard' %}active{% endif %}"
           data-tooltip="Dashboard">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            <span class="sidebar-label">Dashboard</span>
        </a>

        {# Analytics group #}
        <div class="sidebar-group">
            <button class="sidebar-group-btn" data-group="hq-analytics" data-tooltip="Analytics" onclick="toggleGroup('hq-analytics')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                <span class="sidebar-label">Analytics</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-hq-analytics">
                <a href="#" class="sidebar-sublink"><span class="sidebar-sublink-dot"></span><span class="sidebar-label">Company Analytics</span></a>
                <a href="#" class="sidebar-sublink"><span class="sidebar-sublink-dot"></span><span class="sidebar-label">Financial Summary</span></a>
            </div>
        </div>

        {# Network group #}
        {% if multi_branch_enabled and (can('view_all_branch_data') or can('manage_branches') or can('assign_branch_heads')) %}
        {% set _na = (_r starts with 'admin_branches' or _r starts with 'admin_org') %}
        <div class="sidebar-group">
            <button class="sidebar-group-btn {% if _na %}has-active{% endif %}"
                    data-group="hq-network" data-tooltip="Network" onclick="toggleGroup('hq-network')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="sidebar-label">Network</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-hq-network">
                {% if can('view_all_branch_data') %}
                <a href="{{ path('admin_branches', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_branches' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">All Branches</span>
                </a>
                {% endif %}
                {% if can('assign_branch_heads') %}
                <a href="{{ path('admin_org', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_org' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Org Chart</span>
                </a>
                {% endif %}
                <a href="#" class="sidebar-sublink"><span class="sidebar-sublink-dot"></span><span class="sidebar-label">Branch Performance</span></a>
            </div>
        </div>
        {% endif %}

        {# People group #}
        {% if can('view_users') or can('view_roles') or can('view_permissions') or can('view_departments') or can('view_areas') %}
        {% set _pa = (_r starts with 'admin_users' or _r starts with 'admin_roles' or _r starts with 'admin_permissions' or _r starts with 'admin_departments' or _r starts with 'admin_areas') %}
        <div class="sidebar-group">
            <button class="sidebar-group-btn {% if _pa %}has-active{% endif %}"
                    data-group="hq-people" data-tooltip="People" onclick="toggleGroup('hq-people')">
                <svg class="group-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span class="sidebar-label">People</span>
                <svg class="sidebar-group-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sidebar-group-content" id="sg-hq-people">
                {% if can('view_users') %}
                <a href="{{ path('admin_users', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_users' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Staff Directory</span>
                </a>
                {% endif %}
                {% if can('view_roles') %}
                <a href="{{ path('admin_roles', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_roles' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Roles</span>
                </a>
                {% endif %}
                {% if can('view_permissions') %}
                <a href="{{ path('admin_permissions', {subdomain: tenant_subdomain, domain: tenant_domain, branch: current_branch}) }}"
                   class="sidebar-sublink {% if _r starts with 'admin_permissions' %}active{% endif %}">
                    <span class="sidebar-sublink-dot"></span><span class="sidebar-label">Permissions</span>
                </a>
                {% endif %}
                {% if can('view_departments') %}
