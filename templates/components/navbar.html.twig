<header id="app-navbar">

    {# ── HAMBURGER — mobile only, inside navbar ───────────────────────────── #}
    <button id="navbar-hamburger" onclick="openMobileSidebar()" aria-label="Open menu">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    {# ── BREADCRUMB + PAGE TITLE ──────────────────────────────────────────── #}
    <div class="flex-1 min-w-0">
        <div id="navbar-breadcrumb" class="flex items-center gap-1 overflow-hidden flex-nowrap" style="font-size:11px;margin-bottom:1px;">
            <a href="{{ path('app_dashboard') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;transition:color 0.15s;">Angavu</a>
            {% set route = app.request.attributes.get('_route') %}
            {% if route starts with 'admin_users' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <a href="{{ path('admin_users') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;">Admin</a>
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Users</span>
            {% elseif route starts with 'admin_roles' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <a href="{{ path('admin_roles') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;">Admin</a>
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Roles</span>
            {% elseif route starts with 'admin_permissions' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <a href="{{ path('admin_permissions') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;">Admin</a>
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Permissions</span>
            {% elseif route starts with 'admin_terminals' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <a href="{{ path('admin_terminals') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;">Admin</a>
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">POS Terminals</span>
            {% elseif route starts with 'admin_audit' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <a href="{{ path('admin_audit_logs') }}" style="color:#9ca3af;text-decoration:none;white-space:nowrap;">Admin</a>
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Audit Logs</span>
            {% elseif route == 'app_customers' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Customers</span>
            {% elseif route == 'app_dashboard' %}
                <span class="bc-separator" style="color:#d1d5db;">›</span>
                <span class="bc-current" style="color:#374151;white-space:nowrap;">Dashboard</span>
            {% endif %}
        </div>
        <div id="navbar-page-title" class="font-semibold truncate" style="font-size:14px;color:#111827;">
            {% set route = app.request.attributes.get('_route') %}
            {% if route starts with 'admin_users' %}Users
            {% elseif route starts with 'admin_roles' %}Roles
            {% elseif route starts with 'admin_permissions' %}Permissions
            {% elseif route starts with 'admin_terminals' %}POS Terminals
            {% elseif route starts with 'admin_audit' %}Audit Logs
            {% elseif route == 'app_customers' %}Customers
            {% elseif route == 'app_dashboard' %}Dashboard
            {% else %}Angavu CRM
            {% endif %}
        </div>
    </div>

    {# ── GLOBAL SEARCH — always present, compact on mobile ───────────────── #}
    <div id="navbar-search-wrap">
        <svg id="navbar-search-icon" width="14" height="14" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24"
             style="position:absolute;left:9px;pointer-events:none;z-index:1;">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="navbar-search-input"
               placeholder="Search…" autocomplete="off" spellcheck="false">
        <kbd id="navbar-search-kbd" style="position:absolute;right:8px;font-size:10px;color:#9ca3af;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:4px;padding:1px 5px;font-family:inherit;pointer-events:none;">⌘K</kbd>
    </div>

    {# ── NOTIFICATIONS ────────────────────────────────────────────────────── #}
    <div class="relative flex-shrink-0">
        <button class="navbar-icon-btn" id="notif-btn"
                onclick="toggleDropdown('notifications-dropdown')"
                title="Notifications"
                style="width:34px;padding:0;">
            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span id="notif-badge-count">3</span>
        </button>

        <div id="notifications-dropdown" class="navbar-dropdown" style="min-width:300px;">
            <div class="flex items-center justify-between" style="padding:12px 14px 8px;">
                <span class="font-semibold" style="font-size:13px;color:#111827;">Notifications</span>
                <button style="font-size:12px;color:#6366f1;background:none;border:none;cursor:pointer;font-weight:500;">Mark all read</button>
            </div>
            <hr class="dropdown-divider">
            <div class="dropdown-item">
                <div style="width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;margin-top:4px;"></div>
                <div><div class="dropdown-item-title">New customer registered</div><div class="dropdown-item-sub">254712345678 · first payment · 5m ago</div></div>
            </div>
            <div class="dropdown-item">
                <div style="width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;margin-top:4px;"></div>
                <div><div class="dropdown-item-title">STK push completed</div><div class="dropdown-item-sub">KES 2,500 · Pool Bar · 12m ago</div></div>
            </div>
            <div class="dropdown-item">
                <div style="width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;margin-top:4px;"></div>
                <div><div class="dropdown-item-title">Terminal expiring soon</div><div class="dropdown-item-sub">Reception POS · 3 days left</div></div>
            </div>
            <hr class="dropdown-divider">
            <div class="dropdown-item" style="justify-content:center;padding:8px;">
                <span style="font-size:12px;color:#6366f1;font-weight:500;">View all</span>
            </div>
        </div>
    </div>

    {# ── COMPANY BADGE — always present ───────────────────────────────────── #}
    {% if session is defined and session.company is defined %}
    <div class="navbar-company-badge">{{ session.company.name }}</div>
    {% endif %}

    {# ── PROFILE ──────────────────────────────────────────────────────────── #}
    <div class="relative flex-shrink-0">
        <button class="navbar-icon-btn" id="profile-btn"
                onclick="toggleDropdown('profile-dropdown')"
                title="Profile"
                style="border:1px solid #e5e7eb;border-radius:8px;padding:0 8px;">
            <div class="flex-shrink-0 flex items-center justify-center text-white font-semibold"
                 style="width:26px;height:26px;border-radius:50%;background:#4f46e5;font-size:11px;">
                {% if session is defined and session.user is defined %}{{ session.user.name|first|upper }}{% else %}U{% endif %}
            </div>
            <span class="font-medium truncate" style="font-size:13px;color:#374151;max-width:80px;display:none;">
                {% if session is defined and session.user is defined %}{{ session.user.name|split(' ')|first }}{% endif %}
            </span>
            <svg width="12" height="12" fill="none" stroke="#9ca3af" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;">
                <polyline points="6 9 12 15 18 9"/>
            </svg>
        </button>

        <div id="profile-dropdown" class="navbar-dropdown" style="min-width:220px;">
            <div style="padding:12px 14px 10px;">
                <div class="font-semibold" style="font-size:13px;color:#111827;">
                    {% if session is defined and session.user is defined %}{{ session.user.name }}{% endif %}
                </div>
                <div style="font-size:12px;color:#9ca3af;margin-top:1px;">
                    {% if session is defined and session.user is defined %}{{ session.user.email }}{% endif %}
                </div>
                {% if session is defined and session.user.roles is defined and session.user.roles|length > 0 %}
                <div class="flex flex-wrap gap-1 mt-2">
                    {% for role in session.user.roles %}
                    <span style="font-size:11px;padding:2px 7px;background:#eef2ff;color:#4f46e5;border-radius:4px;font-weight:500;">{{ role }}</span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            <hr class="dropdown-divider">
            <a href="#" class="dropdown-item">
                <svg width="15" height="15" fill="none" stroke="#6b7280" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <div><div class="dropdown-item-title">My Profile</div><div class="dropdown-item-sub">Account settings</div></div>
            </a>
            <a href="#" class="dropdown-item">
                <svg width="15" height="15" fill="none" stroke="#6b7280" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
                <div><div class="dropdown-item-title">Sessions</div><div class="dropdown-item-sub">Manage active devices</div></div>
            </a>
            <hr class="dropdown-divider">
            <div class="dropdown-item" onclick="navbarLogout('{{ path('app_logout') }}', '{{ path('app_login') }}')" style="cursor:pointer;">
                <svg width="15" height="15" fill="none" stroke="#ef4444" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <div><div class="dropdown-item-title" style="color:#ef4444;">Sign out</div><div class="dropdown-item-sub">End your session</div></div>
            </div>
        </div>
    </div>

</header>
