{% extends 'layouts/auth.html.twig' %}

{% block auth_title %}Sign In | Koma Gardens & Resort{% endblock %}

{% block auth_content %}

    <div class="text-center mb-6">
        <img src="{{ asset('images/logo.png') }}" alt="Koma Gardens Logo" class="h-14 mx-auto mb-3">
        <h2 class="text-xl font-semibold text-gray-800">Staff Login</h2>
        <p class="text-sm text-gray-500 mt-1">Koma Gardens & Resort</p>
    </div>

    <div id="login-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded text-center"></div>

    <div id="login-panel">

        <form id="login-form" class="space-y-4">

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <input type="email" id="login-email"
                       placeholder="email@example.com" required autocomplete="email"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input type="password" id="login-password"
                       placeholder="••••••••" required autocomplete="current-password"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300">
            </div>

            <div class="flex items-center gap-2 text-sm text-gray-600">
                <input type="checkbox" id="login-remember" class="rounded">
                <label for="login-remember">Remember me</label>
            </div>

            <button type="submit" id="login-btn"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded text-sm font-semibold transition">
                Sign In
            </button>

        </form>

    </div>

    <div class="mt-6 text-center">
        <a href="{{ path('mpesa_login_page') }}" class="text-xs text-gray-400 hover:text-gray-600">
            Setting up a POS terminal?
        </a>
    </div>

    <script>
    function showError(msg) {
        const el = document.getElementById('login-error');
        el.textContent = msg;
        el.classList.remove('hidden');
    }

    function clearError() {
        document.getElementById('login-error').classList.add('hidden');
    }

    function setLoading(loading) {
        const btn = document.getElementById('login-btn');
        btn.disabled = loading;
        btn.textContent = loading ? 'Please wait…' : 'Sign In';
    }

    document.getElementById('login-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        clearError();
        setLoading(true);

        try {
            const body = new URLSearchParams({
                email:    document.getElementById('login-email').value,
                password: document.getElementById('login-password').value,
                remember: document.getElementById('login-remember').checked ? 1 : 0,
            });

            const res = await fetch('{{ path('app_login_auth') }}', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:    body.toString(),
            });

            const data = await res.json();

            if (data.success) {
                window.location.href = data.redirect;
            } else {
                showError(data.message ?? 'Login failed. Please try again.');
            }
        } catch (err) {
            showError('An unexpected error occurred. Please try again.');
            console.error(err);
        } finally {
            setLoading(false);
        }
    });
    </script>

{% endblock %}
