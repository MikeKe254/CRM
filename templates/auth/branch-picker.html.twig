{% extends 'layouts/auth.html.twig' %}
{% set tenant_subdomain = subdomain %}
{% set tenant_domain = baseDomain %}

{% block auth_title %}Select Branch | {{ session.company.name }}{% endblock %}

{% block auth_content %}

    <div class="text-center mb-6">
        <div class="mx-auto mb-3 flex items-center justify-center"
             style="width:48px;height:48px;background:#4f46e5;border-radius:12px;">
            <svg width="24" height="24" fill="none" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
        </div>
        <h2 class="text-xl font-semibold text-gray-800">Select a Branch</h2>
        <p class="text-sm text-gray-500 mt-1">{{ session.company.name }}</p>
    </div>

    <p class="text-sm text-gray-500 text-center mb-5">
        You have access to multiple branches. Choose one to continue.
    </p>

    <div class="space-y-2">
        {% for branch in branches %}
        <a href="{{ path('app_dashboard', {subdomain: tenant_subdomain, domain: tenant_domain, branch: branch.slug}) }}"
           class="flex items-center gap-3 w-full px-4 py-3 rounded-lg border border-gray-200 hover:border-indigo-400 hover:bg-indigo-50 transition-all text-left group">

            <div class="flex-shrink-0 flex items-center justify-center rounded-lg text-white font-semibold text-sm"
                 style="width:36px;height:36px;background:{% if branch.isHq %}#7c3aed{% else %}#4f46e5{% endif %};">
                {{ branch.name|first|upper }}
            </div>

            <div class="flex-1 min-w-0">
                <div class="font-medium text-gray-800 text-sm truncate group-hover:text-indigo-700">
                    {{ branch.name }}
                    {% if branch.isHq %}
                    <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-700">HQ</span>
                    {% endif %}
                </div>
                <div class="text-xs text-gray-400 truncate">
                    {{ branch.type|capitalize }}
                    {% if branch.depth > 0 %}
                        &bull; Level {{ branch.depth }}
                    {% endif %}
                </div>
            </div>

            <svg class="flex-shrink-0 text-gray-300 group-hover:text-indigo-400" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </a>
        {% endfor %}
    </div>

    <div class="mt-6 pt-4 border-t border-gray-100 text-center">
        <span class="text-xs text-gray-400">Signed in as <strong>{{ session.user.name }}</strong></span>
        <span class="mx-2 text-gray-200">&bull;</span>
        <button onclick="logoutFromPicker('{{ path('app_logout', {subdomain: tenant_subdomain, domain: tenant_domain}) }}', '{{ path('app_login', {subdomain: tenant_subdomain, domain: tenant_domain}) }}')"
                class="text-xs text-gray-400 hover:text-red-500 transition-colors">
            Sign out
        </button>
    </div>

<script>
function logoutFromPicker(logoutUrl, loginUrl) {
    fetch(logoutUrl, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' } })
        .finally(() => { window.location.href = loginUrl; });
}
</script>

{% endblock %}
