<!DOCTYPE html>
<script>
(function(){var t=localStorage.getItem('tm-theme');if(t)document.documentElement.setAttribute('data-theme',t);})();
</script>
<html lang="en" style="height:100%;background:#030712;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#030712">
    <title>{% block title %}Patronr Terminal{% endblock %}</title>

    {% block stylesheets %}
    <style>
        *, *::before, *::after { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        html, body { height: 100%; margin: 0; padding: 0; }
        body {
            background: #030712 !important;
            background-image: none !important;
            color: #fff;
            overflow: hidden;
            overscroll-behavior: none;
            user-select: none;
            -webkit-user-select: none;
            touch-action: none;
            font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        }
        /* Keypad & action button press feedback */
        .keypad-btn { cursor: pointer; transition: transform 0.05s, background-color 0.05s; }
        .keypad-btn:active { transform: scale(0.93); }
        .action-btn { cursor: pointer; transition: transform 0.05s, background-color 0.08s; }
        .action-btn:active { transform: scale(0.97); }
        @keyframes shake {
          0%,100%{ transform:translateX(0); }
          20%    { transform:translateX(-6px); }
          40%    { transform:translateX(6px); }
          60%    { transform:translateX(-4px); }
          80%    { transform:translateX(4px); }
        }
        /* Animations */
        @keyframes pulse-ring {
            0%   { transform: scale(1);   opacity: 0.6; }
            100% { transform: scale(1.6); opacity: 0; }
        }
        .pulse-ring { animation: pulse-ring 1.4s cubic-bezier(0.215,0.61,0.355,1) infinite; }
        @keyframes slide-up {
            from { transform: translateY(20px); opacity: 0; }
            to   { transform: translateY(0);    opacity: 1; }
        }
        .slide-up { animation: slide-up 0.22s ease-out both; }
        @keyframes fade-in {
            from { opacity: 0; } to { opacity: 1; }
        }
        .fade-in { animation: fade-in 0.2s ease-out both; }
        /* Area / payment chip states */
        .chip-active   { background:#059669 !important; border-color:#10b981 !important; color:#fff !important; }
        .chip-inactive { background:#1f2937; border-color:#374151; color:#fff; }
        /* Input that must never show device keyboard */
        input[readonly] { caret-color: transparent; }
        /* Horizontal scroll rows — allow pan-x, hide bar */
        .area-scroll-row { touch-action: pan-x; }
        .area-scroll-row::-webkit-scrollbar { display: none; }

        /* ── Light mode ───────────────────────────────────────────────── */
        [data-theme="light"] html,
        [data-theme="light"] body {
            background: #f8fafc !important;
            color: #0f172a !important;
        }

        /* Page-level dark backgrounds */
        [data-theme="light"] [style*="background:#030712"],
        [data-theme="light"] [style*="background: #030712"] { background: #f8fafc !important; }

        /* Card / surface */
        [data-theme="light"] [style*="background:#111827"],
        [data-theme="light"] [style*="background: #111827"] { background: #ffffff !important; color: #0f172a !important; }

        /* Elevated surface, chip inactive, keypad keys */
        [data-theme="light"] [style*="background:#1f2937"],
        [data-theme="light"] [style*="background: #1f2937"] { background: #f1f5f9 !important; color: #334155 !important; }

        /* Hover / pressed states */
        [data-theme="light"] [style*="background:#374151"],
        [data-theme="light"] [style*="background: #374151"] { background: #e2e8f0 !important; }

        /* Borders & dividers */
        [data-theme="light"] [style*="border-bottom:1px solid #1f2937"] { border-bottom-color: #e2e8f0 !important; }
        [data-theme="light"] [style*="border:1px solid #1f2937"]        { border-color: #e2e8f0 !important; }
        [data-theme="light"] [style*="border: 1px solid #1f2937"]       { border-color: #e2e8f0 !important; }

        /* White text inside dark containers */
        [data-theme="light"] [style*="background:#111827"] [style*="color:#fff"],
        [data-theme="light"] [style*="background:#1f2937"] [style*="color:#fff"] { color: #0f172a !important; }

        /* Stand-alone white text */
        [data-theme="light"] [style*="color:#9ca3af"] { color: #64748b !important; }
        [data-theme="light"] [style*="color: #9ca3af"] { color: #64748b !important; }
        [data-theme="light"] [style*="color:#4b5563"]  { color: #475569 !important; }
        [data-theme="light"] [style*="color: #4b5563"] { color: #475569 !important; }
        [data-theme="light"] [style*="color:#6b7280"]  { color: #64748b !important; }

        /* Light-gray text (paybill number, input values) → dark */
        [data-theme="light"] [style*="color:#d1d5db"],
        [data-theme="light"] [style*="color: #d1d5db"] { color: #1e293b !important; }

        /* Bright lime (M-Pesa Payment label) → dark green */
        [data-theme="light"] [style*="color:#4ade80"],
        [data-theme="light"] [style*="color: #4ade80"] { color: #15803d !important; }

        /* Very light yellow (loyalty program name) → dark amber */
        [data-theme="light"] [style*="color:#fde68a"],
        [data-theme="light"] [style*="color: #fde68a"] { color: #92400e !important; }

        /* Loyalty banner — gradient version (step 4) */
        [data-theme="light"] [style*="background:linear-gradient(135deg,rgba(161,98,7"] {
            background: #fef3c7 !important;
            border-color: #fcd34d !important;
        }

        /* Loyalty banner — flat rgba version (enroll page) */
        [data-theme="light"] [style*="background:rgba(161,98,7,0.15)"],
        [data-theme="light"] [style*="background:rgba(161,98,7,0.3)"] {
            background: #fef3c7 !important;
            border-color: #fcd34d !important;
        }

        /* Loyalty status pill rgba amber bg (JS-set, new customer state) */
        [data-theme="light"] [style*="background:rgba(234,179,8,0.15)"] {
            background: #fffbeb !important;
            border-color: #fcd34d !important;
        }

        /* Enrolled pill (JS-set green state) */
        [data-theme="light"] [style*="background:rgba(5,150,105,0.2)"] {
            background: rgba(5,150,105,0.1) !important;
        }
        [data-theme="light"] [style*="color:#34d399"] { color: #047857 !important; }

        /* All white text → dark in light mode */
        [data-theme="light"] [style*="color:#fff"],
        [data-theme="light"] [style*="color: #fff"],
        [data-theme="light"] [style*="color:#ffffff"] { color: #0f172a !important; }

        /* Keep amber accent color in light mode */
        [data-theme="light"] [style*="color:#eab308"] { color: #b45309 !important; }

        /* Restore white text + children on colored action buttons */
        [data-theme="light"] [style*="background:#059669"],
        [data-theme="light"] [style*="background:#059669"] *,
        [data-theme="light"] [style*="background:#16a34a"],
        [data-theme="light"] [style*="background:#16a34a"] *,
        [data-theme="light"] [style*="background:#2563eb"],
        [data-theme="light"] [style*="background:#2563eb"] *,
        [data-theme="light"] [style*="background:#7c3aed"],
        [data-theme="light"] [style*="background:#7c3aed"] *,
        [data-theme="light"] [style*="background:#d97706"],
        [data-theme="light"] [style*="background:#d97706"] * { color: #ffffff !important; }

        /* CSS-class-based elements (pin keypad from terminal.html.twig layout) */
        [data-theme="light"] .pin-key,
        [data-theme="light"] #pin-clear,
        [data-theme="light"] #pin-back { background: #f1f5f9 !important; color: #0f172a !important; }
        [data-theme="light"] .pin-key:hover,
        [data-theme="light"] #pin-clear:hover,
        [data-theme="light"] #pin-back:hover { background: #e2e8f0 !important; }
        [data-theme="light"] .chip-inactive { background: #f1f5f9 !important; border-color: #e2e8f0 !important; color: #334155 !important; }

        /* Theme toggle button */
        #tm-theme-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid #1f2937;
            background: #111827;
            color: #9ca3af;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s, color 0.15s;
        }
        [data-theme="light"] #tm-theme-btn {
            background: #ffffff !important;
            border-color: #e2e8f0 !important;
            color: #475569 !important;
        }
    </style>
    {% endblock %}

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body data-patronr="true">
    {% block body %}{% endblock %}

    <button id="tm-theme-btn" aria-label="Toggle theme">
        {# Sun icon — shown in dark mode #}
        <svg id="tm-icon-sun" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M18.66 5.34l1.41-1.41"/>
        </svg>
        {# Moon icon — shown in light mode #}
        <svg id="tm-icon-moon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
        </svg>
    </button>

    <script>
    (function () {
        var html = document.documentElement;
        var btn  = document.getElementById('tm-theme-btn');
        var sun  = document.getElementById('tm-icon-sun');
        var moon = document.getElementById('tm-icon-moon');

        function applyTheme(theme) {
            html.setAttribute('data-theme', theme);
            localStorage.setItem('tm-theme', theme);
            if (theme === 'light') {
                sun.style.display  = 'none';
                moon.style.display = '';
            } else {
                sun.style.display  = '';
                moon.style.display = 'none';
            }
        }

        // Sync icon with current theme on load
        applyTheme(html.getAttribute('data-theme') || 'dark');

        btn.addEventListener('click', function () {
            applyTheme(html.getAttribute('data-theme') === 'light' ? 'dark' : 'light');
        });
    })();
    </script>
</body>
</html>
