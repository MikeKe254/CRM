{% extends 'layouts/app.html.twig' %}

{% block content %}

<div class="flex items-start justify-between mb-6">
    <div>
        <h1 class="text-xl font-semibold text-gray-900">{% block admin_title %}Admin{% endblock %}</h1>
        <p class="text-sm text-gray-500 mt-0.5">{% block admin_subtitle %}{% endblock %}</p>
    </div>
    <div class="flex items-center gap-3">{% block admin_actions %}{% endblock %}</div>
</div>

{% for message in app.flashes('success') %}
<div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-700 text-sm rounded-lg">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
<div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg">{{ message }}</div>
{% endfor %}

{% block admin_content %}{% endblock %}

{# ── DRAWER ── #}
<div id="admin-drawer-overlay"
     class="hidden fixed inset-0 bg-black/30 z-[300] backdrop-blur-sm"
     onclick="closeDrawer()"></div>

<div id="admin-drawer"
     class="fixed top-0 right-0 h-screen w-[420px] max-w-[95vw] bg-white z-[301] shadow-2xl flex flex-col">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 flex-shrink-0">
        <span id="admin-drawer-title" class="text-base font-semibold text-gray-900"></span>
        <button onclick="closeDrawer()" class="text-gray-400 hover:text-gray-700 p-1 rounded transition-colors">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>
    <div id="admin-drawer-body" class="flex-1 overflow-y-auto p-5"></div>
    <div id="admin-drawer-footer" class="flex gap-3 px-5 py-4 border-t border-gray-100 flex-shrink-0"></div>
</div>

<div id="admin-modal-backdrop"
     class="hidden fixed inset-0 z-[310] bg-slate-950/40 backdrop-blur-sm px-4 items-center justify-center">
    <div id="admin-modal-card"
         class="w-full max-w-md rounded-2xl bg-white shadow-2xl ring-1 ring-slate-200/70 transform transition duration-200 scale-95 opacity-0">
        <div class="px-6 pt-6">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full" id="admin-modal-icon-wrap">
                <div id="admin-modal-icon" class="flex h-6 w-6 items-center justify-center"></div>
            </div>
            <div id="admin-modal-title" class="mt-4 text-center text-base font-semibold text-slate-900"></div>
            <div id="admin-modal-message" class="mt-2 text-center text-sm leading-6 text-slate-500"></div>
        </div>
        <div class="flex gap-3 px-6 py-5" id="admin-modal-buttons">
            <button id="admin-modal-cancel"
                    type="button"
                    class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-600 transition hover:bg-slate-50">
                Cancel
            </button>
            <button id="admin-modal-confirm"
                    type="button"
                    class="flex-1 rounded-xl px-4 py-2.5 text-sm font-semibold text-white transition">
                Confirm
            </button>
        </div>
    </div>
</div>

{% block admin_scripts %}{% endblock %}

{% endblock %}
